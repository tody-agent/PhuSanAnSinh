---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("handbook")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryMap: Record<string, string> = {
  "nen-tang": "Nền Tảng Y Khoa",
  "vo-sinh-hiem-muon": "Vô Sinh & Hiếm Muộn",
  "ho-tro-sinh-san": "Hỗ Trợ Sinh Sản",
  "di-truyen": "Di Truyền Học",
  "phu-khoa": "Phụ Khoa",
  "san-khoa": "Sản Khoa",
  "hau-san": "Hậu Sản",
};

const volumeMap: Record<string, string> = {
  "nen-tang": "Tập 1",
  "vo-sinh-hiem-muon": "Tập 2",
  "ho-tro-sinh-san": "Tập 3",
  "di-truyen": "Tập 4",
  "phu-khoa": "Tập 5",
  "san-khoa": "Tập 6",
  "hau-san": "Tập 7",
};

const categories = [...new Set(posts.map((p) => p.data.category))];
---

<BaseLayout
  title="Sản Phụ Handbook — Kiến Thức Y Khoa Chuyên Sâu | An Sinh"
  description="Tổng hợp kiến thức y khoa chuyên sâu về sản phụ khoa: nền tảng, vô sinh, hỗ trợ sinh sản, di truyền, phụ khoa, sản khoa, hậu sản. Biên soạn bởi giáo sư chuyên khoa."
>
  <section class="section" id="handbook-listing">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Sản Phụ Handbook</span>
        <h1>Kiến thức y khoa chuyên sâu</h1>
        <p>
          Tổng hợp 7 tập kiến thức sản phụ khoa — từ nền tảng giải phẫu đến
          lâm sàng chuyên sâu. Biên soạn bởi giáo sư chuyên khoa.
        </p>
      </div>

      {
        categories.length > 1 && (
          <nav class="blog-categories" aria-label="Danh mục handbook">
            <a href="/san-phu-handbook" class="cat-tag active" data-cat="all">
              Tất cả ({posts.length})
            </a>
            {categories.map((cat) => (
              <a
                href={`#`}
                class="cat-tag"
                data-cat={cat}
              >
                {volumeMap[cat] && (
                  <span class="cat-volume">{volumeMap[cat]}</span>
                )}
                {categoryMap[cat] || cat}
              </a>
            ))}
          </nav>
        )
      }

      {
        posts.length === 0 ? (
          <div class="text-center" style="padding: var(--space-4xl) 0;">
            <p>Bài viết đang được cập nhật. Vui lòng quay lại sau!</p>
          </div>
        ) : (
          <div class="grid-3 blog-grid" id="handbook-grid">
            {posts.map((post) => (
              <a
                href={`/san-phu-handbook/${post.id.replace(/\.mdx?$/, "")}`}
                class="card blog-card handbook-card"
                data-category={post.data.category}
                id={`hb-${post.id.replace(/\.mdx?$/, "")}`}
              >
                <div class="blog-card-body">
                  <div class="handbook-card-badges">
                    <span class="blog-card-cat">
                      {categoryMap[post.data.category] || post.data.category}
                    </span>
                    {post.data.volume && (
                      <span class="handbook-card-vol">{post.data.volume}</span>
                    )}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="blog-card-meta">
                    <span>{post.data.author}</span>
                    {post.data.readingTime && (
                      <span>{post.data.readingTime} phút đọc</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-categories {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--space-3xl);
  }

  .cat-tag {
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--surface);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: all var(--transition-fast);
    min-height: 36px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .cat-tag:hover,
  .cat-tag.active {
    background: var(--primary);
    color: #fff;
    border-color: var(--primary);
  }

  .cat-volume {
    font-size: 0.6875rem;
    font-weight: 700;
    opacity: 0.7;
  }

  .handbook-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
    padding: 0;
    border-left: 3px solid var(--primary);
    transition: all var(--transition-fast);
  }

  .handbook-card:hover {
    border-left-color: var(--accent, var(--primary));
    transform: translateY(-2px);
  }

  .handbook-card-badges {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .handbook-card-vol {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-muted);
    background: var(--surface-alt);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-light);
  }

  .blog-card-body {
    padding: var(--space-xl);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-cat {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .handbook-card h3 {
    font-size: 1.0625rem;
    margin-bottom: var(--space-sm);
    color: var(--text-primary);
    line-height: 1.4;
  }

  .handbook-card p {
    font-size: 0.875rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-light);
  }

  /* Hide cards on filter */
  .handbook-card.hidden {
    display: none;
  }
</style>

<script>
  // Client-side category filter
  document.addEventListener("DOMContentLoaded", () => {
    const tags = document.querySelectorAll(".cat-tag[data-cat]");
    const cards = document.querySelectorAll(".handbook-card[data-category]");

    tags.forEach((tag) => {
      tag.addEventListener("click", (e) => {
        e.preventDefault();
        const cat = (tag as HTMLElement).dataset.cat;

        // Update active state
        tags.forEach((t) => t.classList.remove("active"));
        tag.classList.add("active");

        // Filter cards
        cards.forEach((card) => {
          if (cat === "all" || (card as HTMLElement).dataset.category === cat) {
            card.classList.remove("hidden");
          } else {
            card.classList.add("hidden");
          }
        });
      });
    });
  });
</script>
