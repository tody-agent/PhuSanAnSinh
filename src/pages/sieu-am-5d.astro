---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/landing.css";

const pageTitle =
    "Siêu Âm Thai 5D Bắc Ninh — Nhìn Thấy Con Yêu Rõ Nét Nhất | An Sinh";
const pageDescription =
    "Siêu âm thai 5D tại Từ Sơn, Bắc Ninh. Máy Samsung thế hệ mới, bác sĩ 20+ năm kinh nghiệm. Xem kết quả online, hình ảnh sắc nét. Đặt lịch ngay!";

const faqs = [
    {
        q: "Siêu âm 5D khác gì siêu âm 4D?",
        a: "Siêu âm 5D cho hình ảnh sắc nét hơn 4D nhờ công nghệ xử lý hình ảnh tiên tiến, giúp nhìn rõ khuôn mặt, các bộ phận của thai nhi. Ở An Sinh, chúng tôi sử dụng máy Samsung thế hệ mới cho chất lượng hình ảnh tốt nhất.",
    },
    {
        q: "Nên siêu âm 5D vào tuần thai bao nhiêu?",
        a: "Thời điểm lý tưởng nhất để siêu âm 5D là tuần 20-28 khi thai nhi đã hình thành đầy đủ nhưng vẫn đủ không gian để có hình ảnh đẹp. Tuy nhiên, mỗi giai đoạn thai kỳ đều có mục đích siêu âm riêng.",
    },
    {
        q: "Siêu âm 5D có an toàn cho mẹ và bé không?",
        a: "Hoàn toàn an toàn. Siêu âm sử dụng sóng âm, không có bức xạ. Đây là phương pháp được WHO và các tổ chức y tế thế giới khuyên dùng để theo dõi thai kỳ.",
    },
    {
        q: "Có cần nhịn ăn trước khi siêu âm không?",
        a: "Không cần nhịn ăn. Bạn chỉ cần đến đúng giờ hẹn. Nếu siêu âm thai 3 tháng đầu, nên uống đủ nước để bàng quang đầy giúp hình ảnh rõ hơn.",
    },
    {
        q: "Làm sao xem kết quả siêu âm online?",
        a: "Sau khi siêu âm, bác sĩ sẽ cung cấp link hoặc mã tra cứu. Bạn có thể xem lại hình ảnh, video siêu âm ngay trên điện thoại — tiện lợi chia sẻ cho gia đình.",
    },
    {
        q: "Chi phí siêu âm 5D tại An Sinh là bao nhiêu?",
        a: "Chi phí siêu âm 5D tại An Sinh rất hợp lý, được niêm yết công khai. Vui lòng liên hệ hotline 0899 268 299 hoặc đặt lịch để được tư vấn chi tiết.",
    },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
    <!-- Breadcrumb + Schema -->
    <nav class="landing-breadcrumb" aria-label="Breadcrumb">
        <div class="container">
            <ol itemscope itemtype="https://schema.org/BreadcrumbList">
                <li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <a itemprop="item" href="/"
                        ><span itemprop="name">Trang chủ</span>
                    </a>
                    <meta itemprop="position" content="1" />
                </li>
                <li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <span itemprop="name">Siêu âm 5D</span>
                    <meta itemprop="position" content="2" />
                </li>
            </ol>
        </div>
    </nav>

    <!-- HERO — SB7: Hero + Desire -->
    <section class="landing-hero" id="hero">
        <div class="container landing-hero-inner">
            <div class="landing-hero-content">
                <span class="landing-hero-badge"
                    >⭐ Đánh giá 5.0 trên Google Maps</span
                >
                <h1>
                    Siêu Âm Thai 5D — Nhìn Thấy Con Yêu <span
                        class="text-accent-color">Rõ Nét Nhất</span
                    >
                </h1>
                <p class="landing-hero-sub">
                    Từ lo lắng → an tâm chỉ sau 15 phút. Máy Samsung thế hệ mới,
                    bác sĩ 20+ năm kinh nghiệm giải thích tận tình. Xem kết quả
                    online ngay trên điện thoại.
                </p>
                <div class="landing-hero-actions">
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-accent btn-lg"
                        id="sieu-am-hero-cta"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            ><rect
                                x="3"
                                y="4"
                                width="18"
                                height="18"
                                rx="2"
                                ry="2"></rect><line
                                x1="16"
                                y1="2"
                                x2="16"
                                y2="6"></line><line x1="8" y1="2" x2="8" y2="6"
                            ></line><line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        Đặt Lịch Siêu Âm 5D
                    </a>
                    <a
                        href="tel:0899268299"
                        class="btn btn-outline btn-lg"
                        id="sieu-am-hero-call"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            ><path
                                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                            ></path>
                        </svg>
                        Gọi: 0899 268 299
                    </a>
                </div>
            </div>
            <div class="landing-hero-visual" aria-hidden="true">
                <div class="hero-feature-grid">
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="1.5"
                            ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                        </svg>
                        <span>Máy 5D Samsung</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            ><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"
                            ></path><circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <span>BS 20+ năm</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="1.5"
                            ><rect
                                x="2"
                                y="3"
                                width="20"
                                height="14"
                                rx="2"
                                ry="2"></rect><line
                                x1="8"
                                y1="21"
                                x2="16"
                                y2="21"></line><line
                                x1="12"
                                y1="17"
                                x2="12"
                                y2="21"></line>
                        </svg>
                        <span>Kết quả Online</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg>
                        <span>An Toàn 100%</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TRUST BAR -->
    <section class="landing-trust" aria-label="Chỉ số tin cậy">
        <div class="container">
            <div class="trust-metrics">
                <div class="trust-metric">
                    <span class="trust-metric-number">5.0</span>
                    <span class="trust-metric-label">⭐ Google Maps</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">20+</span>
                    <span class="trust-metric-label">Năm kinh nghiệm</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">10.000+</span>
                    <span class="trust-metric-label">Ca siêu âm</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">5D</span>
                    <span class="trust-metric-label">Công nghệ Samsung</span>
                </div>
            </div>
        </div>
    </section>

    <!-- PROBLEM — SB7: 3-Level Problem -->
    <section class="section landing-problems" id="van-de">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Chúng tôi hiểu</span>
                <h2>Mang thai lần đầu — mọi thứ đều lo lắng</h2>
                <p>
                    Bạn xứng đáng được đồng hành bởi bác sĩ thật sự quan tâm và
                    giải thích tận tình.
                </p>
            </div>
            <div class="grid-3">
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><circle cx="12" cy="12" r="10"></circle><path
                                d="M8 15s1.5 2 4 2 4-2 4-2"></path><line
                                x1="9"
                                y1="9"
                                x2="9.01"
                                y2="9"></line><line
                                x1="15"
                                y1="9"
                                x2="15.01"
                                y2="9"></line>
                        </svg>
                    </div>
                    <h3>Lo lắng thai nhi có khỏe không</h3>
                    <p>
                        "Em bé có phát triển bình thường không?" — Câu hỏi bạn
                        tự hỏi mỗi ngày. Siêu âm 5D giúp bạn thấy rõ và an tâm.
                    </p>
                </div>
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><circle cx="12" cy="12" r="10"></circle><polyline
                                points="12 6 12 12 16 14"></polyline>
                        </svg>
                    </div>
                    <h3>Sợ bỏ lỡ mốc quan trọng</h3>
                    <p>
                        Thai kỳ có nhiều mốc siêu âm cần thiết. Bỏ lỡ một mốc có
                        thể ảnh hưởng đến việc tầm soát dị tật sớm.
                    </p>
                </div>
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><path
                                d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
                            ></path><circle cx="12" cy="10" r="3"></circle>
                        </svg>
                    </div>
                    <h3>Đi HN xa và vất vả</h3>
                    <p>
                        Lên Hà Nội mất cả ngày, xếp hàng 2-3 tiếng. Bạn cần siêu
                        âm 5D chất lượng cao ngay tại Từ Sơn — tiện lợi, nhanh
                        chóng.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- GUIDE — SB7: Empathy + Authority -->
    <section class="section section-alt" id="bac-si">
        <div class="container">
            <div class="landing-guide-layout">
                <div>
                    <span class="section-label">Bác sĩ siêu âm</span>
                    <h2>
                        Bác sĩ chuyên khoa với <span class="text-primary-color"
                            >20+ năm kinh nghiệm</span>
                    </h2>
                    <p>
                        Chúng tôi hiểu rằng mỗi lần siêu âm, bạn mang theo cả
                        nỗi lo và niềm háo hức được nhìn thấy con. Đó là lý do
                        chúng tôi không chỉ siêu âm — mà còn giải thích tận tình
                        từng hình ảnh, từng chỉ số.
                    </p>
                    <ul class="guide-credentials-list">
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            Thạc sĩ chuyên ngành Sản phụ khoa
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            Hơn 10.000 ca siêu âm thai thành công
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            Máy siêu âm Samsung 5D thế hệ mới nhất
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            Liên kết với bệnh viện tuyến trên
                        </li>
                    </ul>
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-primary"
                        id="sieu-am-guide-cta">Đặt Lịch Siêu Âm 5D</a
                    >
                </div>
                <div class="guide-card-visual" aria-hidden="true">
                    <svg
                        viewBox="0 0 120 120"
                        width="120"
                        height="120"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <circle cx="60" cy="60" r="60" fill="var(--primary)"
                        ></circle>
                        <circle
                            cx="60"
                            cy="45"
                            r="20"
                            fill="white"
                            opacity="0.3"></circle>
                        <path
                            d="M60 70c-18 0-32 10-32 22v8h64v-8c0-12-14-22-32-22z"
                            fill="white"
                            opacity="0.2"></path>
                        <circle
                            cx="60"
                            cy="45"
                            r="18"
                            fill="white"
                            opacity="0.8"></circle>
                        <path
                            d="M52 42c0-1 1-2 2-2h12c1 0 2 1 2 2v6c0 1-1 2-2 2H54c-1 0-2-1-2-2z"
                            fill="var(--primary)"
                            opacity="0.4"></path>
                    </svg>
                    <div class="guide-card-quote">
                        <p>
                            "Mỗi lần siêu âm, tôi luôn dành thời gian giải thích
                            để mẹ bầu hiểu rõ tình trạng của bé. An tâm của bạn
                            là ưu tiên số 1."
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3-STEP PLAN -->
    <section class="section" id="quy-trinh">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Đơn giản & Nhanh chóng</span>
                <h2>3 bước để siêu âm 5D tại An Sinh</h2>
            </div>
            <div class="landing-steps-grid">
                <div class="landing-step">
                    <div class="landing-step-number">1</div>
                    <h3>Đặt lịch hẹn</h3>
                    <p>
                        Online hoặc gọi hotline 0899 268 299. Chọn ngày giờ phù
                        hợp, không cần chờ đợi.
                    </p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-number">2</div>
                    <h3>Siêu âm với bác sĩ</h3>
                    <p>
                        Bác sĩ 20+ năm kinh nghiệm siêu âm, giải thích tận tình
                        từng hình ảnh, chỉ số.
                    </p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-number">3</div>
                    <h3>Nhận kết quả online</h3>
                    <p>
                        Xem lại video, hình ảnh siêu âm 5D ngay trên điện thoại.
                        Chia sẻ cho gia đình.
                    </p>
                </div>
            </div>
            <div class="text-center mt-2">
                <a
                    href="https://phusanansinh.com/dat-lich-hen-kham.html"
                    class="btn btn-accent btn-lg"
                    id="sieu-am-steps-cta">Đặt Lịch Siêu Âm Ngay</a
                >
            </div>
        </div>
    </section>

    <!-- SOCIAL PROOF — Testimonials -->
    <section class="section section-alt" id="review">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Mẹ bầu nói gì</span>
                <h2>Hàng nghìn mẹ bầu tin tưởng siêu âm tại An Sinh</h2>
            </div>
            <div class="grid-3">
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Siêu âm 5D ở đây rõ nét lắm, lần nào đi cũng được bác
                        giải thích rất kỹ. Thấy mặt con rõ ràng, cả nhà vui
                        lắm!"
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">M</div>
                        <div class="landing-testimonial-meta">
                            <strong>Chị M.</strong>
                            <span>Siêu âm 5D — 24 tuần</span>
                        </div>
                    </div>
                </div>
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Bác sĩ rất tận tâm, giải thích kỹ lưỡng từng chỉ số.
                        Thai kỳ của mình suôn sẻ nhờ được theo dõi sát sao từ
                        ngày đầu."
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">T</div>
                        <div class="landing-testimonial-meta">
                            <strong>Chị T.</strong>
                            <span>Khám thai định kỳ</span>
                        </div>
                    </div>
                </div>
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Gần nhà, máy móc hiện đại, không phải lên HN xa xôi.
                        Kết quả xem online luôn, tiện lắm. Recommend cho các mẹ
                        bầu!"
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">L</div>
                        <div class="landing-testimonial-meta">
                            <strong>Chị L.</strong>
                            <span>Siêu âm 5D — 28 tuần</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- STAKES — Failure vs Success -->
    <section class="section" id="stakes">
        <div class="container">
            <div class="landing-stakes">
                <div class="landing-stakes-fail">
                    <h3 class="stakes-heading fail">
                        Đừng để sự trì hoãn ảnh hưởng thai kỳ
                    </h3>
                    <ul class="landing-stakes-list">
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--error)"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="15"
                                    y1="9"
                                    x2="9"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line><line
                                    x1="9"
                                    y1="9"
                                    x2="15"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line>
                            </svg>
                            Bỏ lỡ mốc siêu âm 12-13 tuần — mất cơ hội tầm soát dị
                            tật sớm
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--error)"
                                aria-hidden="true"
