---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/landing.css";
import reviewsData from "../data/reviews.json";

const pageTitle = "Cảm Nhận Khách Hàng — Phòng Khám An Sinh | 4.9★ Google Maps";
const pageDescription =
    "Đánh giá thực từ khách hàng về Phòng khám sản phụ khoa An Sinh, Từ Sơn, Bắc Ninh. 4.9/5 sao trên Google Maps với hơn 50 đánh giá. Xem cảm nhận ngay!";

const topicLabels: Record<string, string> = {
    all: "Tất cả",
    "vo-sinh": "Điều trị vô sinh",
    "kham-thai": "Khám thai",
    "sieu-am": "Siêu âm 5D",
    "phu-khoa": "Phụ khoa",
    "nam-khoa": "Nam khoa",
    "tranh-thai": "Tránh thai",
};

const reviews = reviewsData.reviews;
---

<BaseLayout title={pageTitle} description={pageDescription}>
    <!-- Breadcrumb -->
    <nav class="landing-breadcrumb" aria-label="Breadcrumb">
        <div class="container">
            <ol itemscope itemtype="https://schema.org/BreadcrumbList">
                <li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <a itemprop="item" href="/"
                        ><span itemprop="name">Trang chủ</span>
                    </a>
                    <meta itemprop="position" content="1" />
                </li>
                <li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <span itemprop="name">Cảm nhận khách hàng</span>
                    <meta itemprop="position" content="2" />
                </li>
            </ol>
        </div>
    </nav>

    <!-- HERO -->
    <section class="reviews-hero" id="hero">
        <div class="container reviews-hero-inner">
            <div class="reviews-hero-content">
                <span class="landing-hero-badge"
                    >⭐ 4.9/5 sao trên Google Maps</span
                >
                <h1>
                    Cảm Nhận Từ <span class="text-accent-color">Khách Hàng</span
                    > Của Chúng Tôi
                </h1>
                <p class="reviews-hero-sub">
                    Hơn <strong>50 đánh giá thực</strong> trên Google Maps — mỗi
                    lời chia sẻ là động lực để chúng tôi phục vụ tốt hơn mỗi ngày.
                </p>
                <div class="reviews-hero-stats">
                    <div class="reviews-stat">
                        <span class="reviews-stat-number">4.9</span>
                        <span class="reviews-stat-label">Điểm trung bình</span>
                    </div>
                    <div class="reviews-stat-divider"></div>
                    <div class="reviews-stat">
                        <span class="reviews-stat-number">50+</span>
                        <span class="reviews-stat-label">Đánh giá</span>
                    </div>
                    <div class="reviews-stat-divider"></div>
                    <div class="reviews-stat">
                        <span class="reviews-stat-number">96%</span>
                        <span class="reviews-stat-label">5 sao</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TOPIC FILTERS -->
    <section class="section" id="reviews-section">
        <div class="container">
            <div class="reviews-filter-bar">
                {
                    Object.entries(topicLabels).map(([key, label]) => (
                        <button
                            class={`reviews-filter-btn ${
                                key === "all" ? "active" : ""
                            }`}
                            data-topic={key}
                        >
                            {label}
                        </button>
                    ))
                }
            </div>

            <!-- Reviews Grid -->
            <div class="reviews-grid" id="reviews-grid">
                {
                    reviews.map((review) => (
                        <div
                            class="reviews-card"
                            data-topics={review.topics.join(",")}
                            data-id={review.id}
                        >
                            <div class="reviews-card-header">
                                <div class="reviews-card-avatar">
                                    {review.name.charAt(0).toUpperCase()}
                                </div>
                                <div class="reviews-card-meta">
                                    <strong class="reviews-card-name">
                                        {review.name}
                                    </strong>
                                    <span class="reviews-card-time">
                                        {review.time}
                                    </span>
                                </div>
                                {review.hasPhotos && (
                                    <span
                                        class="reviews-card-photo-badge"
                                        title="Có ảnh đính kèm"
                                    >
                                        📷
                                    </span>
                                )}
                            </div>
                            <div
                                class="reviews-card-stars"
                                aria-label={`${review.stars} sao`}
                            >
                                {"★".repeat(review.stars)}
                                {"☆".repeat(5 - review.stars)}
                            </div>
                            <p class="reviews-card-text">"{review.text}"</p>
                            <div class="reviews-card-topics">
                                {review.topics.map((topic: string) => {
                                    const mapping =
                                        reviewsData.topicMapping[
                                            topic as keyof typeof reviewsData.topicMapping
                                        ];
                                    return mapping ? (
                                        <span class="reviews-topic-tag">
                                            {mapping.label}
                                        </span>
                                    ) : null;
                                })}
                            </div>
                        </div>
                    ))
                }
            </div>

            <!-- Google Maps CTA -->
            <div class="text-center mt-2">
                <a
                    href="https://www.google.com/search?hl=vi-VN&gl=vn&q=Ph%C3%B2ng+kh%C3%A1m+An+Sinh,+416+Minh+Khai,+%C4%90%E1%BB%93ng+Nguy%C3%AAn,+T%E1%BB%AB+S%C6%A1n,+B%E1%BA%AFc+Ninh&ludocid=16582806101668951572#lrd=0x31350878152011ed:0xe621f64a3d287614,1"
                    class="btn btn-outline btn-lg"
                    target="_blank"
                    rel="noopener noreferrer"
                    id="reviews-google-cta"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <path
                            d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"
                        ></path>
                        <polyline points="15 3 21 3 21 9"></polyline>
                        <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                    Xem tất cả trên Google Maps →
                </a>
            </div>
        </div>
    </section>

    <!-- FINAL CTA -->
    <section class="landing-final-cta">
        <div class="container">
            <h2>Hãy Để An Sinh Đồng Hành Cùng Bạn</h2>
            <p>
                Hơn 50 khách hàng đã tin tưởng và hài lòng. Bạn cũng xứng đáng
                được chăm sóc tận tâm.
            </p>
            <div class="cta-actions">
                <a
                    href="https://phusanansinh.com/dat-lich-hen-kham.html"
                    class="btn btn-white btn-lg"
                    id="reviews-final-cta">Đặt Lịch Khám Ngay</a
                >
                <a
                    href="tel:0899268299"
                    class="btn-outline-white"
                    id="reviews-final-call"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <path
                            d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                        ></path>
                    </svg>
                    Gọi: 0899 268 299
                </a>
            </div>
        </div>
    </section>

    <!-- Review Schema -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "MedicalClinic",
            name: "Phòng khám sản phụ khoa An Sinh",
            address: {
                "@type": "PostalAddress",
                streetAddress: "416 Minh Khai, Đồng Nguyên",
                addressLocality: "Từ Sơn",
                addressRegion: "Bắc Ninh",
                addressCountry: "VN",
            },
            telephone: "0899268299",
            aggregateRating: {
                "@type": "AggregateRating",
                ratingValue: "4.9",
                bestRating: "5",
                worstRating: "1",
                ratingCount: "50",
            },
            review: reviews.slice(0, 5).map((r) => ({
                "@type": "Review",
                author: { "@type": "Person", name: r.name },
                datePublished: "2025-01-01",
                reviewRating: {
                    "@type": "Rating",
                    ratingValue: r.stars.toString(),
                    bestRating: "5",
                },
                reviewBody: r.text,
            })),
        })}
    ></script>

    <!-- Filter Script -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const btns = document.querySelectorAll<HTMLButtonElement>(
                ".reviews-filter-btn"
            );
            const cards =
                document.querySelectorAll<HTMLElement>(".reviews-card");

            btns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    btns.forEach((b) => b.classList.remove("active"));
                    btn.classList.add("active");
                    const topic = btn.dataset.topic;

                    cards.forEach((card) => {
                        const topics = card.dataset.topics?.split(",") || [];
                        if (topic === "all" || topics.includes(topic || "")) {
                            card.style.display = "";
                            card.style.animation =
                                "fadeInUp 0.4s ease forwards";
                        } else {
                            card.style.display = "none";
                        }
                    });
                });
            });
        });
    </script>
</BaseLayout>

<style>
    /* ══ Reviews Hero ══ */
    .reviews-hero {
        background: linear-gradient(
            135deg,
            var(--primary) 0%,
            var(--primary-dark) 100%
        );
        color: #fff;
        padding: var(--space-4xl) 0 var(--space-3xl);
        text-align: center;
    }
    .reviews-hero h1 {
        color: #fff;
        margin-bottom: var(--space-md);
    }
    .reviews-hero-sub {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1.125rem;
        max-width: 600px;
        margin: 0 auto var(--space-xl);
    }
    .reviews-hero-stats {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-xl);
        flex-wrap: wrap;
    }
    .reviews-stat {
        text-align: center;
    }
    .reviews-stat-number {
        display: block;
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1;
    }
    .reviews-stat-label {
        font-size: 0.875rem;
        opacity: 0.85;
        margin-top: var(--space-xs);
        display: block;
    }
    .reviews-stat-divider {
        width: 1px;
        height: 48px;
        background: rgba(255, 255, 255, 0.3);
    }

    /* ══ Filter Bar ══ */
    .reviews-filter-bar {
        display: flex;
        gap: var(--space-sm);
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: var(--space-2xl);
    }
    .reviews-filter-btn {
        padding: 0.5rem 1.25rem;
        border: 2px solid var(--border);
        border-radius: var(--radius-full);
        background: transparent;
        color: var(--text-secondary);
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all var(--transition-fast);
        min-height: 44px;
    }
    .reviews-filter-btn:hover {
        border-color: var(--primary);
        color: var(--primary);
    }
    .reviews-filter-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
    }

    /* ══ Reviews Grid ══ */
    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-xl);
    }

    /* ══ Review Card ══ */
    .reviews-card {
        background: var(--surface);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-lg);
        padding: var(--space-xl);
        transition: all var(--transition-base);
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }
    .reviews-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-3px);
    }
    .reviews-card-header {
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }
    .reviews-card-avatar {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-full);
        background: linear-gradient(
            135deg,
            var(--primary) 0%,
            var(--primary-dark) 100%
        );
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.125rem;
        flex-shrink: 0;
    }
    .reviews-card-meta {
        flex: 1;
    }
    .reviews-card-name {
        display: block;
        font-size: 0.95rem;
        color: var(--text-primary);
    }
    .reviews-card-time {
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .reviews-card-photo-badge {
        font-size: 1.25rem;
        flex-shrink: 0;
    }
    .reviews-card-stars {
        color: #f59e0b;
        font-size: 1.125rem;
        letter-spacing: 2px;
    }
    .reviews-card-text {
        font-style: italic;
        color: var(--text-secondary);
        line-height: 1.7;
        flex: 1;
        margin-bottom: 0;
    }
    .reviews-card-topics {
        display: flex;
        gap: var(--space-xs);
        flex-wrap: wrap;
    }
    .reviews-topic-tag {
        padding: 0.2rem 0.6rem;
        background: var(--primary-light);
        color: var(--primary-dark);
        border-radius: var(--radius-full);
        font-size: 0.75rem;
        font-weight: 500;
    }

    /* ══ Animations ══ */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ══ Responsive ══ */
    @media (max-width: 1024px) {
        .reviews-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 768px) {
        .reviews-grid {
            grid-template-columns: 1fr;
        }
        .reviews-hero {
            padding: var(--space-2xl) 0;
        }
        .reviews-stat-number {
            font-size: 2rem;
        }
        .reviews-filter-bar {
            gap: 0.4rem;
        }
        .reviews-filter-btn {
            padding: 0.4rem 0.9rem;
            font-size: 0.8rem;
        }
    }
</style>
