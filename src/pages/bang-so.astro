---
import "../styles/global.css";
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Bảng Số Thứ Tự — Phòng Khám An Sinh</title>
    <link rel="icon" type="image/png" href="/AnSinhLogo_256.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  </head>
  <body>

    <!-- ===== TV LAYOUT ===== -->
    <div class="tv-root" id="tv-root">

      <!-- HEADER -->
      <header class="tv-header">
        <div class="tv-brand">
          <img src="/AnSinhLogo_256.png" alt="An Sinh" class="tv-logo" />
          <div>
            <h1 class="tv-clinic-name">PHÒNG KHÁM AN SINH</h1>
            <p class="tv-clinic-sub">SỐ THỨ TỰ KHÁM BỆNH</p>
          </div>
        </div>
        <div class="tv-header-right">
          <button id="btn-fullscreen" class="tv-icon-btn" title="Toàn màn hình" aria-label="Fullscreen">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
          </button>
          <div class="tv-clock" id="tv-clock">--:--</div>
        </div>
      </header>

      <!-- MAIN SPLIT -->
      <main class="tv-main">

        <!-- LEFT: FOCUS ZONE (Currently Called Patient) -->
        <section class="tv-focus" id="tv-focus">
          <div class="tv-focus-inner" id="tv-focus-content">
            <!-- Idle state -->
            <div class="tv-focus-idle" id="focus-idle">
              <svg class="tv-focus-idle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <p class="tv-focus-idle-text">Đang chờ gọi số...</p>
              <p class="tv-focus-idle-hint">Vui lòng ngồi chờ đến lượt</p>
            </div>
            <!-- Active state (hidden by default, shown by JS) -->
            <div class="tv-focus-active" id="focus-active" style="display:none">
              <div class="tv-focus-badge" id="focus-badge">ĐANG GỌI</div>
              <div class="tv-focus-room" id="focus-room">Phòng 1</div>
              <div class="tv-focus-number" id="focus-number">---</div>
              <div class="tv-focus-name" id="focus-name">---</div>
              <div class="tv-focus-doctor" id="focus-doctor"></div>
            </div>
          </div>
        </section>

        <!-- RIGHT: ROOM STATUS LIST -->
        <aside class="tv-sidebar" id="tv-sidebar">
          <h2 class="tv-sidebar-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
            Trạng Thái Phòng Khám
          </h2>
          <div class="tv-room-list" id="tv-room-list">
            <!-- Loading -->
            <div class="tv-room-loading" id="room-loading">
              <div class="tv-spinner"></div>
              <span>Đang kết nối...</span>
            </div>
          </div>

          <!-- PROMO BLOCK: Carousel QR Codes (Sticky Bottom) -->
          <div class="tv-sidebar-promo-wrapper">
            <!-- Promo 1: Booking -->
            <div class="tv-promo-slide active" id="promo-1">
              <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https://ansinh.app/dat-lich" alt="QR Đặt Lịch" class="tv-promo-qr-large" crossorigin="anonymous" />
              <div class="tv-promo-info-large">
                <span class="tv-promo-tag" style="background:var(--brand)">ĐẶT LỊCH TRƯỚC</span>
                <strong>Giảm thời gian chờ</strong>
                <span>Quét mã vuông để đặt lịch khám ngay trên điện thoại của bạn.</span>
              </div>
            </div>
            <!-- Promo 2: Tool -->
            <div class="tv-promo-slide" id="promo-2">
              <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https://ansinh.app/tinh-ngay-du-sinh" alt="QR Dự Sinh" class="tv-promo-qr-large" crossorigin="anonymous" style="border-color:#059669;box-shadow:0 4px 12px rgba(5,150,105,0.2)" />
              <div class="tv-promo-info-large">
                <span class="tv-promo-tag" style="background:#059669">TIỆN ÍCH MẸ BẦU</span>
                <strong>Tính Ngày Dự Sinh</strong>
                <span>Công cụ y khoa giúp mẹ bầu theo dõi thai kỳ chuẩn xác.</span>
              </div>
            </div>
          </div>
        </aside>

      </main>

      <!-- ALERT BANNER (Slides from top) -->
      <div id="tv-alert" class="tv-alert" style="display:none">
        <div class="tv-alert-bell">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        </div>
        <span class="tv-alert-text">Mời <strong id="alert-name">---</strong> vào <strong id="alert-room">---</strong></span>
        <span class="tv-alert-num" id="alert-num">---</span>
      </div>

      <!-- FOOTER TICKER -->
      <footer class="tv-footer">
        <div class="tv-ticker-track">
          <div class="tv-ticker" id="tv-ticker">
            <span>📋 Vui lòng ngồi chờ đến lượt gọi tên.</span>
            <span>🆔 Chuẩn bị sẵn CCCD / BHYT nếu cần.</span>
            <span>⭐ Ưu tiên người già, trẻ nhỏ, phụ nữ có thai, và người đã đặt lịch trước.</span>
            <span>📋 Vui lòng ngồi chờ đến lượt gọi tên.</span>
            <span>🆔 Chuẩn bị sẵn CCCD / BHYT nếu cần.</span>
            <span>⭐ Ưu tiên người già, trẻ nhỏ, phụ nữ có thai, và người đã đặt lịch trước.</span>
          </div>
        </div>
      </footer>

      <!-- Audio -->
      <audio id="audio-ding" preload="auto">
        <source src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" type="audio/mpeg" />
      </audio>
    </div>

    <!-- ===== SCRIPT ===== -->
    <script>
      const API_URL = 'https://ansinh-api.todyai.workers.dev/api/queue/current';
      const urlParams = new URLSearchParams(window.location.search);
      const zone = urlParams.get('zone');
      const fetchUrl = zone ? `${API_URL}?zone=${zone}` : API_URL;

      /** @type {Record<string, string>} */
      let lastState = {};
      let isFirstLoad = true;
      /** @type {ReturnType<typeof setTimeout> | null} */
      let alertTimeout = null;
      /** @type {{ roomId: string, roomName: string, customerName: string, queueNumber: string, doctorName: string, timeCalled: string } | null} */
      let currentFocus = null;

      // ── Clock ──
      function updateClock() {
        const el = document.getElementById('tv-clock');
        if (el) {
          el.textContent = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
        }
      }
      setInterval(updateClock, 1000);
      updateClock();

      // ── Fullscreen ──
      const btnFs = document.getElementById('btn-fullscreen');
      if (btnFs) {
        btnFs.addEventListener('click', () => {
          if (!document.fullscreenElement) {
            document.documentElement.requestFullscreen().catch(() => {});
          } else {
            document.exitFullscreen();
          }
        });
      }

      // ── TTS ──
      /** @param {string} text */
      function speakText(text) {
        if (!('speechSynthesis' in window)) return;
        window.speechSynthesis.cancel();
        const u = new SpeechSynthesisUtterance(text);
        u.lang = 'vi-VN';
        u.rate = 0.85;
        u.pitch = 1;
        const voices = window.speechSynthesis.getVoices();
        const vi = voices.find(v => v.lang.includes('vi') || v.lang.includes('VN'));
        if (vi) u.voice = vi;
        window.speechSynthesis.speak(u);
      }

      function playDing() {
        /** @type {HTMLAudioElement | null} */
        const audio = document.getElementById('audio-ding');
        if (audio) {
          audio.currentTime = 0;
          audio.play().catch(() => {});
        }
      }

      // ── Alert Banner ──
      /**
       * @param {string} roomName
       * @param {string} customerName
       * @param {string} queueNumber
       */
      function triggerAlert(roomName, customerName, queueNumber) {
        const elRoom = document.getElementById('alert-room');
        const elName = document.getElementById('alert-name');
        const elNum = document.getElementById('alert-num');
        const alertEl = document.getElementById('tv-alert');

        if (elRoom) elRoom.textContent = roomName;
        if (elName) elName.textContent = customerName;
        if (elNum) elNum.textContent = queueNumber ? queueNumber.split('-').pop() : '';

        if (alertEl) {
          alertEl.style.display = 'flex';
          alertEl.classList.remove('alert-hide');
          alertEl.classList.add('alert-show');
        }

        playDing();
        setTimeout(() => {
          speakText(`Mời khách hàng, ${customerName}, vào ${roomName}.`);
        }, 1500);

        if (alertTimeout) clearTimeout(alertTimeout);
        alertTimeout = setTimeout(() => {
          if (alertEl) {
            alertEl.classList.remove('alert-show');
            alertEl.classList.add('alert-hide');
            setTimeout(() => { if (alertEl) alertEl.style.display = 'none'; }, 600);
          }
        }, 10000);
      }

      // ── Update Focus Zone (Left Panel) ──
      /**
       * @param {{ roomId: string, roomName: string, customerName: string, queueNumber: string, doctorName: string }} info
       */
      function updateFocus(info) {
        const idle = document.getElementById('focus-idle');
        const active = document.getElementById('focus-active');
        const badge = document.getElementById('focus-badge');
        const room = document.getElementById('focus-room');
        const num = document.getElementById('focus-number');
        const name = document.getElementById('focus-name');
        const doc = document.getElementById('focus-doctor');
        const focusSection = document.getElementById('tv-focus');

        if (idle) idle.style.display = 'none';
        if (active) active.style.display = 'flex';
        if (badge) badge.textContent = 'ĐANG GỌI';
        if (room) room.textContent = info.roomName;
        if (num) num.textContent = info.queueNumber ? info.queueNumber.split('-').pop() : '---';
        if (name) name.textContent = info.customerName || '---';
        if (doc) doc.textContent = info.doctorName ? `BS. ${info.doctorName}` : '';

        // Pulse animation
        if (focusSection) {
          focusSection.classList.remove('focus-pulse');
          void focusSection.offsetWidth; // force reflow
          focusSection.classList.add('focus-pulse');
        }
      }

      // ── Render Sidebar (Right Panel) ──
      /**
       * @param {Record<string, {queueNumber?: string, customerName?: string, type?: string, doctorName?: string, timeCalled?: string}>} data
       * @param {string | null} focusRoomId
       */
      function renderSidebar(data, focusRoomId) {
        const list = document.getElementById('tv-room-list');
        if (!list) return;

        const rooms = Object.keys(data);
        if (rooms.length === 0) {
          list.innerHTML = '<div class="tv-room-empty">Chưa có phòng khám nào</div>';
          return;
        }

        let html = '';
        rooms.forEach(roomId => {
          const info = data[roomId];
          const ticketShort = info.queueNumber ? info.queueNumber.split('-').pop() : '---';
          const custName = info.customerName || 'Chưa gọi';
          const rType = info.type || 'Phòng';
          const roomLabel = `${rType} ${roomId}`.toUpperCase();
          const isFocus = roomId === focusRoomId;
          const hasPatient = !!info.queueNumber;

          html += `
            <div class="tv-room-card ${isFocus ? 'is-active' : ''} ${hasPatient ? 'has-patient' : ''}">
              <div class="tv-room-card-left">
                <span class="tv-room-card-label">${roomLabel}</span>
                <span class="tv-room-card-doctor">${info.doctorName ? 'BS. ' + info.doctorName : ''}</span>
              </div>
              <div class="tv-room-card-right">
                <span class="tv-room-card-num ${hasPatient ? '' : 'is-idle'}">${ticketShort}</span>
                <span class="tv-room-card-name">${custName}</span>
              </div>
            </div>
          `;
        });

        list.innerHTML = html;
      }

      // ── Fetch & Process ──
      async function fetchQueue() {
        try {
          const res = await fetch(fetchUrl);
          const result = await res.json();
          if (result.status !== 'success' || !result.data) return;

          const data = result.data;
          const rooms = Object.keys(data);

          // Hide loading
          const loadEl = document.getElementById('room-loading');
          if (loadEl) loadEl.hidden = true;

          if (rooms.length === 0) {
            renderSidebar(data, null);
            return;
          }

          // Detect newly called
          /** @type {Array<{roomId: string, roomName: string, customerName: string, queueNumber: string, doctorName: string, timeCalled: string}>} */
          let newlyCalled = [];
          rooms.forEach(roomId => {
            const info = data[roomId];
            if (!isFirstLoad && info.queueNumber && lastState[roomId] !== info.queueNumber) {
              const rType = info.type || 'Phòng';
              newlyCalled.push({
                roomId,
                roomName: `${rType} ${roomId}`.toUpperCase(),
                customerName: info.customerName || 'Khách hàng',
                queueNumber: info.queueNumber,
                doctorName: info.doctorName || '',
                timeCalled: info.timeCalled || ''
              });
            }
            lastState[roomId] = info.queueNumber;
          });

          // If new call → update focus + trigger alert
          if (newlyCalled.length > 0) {
            const newest = newlyCalled[0];
            currentFocus = newest;
            updateFocus(newest);
            triggerAlert(newest.roomName, newest.customerName, newest.queueNumber);
          }

          // On first load, pick the most recently called room for focus
          if (isFirstLoad) {
            let latestRoom = null;
            let latestTime = '';
            rooms.forEach(roomId => {
              const info = data[roomId];
              if (info.queueNumber && info.timeCalled && info.timeCalled > latestTime) {
                latestTime = info.timeCalled;
                latestRoom = roomId;
              }
            });
            if (latestRoom) {
              const info = data[latestRoom];
              const rType = info.type || 'Phòng';
              currentFocus = {
                roomId: latestRoom,
                roomName: `${rType} ${latestRoom}`.toUpperCase(),
                customerName: info.customerName || '---',
                queueNumber: info.queueNumber || '',
                doctorName: info.doctorName || '',
                timeCalled: info.timeCalled || ''
              };
              updateFocus(currentFocus);
            }
          }

          isFirstLoad = false;
          renderSidebar(data, currentFocus?.roomId || null);
        } catch (e) {
          console.error('Fetch error:', e);
        }
      }

      // ── Poll every X seconds ──
      fetchQueue();
      setInterval(fetchQueue, 3000);

      // ── Promo Carousel Logic ──
      let currentPromo = 1;
      setInterval(() => {
        const p1 = document.getElementById('promo-1');
        const p2 = document.getElementById('promo-2');
        if (p1 && p2) {
          if (currentPromo === 1) {
            p1.classList.remove('active');
            p2.classList.add('active');
            currentPromo = 2;
          } else {
            p2.classList.remove('active');
            p1.classList.add('active');
            currentPromo = 1;
          }
        }
      }, 10000); // Tự động chuyển mỗi 10 giây
    </script>

    <!-- ===== STYLES ===== -->
    <style is:global>
      /* ── Design Tokens ── */
      :root {
        --bg: #f0f4f8;
        --bg-header: #ffffff;
        --surface: #ffffff;
        --surface-active: #ebf5ff;
        --border: #e2e8f0;
        --border-active: #2563eb;

        --brand: #1e40af;        /* Passport Blue — medical trust */
        --brand-light: #3b82f6;
        --brand-glow: rgba(37, 99, 235, 0.15);
        --accent: #059669;       /* Green for active/success */
        --accent-light: #d1fae5;

        --text: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --text-inverse: #ffffff;

        --focus-bg: linear-gradient(135deg, #1e3a8a 0%, #1e40af 40%, #2563eb 100%);
        --alert-bg: linear-gradient(90deg, #dc2626 0%, #ef4444 100%);

        --radius: 16px;
        --radius-sm: 10px;
        --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        --shadow-lg: 0 10px 40px rgba(0,0,0,0.08);
      }

      /* ── Reset ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow: hidden;
        height: 100dvh;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Root Layout ── */
      .tv-root {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        position: relative;
      }

      /* ── HEADER ── */
      .tv-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 2rem;
        background: var(--bg-header);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        z-index: 10;
      }
      .tv-brand {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .tv-logo {
        width: 56px;
        height: 56px;
        border-radius: 12px;
      }
      .tv-clinic-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--brand);
        letter-spacing: 1px;
        line-height: 1.2;
      }
      .tv-clinic-sub {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        letter-spacing: 3px;
        text-transform: uppercase;
      }
      .tv-header-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .tv-icon-btn {
        background: none;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        min-width: 44px;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: background 0.2s, color 0.2s;
      }
      .tv-icon-btn:hover { background: var(--brand-glow); color: var(--brand); }
      .tv-clock {
        font-size: 2.5rem;
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        color: var(--brand);
      }

      /* ── MAIN SPLIT ── */
      .tv-main {
        flex: 1;
        display: grid;
        grid-template-columns: 62fr 38fr;
        gap: 0;
        overflow: hidden;
      }

      /* ── LEFT: FOCUS ZONE ── */
      .tv-focus {
        background: var(--focus-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        position: relative;
        overflow: hidden;
      }
      /* Decorative circles */
      .tv-focus::before,
      .tv-focus::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        opacity: 0.08;
        background: white;
      }
      .tv-focus::before {
        width: 500px; height: 500px;
        top: -150px; left: -100px;
      }
      .tv-focus::after {
        width: 350px; height: 350px;
        bottom: -100px; right: -50px;
      }

      .tv-focus-inner {
        position: relative;
        z-index: 1;
        text-align: center;
        width: 100%;
      }

      /* Idle */
      .tv-focus-idle {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
      .tv-focus-idle-icon {
        width: 80px;
        height: 80px;
        color: rgba(255,255,255,0.3);
        animation: idlePulse 3s ease-in-out infinite;
      }
      @keyframes idlePulse {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.05); }
      }
      .tv-focus-idle-text {
        font-size: 2rem;
        font-weight: 600;
        color: rgba(255,255,255,0.5);
      }
      .tv-focus-idle-hint {
        font-size: 1.25rem;
        color: rgba(255,255,255,0.3);
      }

      /* Active */
      .tv-focus-active {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      .tv-focus-badge {
        display: inline-block;
        background: #ef4444;
        color: white;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: 3px;
        padding: 0.4rem 1.5rem;
        border-radius: 100px;
        text-transform: uppercase;
        animation: badgePulse 2s ease-in-out infinite;
      }
      @keyframes badgePulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
        50% { box-shadow: 0 0 0 12px rgba(239, 68, 68, 0); }
      }
      .tv-focus-room {
        font-size: 1.75rem;
        font-weight: 700;
        color: rgba(255,255,255,0.7);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 0.5rem;
      }
      .tv-focus-number {
        font-size: clamp(6rem, 12vw, 14rem);
        font-weight: 900;
        color: #ffffff;
        line-height: 1;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 4px 30px rgba(0,0,0,0.2);
        letter-spacing: -2px;
        margin: 0.25rem 0;
      }
      .tv-focus-name {
        font-size: clamp(1.75rem, 3vw, 3rem);
        font-weight: 700;
        color: #fde68a;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .tv-focus-doctor {
        font-size: 1.25rem;
        font-weight: 500;
        color: rgba(255,255,255,0.5);
        margin-top: 0.5rem;
      }

      /* Focus pulse on new call */
      .focus-pulse {
        animation: focusPulseAnim 1.5s ease-out;
      }
      @keyframes focusPulseAnim {
        0% { filter: brightness(1.3); }
        100% { filter: brightness(1); }
      }

      /* ── RIGHT: SIDEBAR ── */
      .tv-sidebar {
        background: var(--surface);
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .tv-sidebar-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-secondary);
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        flex-shrink: 0;
      }
      .tv-sidebar-title svg {
        color: var(--brand-light);
        flex-shrink: 0;
      }

      .tv-room-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      /* Room Card */
      .tv-room-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        border-radius: var(--radius-sm);
        border: 2px solid transparent;
        background: var(--bg);
        transition: all 0.3s ease;
      }
      /* ── PROMO BLOCK CAROUSEL (Sticky Bottom Sidebar) ── */
      .tv-sidebar-promo-wrapper {
        margin-top: auto;
        border-top: 1px solid var(--border);
        background: var(--surface);
        position: relative;
        height: 140px; /* Fixed height for carousel */
        overflow: hidden;
      }
      .tv-promo-slide {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1rem 1.75rem;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); /* Apple-like smooth spring */
        pointer-events: none;
      }
      .tv-promo-slide.active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }
      .tv-promo-qr-large {
        width: 100px;
        height: 100px;
        border-radius: 12px;
        background: #fff;
        padding: 4px;
        border: 2px solid var(--brand-light);
        flex-shrink: 0;
        object-fit: contain;
        animation: qrPulse 3s infinite alternate;
      }
      @keyframes qrPulse {
        0% { box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2); transform: scale(1); }
        100% { box-shadow: 0 0 25px rgba(37, 99, 235, 0.5); transform: scale(1.05); }
      }
      .tv-promo-info-large {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        justify-content: center;
      }
      .tv-promo-tag {
        align-self: flex-start;
        color: #fff;
        font-size: 0.65rem;
        font-weight: 800;
        padding: 0.25rem 0.6rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.2rem;
      }
      .tv-promo-info-large strong {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--text);
        line-height: 1.2;
        letter-spacing: 0.5px;
      }
      .tv-promo-info-large span {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.4;
      }

      /* Empty State */
      .tv-room-card.has-patient {
        background: var(--surface);
        border-color: var(--border);
      }
      .tv-room-card.is-active {
        background: var(--surface-active);
        border-color: var(--border-active);
        box-shadow: 0 0 0 3px var(--brand-glow);
      }

      .tv-room-card-left {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }
      .tv-room-card-label {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
        letter-spacing: 0.5px;
      }
      .tv-room-card.is-active .tv-room-card-label {
        color: var(--brand);
      }
      .tv-room-card-doctor {
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      .tv-room-card-right {
        text-align: right;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.15rem;
      }
      .tv-room-card-num {
        font-size: 2rem;
        font-weight: 900;
        color: var(--brand);
        font-variant-numeric: tabular-nums;
        line-height: 1;
      }
      .tv-room-card-num.is-idle {
        color: var(--text-muted);
        font-size: 1.5rem;
      }
      .tv-room-card-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-secondary);
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* Loading / Empty in sidebar */
      .tv-room-loading, .tv-room-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding: 3rem;
        color: var(--text-muted);
        font-size: 1rem;
      }
      .tv-spinner {
        width: 32px;
        height: 32px;
        border: 3px solid var(--border);
        border-top-color: var(--brand-light);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* ── ALERT BANNER ── */
      .tv-alert {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: var(--alert-bg);
        color: white;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.25rem 2.5rem;
        box-shadow: 0 8px 30px rgba(220, 38, 38, 0.3);
      }
      .tv-alert-bell {
        animation: bellRing 0.8s ease-in-out infinite alternate;
      }
      @keyframes bellRing {
        0% { transform: rotate(-12deg); }
        100% { transform: rotate(12deg); }
      }
      .tv-alert-text {
        font-size: 1.75rem;
        font-weight: 600;
        flex: 1;
      }
      .tv-alert-text strong {
        font-weight: 900;
        color: #fde68a;
      }
      .tv-alert-num {
        font-size: 3rem;
        font-weight: 900;
        font-variant-numeric: tabular-nums;
        color: #fde68a;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
      }

      .alert-show { animation: alertSlideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      .alert-hide { animation: alertSlideOut 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      @keyframes alertSlideIn { from { transform: translateY(-100%); } to { transform: translateY(0); } }
      @keyframes alertSlideOut { from { transform: translateY(0); } to { transform: translateY(-100%); } }

      /* ── FOOTER TICKER ── */
      .tv-footer {
        background: var(--brand);
        color: var(--text-inverse);
        padding: 0.6rem 0;
        overflow: hidden;
        flex-shrink: 0;
      }
      .tv-ticker-track {
        overflow: hidden;
        white-space: nowrap;
      }
      .tv-ticker {
        display: inline-flex;
        gap: 4rem;
        animation: tickerScroll 40s linear infinite;
        font-size: 1.1rem;
        font-weight: 600;
      }
      .tv-ticker span {
        flex-shrink: 0;
      }
      @keyframes tickerScroll {
        0% { transform: translate3d(50%, 0, 0); }
        100% { transform: translate3d(-100%, 0, 0); }
      }

      /* ── Responsive (for smaller screens / portrait TVs) ── */
      @media (max-width: 900px) {
        .tv-main {
          grid-template-columns: 1fr;
          grid-template-rows: 50vh 1fr;
        }
        .tv-sidebar {
          border-left: none;
          border-top: 1px solid var(--border);
        }
        .tv-focus-number {
          font-size: 6rem;
        }
      }
    </style>
  </body>
</html>
