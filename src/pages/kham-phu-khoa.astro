---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import "../styles/landing.css";

const pageTitle =
    "Khám Phụ Khoa Từ Sơn, Bắc Ninh — Riêng Tư, Nhẹ Nhàng, Tận Tâm | An Sinh";
const pageDescription =
    "Khám phụ khoa riêng tư tại Từ Sơn, Bắc Ninh. Bác sĩ nữ tận tâm, không gian kín đáo, điều trị viêm âm đạo, viêm lộ tuyến, rối loạn kinh nguyệt. Đặt lịch ngay!";

const faqs = [
    {
        q: "Khám phụ khoa có đau không?",
        a: "Phần lớn các bước khám phụ khoa không gây đau. Bác sĩ tại An Sinh thực hiện rất nhẹ nhàng, tế nhị. Nếu bạn cảm thấy lo lắng, hãy cho bác sĩ biết — chúng tôi sẽ điều chỉnh để bạn thoải mái nhất.",
    },
    {
        q: "Phòng khám có bác sĩ nữ không?",
        a: "Có. An Sinh có bác sĩ nữ chuyên khoa phụ sản, giàu kinh nghiệm. Bạn hoàn toàn có thể yêu cầu được khám bởi bác sĩ nữ khi đặt lịch.",
    },
    {
        q: "Khi nào nên đi khám phụ khoa?",
        a: "Nên khám phụ khoa định kỳ 6 tháng/lần. Cần khám ngay khi có triệu chứng: khí hư bất thường, ngứa, đau bụng dưới, rối loạn kinh nguyệt, chảy máu bất thường, hoặc đau khi quan hệ.",
    },
    {
        q: "Chi phí khám phụ khoa bao nhiêu?",
        a: "Chi phí khám phụ khoa tại An Sinh được niêm yết công khai, rất hợp lý. Tùy theo các xét nghiệm cần thiết. Liên hệ 0899 268 299 để được tư vấn chi tiết.",
    },
    {
        q: "Viêm âm đạo có tự khỏi không?",
        a: "Viêm âm đạo thường KHÔNG tự khỏi và có thể nặng hơn nếu không điều trị. Phát hiện sớm, điều trị đúng phác đồ sẽ khỏi nhanh, tránh biến chứng. Đừng ngại đi khám.",
    },
    {
        q: "Phòng khám có bảo mật thông tin không?",
        a: "Tuyệt đối bảo mật. Mọi thông tin bệnh nhân tại An Sinh đều được bảo mật nghiêm ngặt theo quy định y tế. Không gian khám riêng tư 100%.",
    },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
    <nav class="landing-breadcrumb" aria-label="Breadcrumb">
        <div class="container">
            <ol itemscope itemtype="https://schema.org/BreadcrumbList">
                <li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <a itemprop="item" href="/"
                        ><span itemprop="name">Trang chủ</span>
                    </a><meta itemprop="position" content="1" />
                </li><li
                    itemprop="itemListElement"
                    itemscope
                    itemtype="https://schema.org/ListItem"
                >
                    <span itemprop="name">Khám phụ khoa</span><meta
                        itemprop="position"
                        content="2"
                    />
                </li>
            </ol>
        </div>
    </nav>

    <section class="landing-hero" id="hero">
        <div class="container landing-hero-inner">
            <div class="landing-hero-content">
                <span class="landing-hero-badge"
                    >🔒 Không gian riêng tư 100%</span
                >
                <h1>
                    Khám Phụ Khoa — Riêng Tư, Nhẹ Nhàng, <span
                        class="text-accent-color">Không Còn Ngại Ngùng</span>
                </h1>
                <p class="landing-hero-sub">
                    Triệu chứng kéo dài mà ngại đi khám? Đừng để nó nặng hơn.
                    Tại An Sinh, bạn được khám bởi bác sĩ nữ tận tâm, trong
                    không gian riêng tư, thoải mái.
                </p>
                <div class="landing-hero-actions">
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-accent btn-lg"
                        id="phu-khoa-hero-cta">Đặt Lịch Khám — Riêng Tư 100%</a
                    >
                    <a
                        href="tel:0899268299"
                        class="btn btn-outline btn-lg"
                        id="phu-khoa-hero-call">Gọi: 0899 268 299</a
                    >
                </div>
            </div>
            <div class="landing-hero-visual" aria-hidden="true">
                <div class="hero-feature-grid">
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="1.5"
                            ><path
                                d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"
                            ></path>
                        </svg><span>Bác sĩ nữ tận tâm</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg><span>Riêng tư 100%</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="1.5"
                            ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                        </svg><span>Chẩn đoán chính xác</span>
                    </div>
                    <div class="hero-feature-item">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            ><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"
                            ></path><circle cx="12" cy="7" r="4"></circle>
                        </svg><span>BS 20+ năm</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="landing-trust" aria-label="Chỉ số tin cậy">
        <div class="container">
            <div class="trust-metrics">
                <div class="trust-metric">
                    <span class="trust-metric-number">5.0</span><span
                        class="trust-metric-label">⭐ Google Maps</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">20+</span><span
                        class="trust-metric-label">Năm kinh nghiệm</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">100%</span><span
                        class="trust-metric-label">Bảo mật thông tin</span>
                </div>
                <div class="trust-metric-divider" aria-hidden="true"></div>
                <div class="trust-metric">
                    <span class="trust-metric-number">♀</span><span
                        class="trust-metric-label">Bác sĩ nữ</span>
                </div>
            </div>
        </div>
    </section>

    <section class="section landing-problems" id="van-de">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Chúng tôi hiểu</span><h2>
                    Ngại đi khám — và điều đó hoàn toàn bình thường
                </h2><p>
                    Nhiều chị em trì hoãn khám phụ khoa vì ngại, nhưng càng chậm
                    càng khó điều trị.
                </p>
            </div>
            <div class="grid-3">
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><circle cx="12" cy="12" r="10"></circle><path
                                d="M8 15s1.5 2 4 2 4-2 4-2"></path><line
                                x1="9"
                                y1="9"
                                x2="9.01"
                                y2="9"></line><line
                                x1="15"
                                y1="9"
                                x2="15.01"
                                y2="9"></line>
                        </svg>
                    </div>
                    <h3>Ngại ngùng, xấu hổ khi đi khám</h3>
                    <p>
                        "Bệnh phụ khoa nói ra ngại lắm" — bạn không đơn độc. Tại
                        An Sinh, không gian khám riêng tư, bác sĩ nữ nhẹ nhàng,
                        tế nhị.
                    </p>
                </div>
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="12"
                                y1="8"
                                x2="12"
                                y2="12"></line><line
                                x1="12"
                                y1="16"
                                x2="12.01"
                                y2="16"></line>
                        </svg>
                    </div>
                    <h3>Triệu chứng kéo dài nhưng ngại đi khám</h3>
                    <p>
                        Khí hư bất thường, ngứa, đau — kéo dài hàng tuần mà vẫn
                        chưa đi khám? Bệnh phụ khoa không tự khỏi — phát hiện
                        sớm mới dễ điều trị.
                    </p>
                </div>
                <div class="card problem-card">
                    <div class="problem-icon" aria-hidden="true">
                        <svg
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--accent)"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg>
                    </div>
                    <h3>Lo phòng khám không kín đáo</h3>
                    <p>
                        Bạn lo gặp người quen, lo không được bảo mật? An Sinh
                        cam kết: không gian riêng tư tuyệt đối, thông tin bảo
                        mật 100%.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section section-alt" id="bac-si">
        <div class="container">
            <div class="landing-guide-layout">
                <div>
                    <span class="section-label">Bác sĩ phụ khoa</span>
                    <h2>
                        Bác sĩ nữ <span class="text-primary-color"
                            >tận tâm, nhẹ nhàng</span>
                    </h2>
                    <p>
                        Chúng tôi hiểu rằng khám phụ khoa là trải nghiệm nhạy
                        cảm. Bác sĩ nữ tại An Sinh luôn thực hiện nhẹ nhàng, tế
                        nhị, và giải thích rõ ràng từng bước.
                    </p>
                    <ul class="guide-credentials-list">
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Bác sĩ nữ chuyên khoa sản phụ khoa
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Không gian khám riêng tư, kín đáo
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Điều trị viêm âm đạo, viêm lộ tuyến, rối loạn
                            kinh nguyệt
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--primary)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Bảo mật thông tin tuyệt đối
                        </li>
                    </ul>
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-primary"
                        id="phu-khoa-guide-cta">Đặt Lịch Khám Phụ Khoa</a
                    >
                </div>
                <div class="guide-card-visual" aria-hidden="true">
                    <svg viewBox="0 0 120 120" width="120" height="120"
                        ><circle cx="60" cy="60" r="60" fill="var(--primary)"
                        ></circle><circle
                            cx="60"
                            cy="45"
                            r="20"
                            fill="white"
                            opacity="0.3"></circle><path
                            d="M60 70c-18 0-32 10-32 22v8h64v-8c0-12-14-22-32-22z"
                            fill="white"
                            opacity="0.2"></path><circle
                            cx="60"
                            cy="45"
                            r="18"
                            fill="white"
                            opacity="0.8"></circle>
                    </svg>
                    <div class="guide-card-quote">
                        <p>
                            "Tôi hiểu sự ngại ngùng của bạn. Vì vậy, mỗi lần
                            khám, tôi luôn nhẹ nhàng, tế nhị và giải thích rõ
                            ràng từng bước."
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section" id="quy-trinh">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Đơn giản & Thoải mái</span><h2>
                    3 bước khám phụ khoa tại An Sinh
                </h2>
            </div>
            <div class="landing-steps-grid">
                <div class="landing-step">
                    <div class="landing-step-number">1</div><h3>
                        Đặt lịch hẹn
                    </h3><p>
                        Online hoặc gọi 0899 268 299. Có thể yêu cầu bác sĩ nữ
                        khi đặt lịch.
                    </p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-number">2</div><h3>
                        Khám riêng tư, nhẹ nhàng
                    </h3><p>
                        Không gian kín đáo, bác sĩ nữ tế nhị. Giải thích rõ ràng
                        kết quả và phương hướng điều trị.
                    </p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-number">3</div><h3>
                        Điều trị hiệu quả
                    </h3><p>
                        Phác đồ cá nhân hóa, theo dõi sát kết quả. Hỗ trợ tư vấn
                        qua điện thoại nếu cần.
                    </p>
                </div>
            </div>
            <div class="text-center mt-2">
                <a
                    href="https://phusanansinh.com/dat-lich-hen-kham.html"
                    class="btn btn-accent btn-lg"
                    id="phu-khoa-steps-cta">Đặt Lịch Khám — Riêng Tư 100%</a>
            </div>
        </div>
    </section>

    <section class="section section-alt" id="review">
        <div class="container">
            <div class="section-header">
                <span class="section-label">Chị em nói gì</span><h2>
                    Nhiều chị em đã vượt qua nỗi ngại
                </h2>
            </div>
            <div class="grid-3">
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Lần đầu khám phụ khoa, hồi hộp lắm. Nhưng bác sĩ nữ ở
                        đây rất nhẹ nhàng, giải thích kỹ. Giờ không còn ngại
                        nữa."
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">P</div><div
                            class="landing-testimonial-meta"
                        >
                            <strong>Chị P.</strong><span
                                >Khám phụ khoa lần đầu</span>
                        </div>
                    </div>
                </div>
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Mình bị viêm âm đạo kéo dài, ngại mãi mới đi khám. May
                        mắn gặp bác sĩ tận tâm, điều trị 2 tuần là khỏi."
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">Q</div><div
                            class="landing-testimonial-meta"
                        >
                            <strong>Chị Q.</strong><span
                                >Điều trị viêm âm đạo</span>
                        </div>
                    </div>
                </div>
                <div class="landing-testimonial">
                    <div class="landing-testimonial-stars" aria-label="5 sao">
                        ★★★★★
                    </div>
                    <p class="landing-testimonial-text">
                        "Phòng khám rất sạch sẽ, riêng tư. Bác sĩ giải thích cặn
                        kẽ, không hề có cảm giác bị vội vàng. Rất hài lòng."
                    </p>
                    <div class="landing-testimonial-author">
                        <div class="landing-testimonial-avatar">A</div><div
                            class="landing-testimonial-meta"
                        >
                            <strong>Chị A.</strong><span
                                >Khám phụ khoa định kỳ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section" id="stakes">
        <div class="container">
            <div class="landing-stakes">
                <div class="landing-stakes-fail">
                    <h3 class="stakes-heading fail">
                        Đừng trì hoãn — bệnh không tự khỏi
                    </h3>
                    <ul class="landing-stakes-list">
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--error)"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="15"
                                    y1="9"
                                    x2="9"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line><line
                                    x1="9"
                                    y1="9"
                                    x2="15"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line>
                            </svg>Viêm nhiễm lan rộng, khó điều trị hơn
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--error)"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="15"
                                    y1="9"
                                    x2="9"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line><line
                                    x1="9"
                                    y1="9"
                                    x2="15"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line>
                            </svg>Ảnh hưởng đến khả năng sinh sản
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--error)"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="15"
                                    y1="9"
                                    x2="9"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line><line
                                    x1="9"
                                    y1="9"
                                    x2="15"
                                    y2="15"
                                    stroke="white"
                                    stroke-width="2"></line>
                            </svg>Lo lắng, ảnh hưởng chất lượng cuộc sống
                        </li>
                    </ul>
                </div>
                <div class="landing-stakes-success">
                    <h3 class="stakes-heading success">
                        Phát hiện sớm — điều trị nhanh, an tâm
                    </h3>
                    <ul class="landing-stakes-list">
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--success)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Điều trị đúng phác đồ, khỏi nhanh
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="var(--success)"
                                aria-hidden="true"
                                ><path
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>Bảo vệ sức khỏe sinh sản lâu dài
                        </li>
                        <li>
                            <svg
                                width="20"
                                height="20"
