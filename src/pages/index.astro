---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import reviewsData from "../data/reviews.json";

const homeReviews = [
  reviewsData.reviews.find((r) => r.topics.includes("vo-sinh")),
  reviewsData.reviews.find((r) => r.topics.includes("kham-thai")),
  reviewsData.reviews.find((r) => r.topics.includes("sieu-am")),
].filter(Boolean);
---

<BaseLayout
  title="Phòng Khám An Sinh — Sản Phụ Khoa Uy Tín Tại Từ Sơn, Bắc Ninh"
  description="Phòng khám sản phụ khoa uy tín nhất Từ Sơn, Bắc Ninh. Siêu âm 5D, khám thai, phụ khoa, nam khoa, điều trị vô sinh. Bác sĩ chuyên khoa 20+ năm. Đặt lịch ngay!"
>
  <!-- ══════════════════════════════════════
     SECTION 1: HERO — SB7 Hero + Desire
     ══════════════════════════════════════ -->
  <section class="hero" id="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-badge">⭐ Đánh giá 5.0 trên Google Maps</span>
        <h1>
          Thai kỳ an toàn,<br /> bắt đầu từ nơi <span class="text-accent-color"
            >đáng tin</span
          >
        </h1>
        <p class="hero-sub">
          Phòng khám sản phụ khoa chuyên sâu tại Từ Sơn, Bắc Ninh — nơi hàng
          nghìn gia đình đặt trọn niềm tin suốt hơn 10 năm.
        </p>
        <div class="hero-actions">
          <a
            href="https://phusanansinh.com/dat-lich-hen-kham.html"
            class="btn btn-accent btn-lg"
            id="hero-cta"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
              ></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
                x1="8"
                y1="2"
                x2="8"
                y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            Hẹn Khám Ngay
          </a>
          <a
            href="tel:0899268299"
            class="btn btn-outline btn-lg"
            id="hero-call"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
              ></path>
            </svg>
            Gọi: 0899 268 299
          </a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-blob">
          <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M300,200Q300,300,200,300Q100,300,100,200Q100,100,200,100Q300,100,300,200Z"
              fill="var(--primary-light)"></path>
          </svg>
          <div class="hero-icon-grid">
            <div class="hero-icon-item">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--primary)"
                stroke-width="1.5"
                ><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"
                ></path><circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span>BS 20+ năm</span>
            </div>
            <div class="hero-icon-item">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--accent)"
                stroke-width="1.5"
                ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
              <span>Siêu âm 5D</span>
            </div>
            <div class="hero-icon-item">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--primary)"
                stroke-width="1.5"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              <span>An toàn</span>
            </div>
            <div class="hero-icon-item">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--accent)"
                stroke-width="1.5"
                ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
                ></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
                  x1="12"
                  y1="17"
                  x2="12"
                  y2="21"></line>
              </svg>
              <span>Kết quả online</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 2: TRUST BAR — Authority
     ══════════════════════════════════════ -->
  <section class="trust-bar" aria-label="Chỉ số tin cậy">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <span class="trust-number">5.0</span>
          <span class="trust-label">⭐ Google Maps</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-number">20+</span>
          <span class="trust-label">Năm kinh nghiệm</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-number">10+</span>
          <span class="trust-label">Năm phục vụ</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item">
          <span class="trust-number">6</span>
          <span class="trust-label">Chuyên khoa</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 3: PROBLEM — SB7 Villain + Problem
     ══════════════════════════════════════ -->
  <section class="section" id="van-de">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Chúng tôi hiểu</span>
        <h2>Bạn đang lo lắng — và điều đó hoàn toàn bình thường</h2>
        <p>
          Sức khỏe sinh sản là hành trình riêng tư, đầy cảm xúc. Bạn xứng đáng
          được đồng hành bởi người thật sự quan tâm.
        </p>
      </div>
      <div class="grid-3">
        <div class="card problem-card">
          <div class="problem-icon" aria-hidden="true">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="M8 15s1.5 2 4 2 4-2 4-2"></path><line
                x1="9"
                y1="9"
                x2="9.01"
                y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
          </div>
          <h3>Lo lắng về thai kỳ</h3>
          <p>
            "Em bé có khỏe không? Kết quả xét nghiệm có bình thường?" — Nỗi lo
            của mọi bà mẹ. Bạn cần bác sĩ giải thích tận tình, không hời hợt.
          </p>
        </div>
        <div class="card problem-card">
          <div class="problem-icon" aria-hidden="true">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h3>Ngại đi khám phụ khoa</h3>
          <p>
            Nhiều chị em trì hoãn khám vì ngại ngùng, lo sợ. Nhưng càng chậm
            càng khó điều trị. Bạn cần nơi tế nhị, riêng tư, thoải mái.
          </p>
        </div>
        <div class="card problem-card">
          <div class="problem-icon" aria-hidden="true">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
              ></path><circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3>Muốn khám gần nhà</h3>
          <p>
            Đi HN mất cả ngày, xếp hàng 2-3 tiếng mới đến lượt. Bạn cần phòng
            khám uy tín ngay tại Từ Sơn — tiện lợi, nhanh chóng.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 4: GUIDE — SB7 Guide (Empathy + Authority)
     ══════════════════════════════════════ -->
  <section class="section section-alt" id="bac-si">
    <div class="container">
      <div class="guide-layout">
        <div class="guide-content">
          <span class="section-label">Người đồng hành</span>
          <h2>
            Bác sĩ chuyên khoa sản với <span class="text-primary-color"
              >20+ năm kinh nghiệm</span
            >
          </h2>
          <p>
            Chúng tôi hiểu rằng mỗi lần đến phòng khám, bạn mang theo cả nỗi lo
            và niềm hy vọng. Đó là lý do chúng tôi không chỉ khám — mà lắng
            nghe, giải thích tận tình, và đồng hành cùng bạn.
          </p>
          <ul class="guide-credentials">
            <li>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="var(--primary)"
                aria-hidden="true"
                ><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Thạc sĩ chuyên ngành Sản phụ khoa
            </li>
            <li>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="var(--primary)"
                aria-hidden="true"
                ><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Tham dự hội thảo quốc tế thường xuyên
            </li>
            <li>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="var(--primary)"
                aria-hidden="true"
                ><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Liên kết với bệnh viện tuyến trên
            </li>
            <li>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="var(--primary)"
                aria-hidden="true"
                ><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Nhiều chứng chỉ, bằng khen chuyên ngành
            </li>
          </ul>
          <a
            href="https://phusanansinh.com/dat-lich-hen-kham.html"
            class="btn btn-primary mt-2"
            id="guide-cta">Đặt Lịch Với Bác Sĩ</a
          >
        </div>
        <div class="guide-visual" aria-hidden="true">
          <div class="guide-card">
            <div class="guide-avatar">
              <svg
                viewBox="0 0 120 120"
                width="120"
                height="120"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle cx="60" cy="60" r="60" fill="var(--primary-light)"
                ></circle>
                <circle
                  cx="60"
                  cy="45"
                  r="20"
                  fill="var(--primary)"
                  opacity="0.3"></circle>
                <path
                  d="M60 70c-18 0-32 10-32 22v8h64v-8c0-12-14-22-32-22z"
                  fill="var(--primary)"
                  opacity="0.2"></path>
                <circle cx="60" cy="45" r="18" fill="white" opacity="0.8"
                ></circle>
                <path
                  d="M52 42c0-1 1-2 2-2h12c1 0 2 1 2 2v6c0 1-1 2-2 2H54c-1 0-2-1-2-2z"
                  fill="var(--primary)"
                  opacity="0.4"></path>
              </svg>
            </div>
            <div class="guide-quote">
              <p>
                "Mỗi bệnh nhân đều đặc biệt. Tôi luôn dành thời gian lắng nghe
                và giải thích cặn kẽ."
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 5: SERVICES — SB7 Plan (Outcome-Based)
     ══════════════════════════════════════ -->
  <section class="section" id="dich-vu">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Dịch vụ chuyên khoa</span>
        <h2>Chăm sóc toàn diện sức khỏe sinh sản</h2>
        <p>
          Mỗi dịch vụ đều được thực hiện bởi bác sĩ chuyên khoa, trên thiết bị
          hiện đại nhất.
        </p>
      </div>
      <div class="grid-3 services-grid">
        <!-- Service 1: Siêu âm -->
        <a href="/sieu-am-5d" class="card service-card" id="service-sieu-am">
          <div class="service-icon si-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          </div>
          <h3>Siêu âm 5D</h3>
          <p>
            Nhìn thấy và lưu giữ hình ảnh con yêu rõ nét nhất. Tra cứu kết quả
            online.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>

        <!-- Service 2: Phụ khoa -->
        <a
          href="/kham-phu-khoa"
          class="card service-card"
          id="service-phu-khoa"
        >
          <div class="service-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path
                d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"
              ></path>
            </svg>
          </div>
          <h3>Khám phụ khoa</h3>
          <p>
            Phát hiện sớm, điều trị kịp thời. Không gian riêng tư, bác sĩ nữ tận
            tâm.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>

        <!-- Service 3: Nam khoa -->
        <a
          href="/kham-nam-khoa"
          class="card service-card"
          id="service-nam-khoa"
        >
          <div class="service-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle
                cx="8.5"
                cy="7"
                r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line
                x1="23"
                y1="11"
                x2="17"
                y2="11"></line>
            </svg>
          </div>
          <h3>Khám nam khoa</h3>
          <p>
            Tầm soát, chẩn đoán chuyên sâu. Bảo mật tuyệt đối, tư vấn tận tình.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>

        <!-- Service 4: Vô sinh -->
        <a
          href="/dieu-tri-vo-sinh"
          class="card service-card"
          id="service-vo-sinh"
        >
          <div class="service-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle
                cx="9"
                cy="7"
                r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path
                d="M16 3.13a4 4 0 010 7.75"></path>
            </svg>
          </div>
          <h3>Điều trị vô sinh</h3>
          <p>
            Đồng hành trên hành trình tìm con. Nhiều cặp vợ chồng đã thành công
            tại đây.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>

        <!-- Service 5: Tránh thai -->
        <a
          href="/tranh-thai-an-toan"
          class="card service-card"
          id="service-tranh-thai"
        >
          <div class="service-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--primary)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h3>Tránh thai an toàn</h3>
          <p>
            Tư vấn phương pháp phù hợp. Đặt vòng, cấy que chuyên nghiệp, an
            toàn.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>

        <!-- Service 6: Trực tuyến -->
        <a
          href="/tu-van-truc-tuyen"
          class="card service-card"
          id="service-online"
        >
          <div class="service-icon" aria-hidden="true">
            <svg
              width="48"
              height="48"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--accent)"
              stroke-width="1.5"
              stroke-linecap="round"
              ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
              ></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
                x1="12"
                y1="17"
                x2="12"
                y2="21"></line>
            </svg>
          </div>
          <h3>Tư vấn trực tuyến</h3>
          <p>
            Không tiện đến khám? Gặp bác sĩ qua video call — tiện lợi, nhanh
            chóng.
          </p>
          <span class="service-link">Tìm hiểu thêm →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 6: 3-STEP PLAN — SB7 Plan
     ══════════════════════════════════════ -->
  <section class="section section-alt" id="quy-trinh">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Đơn giản & Nhanh chóng</span>
        <h2>3 bước để bắt đầu</h2>
      </div>
      <div class="grid-3 steps-grid">
        <div class="step-card">
          <div class="step-number" aria-hidden="true">1</div>
          <h3>Đặt lịch hẹn</h3>
          <p>
            Online hoặc gọi hotline. Chọn ngày giờ phù hợp, không cần chờ đợi.
          </p>
        </div>
        <div class="step-card">
          <div class="step-number" aria-hidden="true">2</div>
          <h3>Khám với bác sĩ chuyên khoa</h3>
          <p>
            Được bác sĩ 20+ năm kinh nghiệm khám, tư vấn tận tâm, giải thích kỹ
            lưỡng.
          </p>
        </div>
        <div class="step-card">
          <div class="step-number" aria-hidden="true">3</div>
          <h3>Nhận kết quả online</h3>
          <p>
            Xem video, hình ảnh siêu âm, kết quả xét nghiệm — ngay trên điện
            thoại.
          </p>
        </div>
      </div>
      <div class="text-center mt-2">
        <a
          href="https://phusanansinh.com/dat-lich-hen-kham.html"
          class="btn btn-accent btn-lg"
          id="steps-cta">Đặt Lịch Ngay — Miễn Phí</a
        >
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
     SECTION 7: SOCIAL PROOF — Testimonials
     ══════════════════════════════════════ -->
  <section class="section" id="review">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Khách hàng nói gì</span>
