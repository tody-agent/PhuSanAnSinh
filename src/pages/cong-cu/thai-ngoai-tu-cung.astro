---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
const title = "Thai Ngoài Tử Cung — Công Cụ Chẩn Đoán & Quản Lý TNTC | An Sinh";
const description =
    "Bộ công cụ hỗ trợ chẩn đoán thai ngoài tử cung: Đánh giá nguy cơ, Fernandez Score, β-hCG Doubling Time. Tạo prompt AI cho gợi ý lâm sàng.";
---

<BaseLayout title={title} description={description}>
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Công cụ chẩn đoán thai ngoài tử cung hoạt động thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Bộ 3 công cụ: A) Đánh giá nguy cơ TNTC dựa trên yếu tố nguy cơ, β-hCG, siêu âm; B) Fernandez Score chấm điểm 6 tiêu chí chọn MTX vs phẫu thuật; C) β-hCG Doubling Time phân biệt IUP/sẩy thai/TNTC.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Fernandez Score là gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Hệ thống chấm điểm 6 tiêu chí (6-18 điểm) đánh giá mức độ nặng TNTC. Điểm < 12: > 80% thành công với nội khoa (MTX). Điểm ≥ 13: ưu tiên phẫu thuật.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Discriminatory Zone là gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Ngưỡng β-hCG mà trên đó nên thấy túi thai trong tử cung trên siêu âm. TVUS: 1,500-3,500 mIU/mL. TAS: 6,000-6,500 mIU/mL.",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="calc-hero">
        <div class="container">
            <div class="hero-badge">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Fernandez + β-hCG · Miễn phí 100%
            </div>
            <h1>
                Chẩn Đoán & Quản Lý <span class="text-accent-color"
                    >Thai Ngoài Tử Cung</span>
            </h1>
            <p class="hero-sub">
                Bộ công cụ hỗ trợ: Đánh giá nguy cơ TNTC, Fernandez Score (MTX
                vs Phẫu thuật), β-hCG Doubling Time. Tạo prompt AI cho gợi ý lâm
                sàng chi tiết.
            </p>
        </div>
    </section>

    <!-- Tab Navigation -->
    <section class="calc-section">
        <div class="container">
            <div class="tab-nav" id="tab-nav">
                <button class="tab-btn active" data-tab="A"
                    >🅰️ Đánh Giá Nguy Cơ</button
                >
                <button class="tab-btn" data-tab="B">🅱️ Fernandez Score</button>
                <button class="tab-btn" data-tab="C"
                    >©️ β-hCG Doubling Time</button
                >
            </div>

            <div class="calc-grid">
                <!-- ══════ TAB A: Risk Estimation ══════ -->
                <div class="tab-content active" id="tab-A">
                    <div class="calc-input-panel card">
                        <h2 class="calc-panel-title">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path
                                    d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
                                ></path><polyline points="14 2 14 8 20 8"
                                ></polyline>
                            </svg>
                            A. Đánh Giá Nguy Cơ Thai Ngoài Tử Cung
                        </h2>
                        <form id="form-A" novalidate>
                            <div class="form-section-label">
                                Thông tin bệnh nhân
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="a-age" class="form-label"
                                        >Tuổi</label
                                    ><input
                                        type="number"
                                        id="a-age"
                                        class="form-input"
                                        min="12"
                                        max="60"
                                        placeholder="Năm"
                                        required
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-para" class="form-label"
                                        >PARA</label
                                    ><input
                                        type="text"
                                        id="a-para"
                                        class="form-input"
                                        placeholder="G_P_"
                                    />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="a-ga-weeks" class="form-label"
                                        >Tuổi thai (tuần)</label
                                    ><input
                                        type="number"
                                        id="a-ga-weeks"
                                        class="form-input"
                                        min="3"
                                        max="20"
                                        placeholder="3–20"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-ga-days" class="form-label"
                                        >Ngày</label
                                    ><input
                                        type="number"
                                        id="a-ga-days"
                                        class="form-input"
                                        min="0"
                                        max="6"
                                        value="0"
                                    />
                                </div>
                            </div>

                            <hr class="form-divider" />
                            <div class="form-section-label">Yếu tố nguy cơ</div>
                            <div class="checkbox-grid">
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-previousEctopic"
                                    /><span
                                        >🔴 Tiền sử TNTC trước đó (OR ≈ 8–10)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-tubalSurgery"
                                    /><span
                                        >🔴 Phẫu thuật vòi trứng (OR ≈ 4–21)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-pid"
                                    /><span
                                        >🟠 Viêm vùng chậu / Chlamydia / Lậu (OR
                                        ≈ 2–4)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-iud"
                                    /><span
                                        >🟠 Mang IUD khi thụ thai (OR ≈ 15–50%)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-ivf"
                                    /><span>🟠 IVF/ART (OR ≈ 2–5)</span>
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-smoking"
                                    /><span>🟡 Hút thuốc lá (OR ≈ 1.5–3.5)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-endometriosis"
                                    /><span
                                        >🟡 Lạc nội mạc tử cung (OR ≈ 1.5–2.5)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-infertilityHistory"
                                    /><span>🟡 Tiền sử vô sinh (OR ≈ 2–3)</span>
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-abdominalSurgery"
                                    /><span
                                        >Phẫu thuật ổ bụng/chậu (OR ≈ 1.5)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-ageOver35"
                                    /><span>Tuổi > 35 (OR ≈ 1.4–2.7)</span>
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-rf-multiplePartners"
                                    /><span
                                        >Nhiều bạn tình / STI (OR ≈ 1.5)</span
                                    >
                                </label>
                            </div>

                            <hr class="form-divider" />
                            <div class="form-section-label">
                                Triệu chứng lâm sàng
                            </div>
                            <div class="form-group">
                                <label class="form-label">Đau bụng</label>
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-pain"
                                            value="none"
                                            checked
                                        /><span>Không</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-pain"
                                            value="induced"
                                        /><span>Khi khám</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-pain"
                                            value="spontaneous"
                                        /><span>Tự phát</span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="a-pain-loc" class="form-label"
                                    >Vị trí đau</label
                                >
                                <select id="a-pain-loc" class="form-input"
                                    ><option value="none">Không đau</option
                                    ><option value="hypogastric">Hạ vị</option
                                    ><option value="right-iliac"
                                        >Hố chậu phải</option
                                    ><option value="left-iliac"
                                        >Hố chậu trái</option
                                    ><option value="diffuse">Lan tỏa</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Ra huyết âm đạo</label
                                >
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-bleeding"
                                            value="none"
                                            checked
                                        /><span>Không</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-bleeding"
                                            value="spotting"
                                        /><span>Ra ít</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-bleeding"
                                            value="heavy"
                                        /><span>Ra nhiều</span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="a-bp" class="form-label"
                                        >Huyết áp (mmHg)</label
                                    ><input
                                        type="text"
                                        id="a-bp"
                                        class="form-input"
                                        placeholder="120/80"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-pulse" class="form-label"
                                        >Mạch (l/ph)</label
                                    ><input
                                        type="number"
                                        id="a-pulse"
                                        class="form-input"
                                        placeholder="80"
                                    />
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Huyết động</label>
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-hemo"
                                            value="stable"
                                            checked
                                        /><span>✅ Ổn định</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-hemo"
                                            value="unstable"
                                        /><span>🚨 Không ổn định</span>
                                    </label>
                                </div>
                            </div>
                            <div class="checkbox-grid">
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-cervical-motion"
                                    /><span
                                        >Đau khi lay CTC (cervical motion
                                        tenderness)</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input type="checkbox" id="a-kehr" /><span
                                        >Đau vai (dấu hiệu Kehr)</span
                                    >
                                </label>
                            </div>

                            <hr class="form-divider" />
                            <div class="form-section-label">Cận lâm sàng</div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="a-hcg" class="form-label"
                                        >β-hCG (mIU/mL)</label
                                    ><input
                                        type="number"
                                        id="a-hcg"
                                        class="form-input"
                                        min="0"
                                        step="1"
                                        placeholder="VD: 2500"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-progest" class="form-label"
                                        >Progesterone (ng/mL)</label
                                    ><input
                                        type="number"
                                        id="a-progest"
                                        class="form-input"
                                        min="0"
                                        step="0.1"
                                        placeholder="VD: 8"
                                    />
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="a-hb" class="form-label"
                                        >Hemoglobin (g/dL)</label
                                    ><input
                                        type="number"
                                        id="a-hb"
                                        class="form-input"
                                        step="0.1"
                                        placeholder="VD: 12"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-blood-type" class="form-label"
                                        >Nhóm máu</label
                                    ><input
                                        type="text"
                                        id="a-blood-type"
                                        class="form-input"
                                        placeholder="VD: O Rh+"
                                    />
                                </div>
                            </div>

                            <hr class="form-divider" />
                            <div class="form-section-label">
                                Siêu âm đầu dò âm đạo (TVUS)
                            </div>
                            <div class="form-group">
                                <label class="form-label"
                                    >Túi thai trong tử cung</label
                                >
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-iup"
                                            value="yes"
                                        /><span>Có (IUP)</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-iup"
                                            value="no"
                                            checked
                                        /><span>Không thấy</span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label"
                                    >Khối cạnh tử cung</label
                                >
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-adnexal"
                                            value="no"
                                            checked
                                        /><span>Không</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-adnexal"
                                            value="yes"
                                        /><span>Có</span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-row" id="a-adnexal-detail" hidden>
                                <div class="form-group">
                                    <label for="a-mass-size" class="form-label"
                                        >Kích thước (cm)</label
                                    ><input
                                        type="number"
                                        id="a-mass-size"
                                        class="form-input"
                                        step="0.1"
                                    />
                                </div>
                                <div class="form-group">
                                    <label for="a-mass-side" class="form-label"
                                        >Bên</label
                                    ><select id="a-mass-side" class="form-input"
                                        ><option value="right">Phải</option
                                        ><option value="left">Trái</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="a-mass-type" class="form-label"
                                    >Đặc điểm khối</label
                                >
                                <select id="a-mass-type" class="form-input"
                                    ><option value="">-- Chọn --</option><option
                                        value="tubal-ring">Tubal ring</option
                                    ><option value="mixed">Khối hỗn hợp</option
                                    ><option value="yolk-sac"
                                        >Túi thai ngoài TC có yolk sac</option
                                    ><option value="heartbeat"
                                        >Phôi ngoài TC có tim thai</option
                                    >
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Dịch ổ bụng</label>
                                <div class="toggle-group">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-fluid"
                                            value="none"
                                            checked
                                        /><span>Không</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-fluid"
                                            value="little"
                                        /><span>Ít</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-fluid"
                                            value="moderate"
                                        /><span>TB</span>
                                    </label><label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="a-fluid"
                                            value="much"
                                        /><span>Nhiều</span>
                                    </label>
                                </div>
                            </div>
                            <div class="checkbox-grid">
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-ectopic-confirmed"
                                    /><span
                                        >Phôi/túi thai ngoài TC xác nhận trên
                                        TVUS</span
                                    >
                                </label>
                                <label class="checkbox-label"
                                    ><input
                                        type="checkbox"
                                        id="a-fetal-hb-outside"
                                    /><span>Tim thai ngoài tử cung (+)</span>
                                </label>
                            </div>

                            <div
                                id="validation-error-A"
                                class="validation-error"
                                role="alert"
                                aria-live="polite"
                                hidden
                            >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-accent btn-lg calc-submit"
                                id="submit-A"
                            >
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                                    ></path><polyline
                                        points="22 4 12 14.01 9 11.01"
                                    ></polyline>
                                </svg>
                                Phân Tích Nguy Cơ TNTC
                            </button>
                        </form>
                    </div>
                    <div class="calc-results-panel" id="results-A" hidden>
                        <div
                            class="result-card result-primary card"
                            id="risk-header-A"
                        >
                            <div class="result-icon-wrap">
                                <span class="result-emoji" id="risk-emoji-A"
                                    >⚠️</span>
                            </div><div class="result-content">
                                <span class="result-label"
                                    >Phân tầng nguy cơ TNTC</span
                                ><div
                                    class="result-risk-level"
                                    id="risk-level-A"
                                >
                                    --
                                </div><div
                                    class="result-sub"
                                    id="risk-reason-A"
                                >
                                </div>
                            </div>
                        </div>
                        <div class="card result-card">
                            <h3 class="card-title">
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="var(--primary)"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><path d="M12 2L2 7l10 5 10-5-10-5z"
                                    ></path><path d="M2 17l10 5 10-5"
                                    ></path><path d="M2 12l10 5 10-5"></path>
                                </svg> Cây quyết định lâm sàng
                            </h3><div
                                id="decision-tree-A"
                                class="decision-tree-output"
                            >
                            </div>
                        </div>
                        <div class="card result-card">
                            <h3 class="card-title">
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="var(--primary)"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><rect
                                        x="3"
                                        y="3"
                                        width="18"
                                        height="18"
                                        rx="2"
                                        ry="2"></rect><line
                                        x1="3"
                                        y1="9"
                                        x2="21"
                                        y2="9"></line><line
                                        x1="9"
                                        y1="21"
                                        x2="9"
                                        y2="9"></line>
                                </svg> Bảng tổng hợp nguy cơ
                            </h3><div id="risk-summary-A"></div>
                        </div>
                        <div class="card result-card prompt-card">
                            <h3 class="card-title">
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="var(--accent)"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><path
                                        d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
                                    ></path>
                                </svg> Prompt cho AI
                            </h3><p class="prompt-desc">
                                Copy prompt → Paste vào ChatGPT, Claude, hoặc
                                Gemini.
                            </p><div class="prompt-output" id="prompt-output-A">
                            </div><button
                                class="btn btn-accent btn-lg calc-submit copy-prompt-btn"
                                data-target="prompt-output-A"
                                type="button"
                                ><svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><rect
                                        x="9"
                                        y="9"
                                        width="13"
                                        height="13"
                                        rx="2"
                                        ry="2"></rect><path
                                        d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                                    ></path>
                                </svg><span>Copy Prompt</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- ══════ TAB B: Fernandez Score ══════ -->
                <div class="tab-content" id="tab-B" hidden>
                    <div class="calc-input-panel card">
                        <h2 class="calc-panel-title">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><polyline
                                    points="22 12 18 12 15 21 9 3 6 12 2 12"
                                ></polyline>
                            </svg>
                            B. Fernandez Score — MTX vs Phẫu thuật
                        </h2>
