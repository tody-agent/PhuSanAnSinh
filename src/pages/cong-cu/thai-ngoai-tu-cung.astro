    <script>
        import {
            validateEctopicInputs,
            assessRiskFactors,
            evaluateDecisionTree,
            classifyRiskLevel,
            calcFernandezScore,
            interpretFernandez,
            checkMtxContraindications,
            calcDoublingTime,
            calcHalfLife,
            calcPercentChange48h,
            classifyHcgTrend,
            compareDiscriminatoryZone,
            getMinimumRise,
            buildPromptA,
            buildPromptB,
            buildPromptC,
        } from "../../utils/ectopic-calc.js";

        // ── Tab Navigation ──
        document.querySelectorAll(".tab-btn").forEach((btn) => {
            btn.addEventListener("click", () => {
                document
                    .querySelectorAll(".tab-btn")
                    .forEach((b) => b.classList.remove("active"));
                document.querySelectorAll(".tab-content").forEach((c) => {
                    c.hidden = true;
                    c.classList.remove("active");
                });
                btn.classList.add("active");
                const tab = document.getElementById("tab-" + btn.dataset.tab);
                if (tab) {
                    tab.hidden = false;
                    tab.classList.add("active");
                }
            });
        });

        // ── Show/Hide adnexal detail ──
        document.querySelectorAll('input[name="a-adnexal"]').forEach((r) => {
            r.addEventListener("change", () => {
                document.getElementById("a-adnexal-detail").hidden =
                    r.value !== "yes" || !r.checked;
            });
        });

        // ── Copy Prompt ──
        document.querySelectorAll(".copy-prompt-btn").forEach((btn) => {
            btn.addEventListener("click", async () => {
                const text = document.getElementById(
                    btn.dataset.target
                ).textContent;
                try {
                    await navigator.clipboard.writeText(text);
                } catch {
                    const ta = document.createElement("textarea");
                    ta.value = text;
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand("copy");
                    document.body.removeChild(ta);
                }
                const span = btn.querySelector("span");
                span.textContent = "✅ Đã Copy!";
                setTimeout(() => {
                    span.textContent = "Copy Prompt";
                }, 2000);
            });
        });

        function showError(id, msg) {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.hidden = false;
        }
        function hideError(id) {
            document.getElementById(id).hidden = true;
        }

        // ═══ TOOL A: Risk Estimation ═══
        document.getElementById("form-A").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError("validation-error-A");
            const fd = {
                age: parseInt(document.getElementById("a-age").value, 10),
                para: document.getElementById("a-para").value,
                gaWeeks: parseInt(
                    document.getElementById("a-ga-weeks").value,
                    10
                ),
                gaDays: parseInt(
                    document.getElementById("a-ga-days").value || "0",
                    10
                ),
                previousEctopic: document.getElementById("a-rf-previousEctopic")
                    .checked,
                tubalSurgery:
                    document.getElementById("a-rf-tubalSurgery").checked,
                pid: document.getElementById("a-rf-pid").checked,
                iud: document.getElementById("a-rf-iud").checked,
                ivf: document.getElementById("a-rf-ivf").checked,
                smoking: document.getElementById("a-rf-smoking").checked,
                endometriosis:
                    document.getElementById("a-rf-endometriosis").checked,
                infertilityHistory: document.getElementById(
                    "a-rf-infertilityHistory"
                ).checked,
                abdominalSurgery: document.getElementById(
                    "a-rf-abdominalSurgery"
                ).checked,
                ageOver35: document.getElementById("a-rf-ageOver35").checked,
                multiplePartners: document.getElementById(
                    "a-rf-multiplePartners"
                ).checked,
                painType: document.querySelector('input[name="a-pain"]:checked')
                    ?.value,
                painLocation: document.getElementById("a-pain-loc").value,
                vaginalBleeding: document.querySelector(
                    'input[name="a-bleeding"]:checked'
                )?.value,
                bp: document.getElementById("a-bp").value,
                pulse: document.getElementById("a-pulse").value,
                hemodynamicStable:
                    document.querySelector('input[name="a-hemo"]:checked')
                        ?.value === "stable",
                cervicalMotionTenderness: document.getElementById(
                    "a-cervical-motion"
                ).checked
                    ? "Có"
                    : "Không",
                shock: document.getElementById("a-kehr").checked
                    ? "Có"
                    : "Không",
                hcg: parseFloat(document.getElementById("a-hcg").value) || null,
                progesterone:
                    parseFloat(document.getElementById("a-progest").value) ||
                    null,
                hemoglobin:
                    parseFloat(document.getElementById("a-hb").value) || null,
                iupSeen:
                    document.querySelector('input[name="a-iup"]:checked')
                        ?.value === "yes"
                        ? "Có"
                        : "Không thấy",
                adnexalMass:
                    document.querySelector('input[name="a-adnexal"]:checked')
                        ?.value === "yes"
                        ? `Có — ${
                              document.getElementById("a-mass-size").value ||
                              "?"
                          } cm`
                        : "Không",
                freeFluid: document.querySelector(
                    'input[name="a-fluid"]:checked'
                )?.value,
            };

            const v = validateEctopicInputs(fd, "A");
            if (!v.valid) return showError("validation-error-A", v.error);

            const rf = assessRiskFactors(fd);
            const iupConfirmed =
                document.querySelector('input[name="a-iup"]:checked')?.value ===
                "yes";
            const hasAdnexalMass =
                document.querySelector('input[name="a-adnexal"]:checked')
                    ?.value === "yes";
            const ectopicConfirmed = document.getElementById(
                "a-ectopic-confirmed"
            ).checked;
            const fetalHbOutside =
                document.getElementById("a-fetal-hb-outside").checked;
            const isPUL = !iupConfirmed && !ectopicConfirmed && !hasAdnexalMass;
            const dtResult = evaluateDecisionTree({
                hemodynamicStable: fd.hemodynamicStable,
                iupConfirmed,
                ectopicConfirmed,
                fetalHeartbeatOutside: fetalHbOutside,
                hasAdnexalMass,
                isPUL,
                hcg: fd.hcg,
                ultrasoundMethod: "tvus",
            });
            const hcgAboveDZ = fd.hcg ? fd.hcg > 3500 : false;
            const riskLevel = classifyRiskLevel({
                riskFactors: rf,
                hcgAboveDiscriminatoryZone: hcgAboveDZ,
                hasAdnexalMass,
                emptyUterus: isPUL,
                iupConfirmed,
                isPUL,
                slowHcgRise: false,
            });

            // Display
            const header = document.getElementById("risk-header-A");
            header.className = `result-card result-primary card risk-${riskLevel.color}`;
            document.getElementById("risk-emoji-A").textContent =
                riskLevel.level === "LOW"
                    ? "✅"
                    : riskLevel.level === "MEDIUM"
                    ? "🟠"
                    : riskLevel.level === "HIGH"
                    ? "🔴"
                    : "🚨";
            document.getElementById("risk-level-A").textContent =
                riskLevel.label;
            document.getElementById(
                "risk-reason-A"
            ).textContent = `${rf.totalFactors} yếu tố nguy cơ | Max OR ≈ ${rf.maxOr}`;
            document.getElementById(
                "decision-tree-A"
            ).textContent = `Pathway: ${dtResult.pathway}\n\n${
                dtResult.description
            }${dtResult.requiresSurgery ? "\n\n⚠️ CẦN PHẪU THUẬT" : ""}`;
            document.getElementById(
                "risk-summary-A"
            ).innerHTML = `<div class="fern-score-grid">${
                rf.factors
                    .map(
                        (f) =>
                            `<div class="fern-score-item"><span>${f.id}. ${f.label}</span><span class="score-val">OR ≈ ${f.or}</span></div>`
                    )
                    .join("") ||
                '<div class="fern-score-item"><span>Không có yếu tố nguy cơ</span><span></span></div>'
            }</div>`;

            fd.riskFactors = rf.factors;
            document.getElementById("prompt-output-A").textContent =
                buildPromptA(fd, {
                    riskLevel: riskLevel.label,
                    pathway: dtResult.pathway,
                });
            document.getElementById("results-A").hidden = false;
            document
                .getElementById("results-A")
                .scrollIntoView({ behavior: "smooth", block: "start" });
        });

        // ═══ TOOL B: Fernandez Score ═══
        document.getElementById("form-B").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError("validation-error-B");
            const fd = {
                gestationalDays: parseInt(
                    document.getElementById("b-ga-days").value,
                    10
                ),
                hcg: parseFloat(document.getElementById("b-hcg").value),
                progesterone: parseFloat(
                    document.getElementById("b-progest").value
                ),
                pain: document.querySelector('input[name="b-pain"]:checked')
                    ?.value,
                hematosalpinxCm: parseFloat(
                    document.getElementById("b-hematosalpinx").value
                ),
                hemoperitoneumMl: parseFloat(
                    document.getElementById("b-hemoperitoneum").value
                ),
            };
            const v = validateEctopicInputs(fd, "B");
            if (!v.valid) return showError("validation-error-B", v.error);

            const fern = calcFernandezScore(fd);
            const interp = interpretFernandez(fern.total);
            const mtxData = {
                hemodynamicStable:
                    !document.getElementById("b-hemo-unstable").checked,
                fetalHeartbeatOutside:
                    document.getElementById("b-fetal-hb").checked,
                liverFailure: document.getElementById("b-liver").checked,
                renalFailure: document.getElementById("b-renal").checked,
                leukopenia: document.getElementById("b-leukopenia").checked,
                thrombocytopenia: document.getElementById("b-thrombo").checked,
                activePulmonary: document.getElementById("b-lung").checked,
                activeUlcer: document.getElementById("b-ulcer").checked,
                breastfeeding: document.getElementById("b-breastfeed").checked,
                mtxAllergy: document.getElementById("b-allergy").checked,
            };
            const mtx = checkMtxContraindications(mtxData);
            const colorMap = {
                MILD: "green",
                MODERATE: "orange",
                SEVERE: "red",
                VERY_SEVERE: "red-urgent",
            };
            const emojiMap = {
                MILD: "✅",
                MODERATE: "🟠",
                SEVERE: "🔴",
                VERY_SEVERE: "🚨",
            };

            document.getElementById(
                "risk-header-B"
            ).className = `result-card result-primary card risk-${
                colorMap[interp.severity]
            }`;
            document.getElementById("risk-emoji-B").textContent =
                emojiMap[interp.severity];
            document.getElementById(
                "risk-level-B"
            ).textContent = `${fern.total} / 18 — ${interp.label}`;
            document.getElementById("risk-reason-B").textContent =
                interp.management;

            const labels = [
                "Tuổi thai",
                "β-hCG",
                "Progesterone",
                "Đau bụng",
                "Hematosalpinx",
                "Hemoperitoneum",
            ];
            document.getElementById(
                "fernandez-detail"
            ).innerHTML = `<div class="fern-score-grid">${fern.scores
                .map(
                    (s, i) =>
                        `<div class="fern-score-item"><span>${i + 1}. ${
                            labels[i]
                        }</span><span class="score-val">${s} / 3</span></div>`
                )
                .join("")}</div>`;

            document.getElementById("mtx-result").innerHTML = mtx.eligible
                ? `<div class="mtx-eligible mtx-yes">✅ Đủ điều kiện MTX (không có chống chỉ định tuyệt đối)</div>`
                : `<div class="mtx-eligible mtx-no">❌ KHÔNG đủ điều kiện MTX<div class="mtx-list">${mtx.contraindications
                      .map((c) => `• ${c}`)
                      .join("<br>")}</div></div>`;

            const rows = document.querySelectorAll("#fernandez-table tbody tr");
            rows.forEach((r) => r.classList.remove("active-row"));
            const idx =
                fern.total <= 8
                    ? 0
                    : fern.total <= 12
                    ? 1
                    : fern.total <= 15
                    ? 2
                    : 3;
            rows[idx]?.classList.add("active-row");

            document.getElementById("prompt-output-B").textContent =
                buildPromptB(fd, {
                    fernandez: fern,
                    severity: interp.label,
                    management: interp.management,
                    mtxContraindications: mtx.contraindications,
                });
            document.getElementById("results-B").hidden = false;
            document
                .getElementById("results-B")
                .scrollIntoView({ behavior: "smooth", block: "start" });
        });

        // ═══ TOOL C: β-hCG Doubling Time ═══
        document.getElementById("form-C").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError("validation-error-C");
            const hcg1 = parseFloat(document.getElementById("c-hcg1").value);
            const hcg2 = parseFloat(document.getElementById("c-hcg2").value);
            const d1 = document.getElementById("c-hcg1-date").value;
            const d2 = document.getElementById("c-hcg2-date").value;
            const usMethod = document.querySelector(
                'input[name="c-us-method"]:checked'
            )?.value;
            const desired =
                document.querySelector('input[name="c-desired"]:checked')
                    ?.value === "yes";
            const ivf =
                document.querySelector('input[name="c-ivf"]:checked')?.value ===
                "yes";

            const fd = {
                hcg1,
                hcg1Date: d1,
                hcg2,
                hcg2Date: d2,
                ultrasoundMethod: usMethod,
            };
            const v = validateEctopicInputs(fd, "C");
            if (!v.valid) return showError("validation-error-C", v.error);

            const deltaMs = new Date(d2) - new Date(d1);
            const deltaHours = deltaMs / (1000 * 60 * 60);
            if (deltaHours <= 0)
                return showError(
                    "validation-error-C",
                    "Ngày lần 2 phải sau lần 1."
                );

            const isDecreasing = hcg2 < hcg1;
            const dt = isDecreasing
                ? null
                : calcDoublingTime(hcg1, hcg2, deltaHours);
            const hl = isDecreasing
                ? calcHalfLife(hcg1, hcg2, deltaHours)
                : null;
            const pct = calcPercentChange48h(hcg1, hcg2, deltaHours);
            const trend = classifyHcgTrend({
                doublingTimeHours: dt,
                percentChange48h: pct,
                isDecreasing,
            });
            const dz = compareDiscriminatoryZone(hcg2, usMethod, desired, ivf);
            const minRise = getMinimumRise(hcg1);
            const meetsMinRise = !isDecreasing && pct >= minRise;

            const colorMap2 = {
                NORMAL_IUP: "green",
                BORDERLINE: "yellow",
                SUSPECT_ECTOPIC: "red",
                SUSPECT_MISCARRIAGE: "orange",
                SUSPECT_ECTOPIC_DECLINE: "red-urgent",
                INDETERMINATE_DECLINE: "orange",
                PLATEAU_SUSPECT_ECTOPIC: "red",
            };
            const emojiMap2 = {
                NORMAL_IUP: "✅",
                BORDERLINE: "🟡",
                SUSPECT_ECTOPIC: "🔴",
                SUSPECT_MISCARRIAGE: "🟠",
                SUSPECT_ECTOPIC_DECLINE: "🚨",
                INDETERMINATE_DECLINE: "🟠",
                PLATEAU_SUSPECT_ECTOPIC: "🔴",
            };

            document.getElementById(
                "risk-header-C"
            ).className = `result-card result-primary card risk-${
                colorMap2[trend.classification] || "orange"
            }`;
            document.getElementById("risk-emoji-C").textContent =
                emojiMap2[trend.classification] || "⚠️";
            document.getElementById("risk-level-C").textContent = trend.label;
            document.getElementById("risk-reason-C").textContent =
                trend.description;

            document.getElementById(
                "hcg-calc-result"
            ).innerHTML = `<div class="hcg-stat-grid">
                <div class="hcg-stat"><div class="hcg-stat-label">Khoảng cách</div><div class="hcg-stat-value">${deltaHours.toFixed(
                    1
                )} giờ</div></div>
                <div class="hcg-stat"><div class="hcg-stat-label">% thay đổi / 48h</div><div class="hcg-stat-value">${
                    pct >= 0 ? "+" : ""
                }${pct.toFixed(1)}%</div></div>
                <div class="hcg-stat"><div class="hcg-stat-label">${
                    isDecreasing ? "Half-life" : "Doubling Time"
                }</div><div class="hcg-stat-value">${
                isDecreasing
                    ? hl && isFinite(hl)
                        ? hl.toFixed(1) + " giờ"
                        : "∞"
                    : dt && isFinite(dt)
                    ? dt.toFixed(1) + " giờ"
                    : "∞"
            }</div></div>
                <div class="hcg-stat"><div class="hcg-stat-label">Ngưỡng tối thiểu</div><div class="hcg-stat-value">${
                    meetsMinRise ? "✅" : "❌"
                } ≥${minRise}%</div></div>
            </div>`;

            document.getElementById(
                "dz-result"
            ).innerHTML = `<div class="hcg-stat-grid">
                <div class="hcg-stat"><div class="hcg-stat-label">β-hCG hiện tại</div><div class="hcg-stat-value">${hcg2.toLocaleString()}</div></div>
                <div class="hcg-stat"><div class="hcg-stat-label">Ngưỡng (${usMethod.toUpperCase()})</div><div class="hcg-stat-value">${dz.threshold.toLocaleString()}</div></div>
            </div><p style="text-align:center;margin-top:var(--space-md);font-weight:600;color:${
                dz.relation === "ABOVE" ? "#dc2626" : "#059669"
            }">${
                dz.relation === "ABOVE"
                    ? "⚠️ TRÊN ngưỡng — nên thấy IUP trên siêu âm"
                    : "📊 DƯỚI ngưỡng — chưa cần thấy IUP"
            }</p>`;

            const hcg3 = parseFloat(document.getElementById("c-hcg3").value);
            const d3 = document.getElementById("c-hcg3-date").value;
            document.getElementById("prompt-output-C").textContent =
                buildPromptC(
                    {
                        ...fd,
                        deltaHours,
                        hcg3: hcg3 || null,
                        hcg3Date: d3 || null,
                        ultrasoundResult:
                            document.getElementById("c-us-result").value,
                        desiredPregnancy: desired,
                        ivf,
                    },
                    {
                        doublingTime: dt,
                        percentChange48h: pct,
                        classification: trend.label,
                        isDecreasing,
                        dzRelation: dz.relation,
                        deltaHours,
                    }
                );
            document.getElementById("results-C").hidden = false;
            document
                .getElementById("results-C")
                .scrollIntoView({ behavior: "smooth", block: "start" });
        });
    </script>
</BaseLayout>
