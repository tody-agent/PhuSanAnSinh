        }
        .cta-inner {
            max-width: 600px;
            margin: 0 auto;
        }
        .cta-inner h2 {
            color: #fff;
            margin-bottom: var(--space-md);
        }
        .cta-inner p {
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: var(--space-xl);
        }
        .cta-actions {
            display: flex;
            gap: var(--space-md);
            justify-content: center;
            flex-wrap: wrap;
        }
        .cta-section .btn-outline {
