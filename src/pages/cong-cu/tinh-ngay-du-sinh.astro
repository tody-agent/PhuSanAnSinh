---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
const title =
    "Tính Ngày Dự Sinh Online — Chính Xác Theo Công Thức Y Khoa | An Sinh";
const description =
    "Công cụ tính ngày dự sinh ACOG-700 chính xác. Hỗ trợ 4 phương pháp: LMP, thụ thai, IVF/ART, siêu âm CRL. Miễn phí, dựa trên y khoa quốc tế.";
---

<BaseLayout title={title} description={description}>
    <!-- Schema.org FAQ -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Công thức tính ngày dự sinh như thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Công cụ sử dụng Quy tắc Naegele cải tiến: EDD = ngày kinh cuối + 280 ngày + (độ dài chu kỳ - 28). Theo ACOG Committee Opinion No. 700 (2017).",
                    },
                },
                {
                    "@type": "Question",
                    name: "Tính ngày dự sinh cho thai IVF như thế nào?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Với thai IVF: EDD = ngày chuyển phôi + (266 - ngày tuổi phôi). Phôi ngày 5: +261 ngày, phôi ngày 3: +263 ngày. Theo ACOG-700, EDD từ IVF ưu tiên tuyệt đối, không điều chỉnh bằng siêu âm.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Khi nào cần điều chỉnh ngày dự sinh theo siêu âm?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Theo ACOG-700: Nếu tuổi thai <9 tuần và sai lệch >5 ngày, hoặc 9-14 tuần sai lệch >7 ngày → cần điều chỉnh EDD theo siêu âm. Chi tiết xem bảng ACOG Redating trong công cụ.",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="calc-hero">
        <div class="container">
            <div class="hero-badge">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Chuẩn ACOG-700 · Miễn phí 100%
            </div>
            <h1>
                Tính Ngày Dự Sinh <span class="text-accent-color"
                    >Chính Xác</span
                >
            </h1>
            <p class="hero-sub">
                Hỗ trợ 4 phương pháp: LMP, ngày thụ thai, IVF/ART, và siêu âm
                CRL. Dựa trên tiêu chuẩn quốc tế ACOG Committee Opinion No. 700.
            </p>
        </div>
    </section>

    <!-- Calculator -->
    <section class="calc-section">
        <div class="container">
            <div class="calc-grid">
                <!-- Input Panel -->
                <div class="calc-input-panel card">
                    <h2 class="calc-panel-title">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            ><rect
                                x="3"
                                y="4"
                                width="18"
                                height="18"
                                rx="2"
                                ry="2"></rect><line
                                x1="16"
                                y1="2"
                                x2="16"
                                y2="6"></line><line x1="8" y1="2" x2="8" y2="6"
                            ></line><line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        Nhập thông tin
                    </h2>

                    <!-- Tab Bar -->
                    <div
                        class="tab-bar"
                        role="tablist"
                        aria-label="Phương pháp tính"
                    >
                        <button
                            class="tab-btn active"
                            data-tab="lmp"
                            role="tab"
                            aria-selected="true"
                            aria-controls="tab-lmp"
                            id="tab-btn-lmp">LMP</button
                        >
                        <button
                            class="tab-btn"
                            data-tab="conception"
                            role="tab"
                            aria-selected="false"
                            aria-controls="tab-conception"
                            id="tab-btn-conception">Thụ thai</button
                        >
                        <button
                            class="tab-btn"
                            data-tab="ivf"
                            role="tab"
                            aria-selected="false"
                            aria-controls="tab-ivf"
                            id="tab-btn-ivf">IVF</button
                        >
                        <button
                            class="tab-btn"
                            data-tab="ultrasound"
                            role="tab"
                            aria-selected="false"
                            aria-controls="tab-ultrasound"
                            id="tab-btn-ultrasound">Siêu âm</button
                        >
                    </div>

                    <!-- Tab: LMP -->
                    <div
                        class="tab-content active"
                        id="tab-lmp"
                        role="tabpanel"
                        aria-labelledby="tab-btn-lmp"
                    >
                        <form id="form-lmp" novalidate>
                            <div class="form-group">
                                <label for="lmp-date" class="form-label"
                                    >Ngày đầu kỳ kinh cuối</label
                                >
                                <input
                                    type="date"
                                    id="lmp-date"
                                    class="form-input"
                                    required
                                    aria-describedby="lmp-help"
                                />
                                <small id="lmp-help" class="form-help"
                                    >Ngày đầu tiên bạn thấy kinh nguyệt gần nhất</small
                                >
                            </div>
                            <div class="form-group">
                                <label for="cycle-length" class="form-label"
                                    >Độ dài chu kỳ: <strong id="cycle-value"
                                        >28</strong
                                    > ngày</label
                                >
                                <input
                                    type="range"
                                    id="cycle-length"
                                    min="21"
                                    max="45"
                                    value="28"
                                    class="form-range"
                                />
                                <div class="range-labels">
                                    <span>21</span><span>28</span><span>35</span
                                    ><span>45</span>
                                </div>
                                <small class="form-help"
                                    >Trung bình 28 ngày. Naegele cải tiến: điều
                                    chỉnh theo chu kỳ thực tế.</small
                                >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-accent btn-lg calc-submit"
                                id="submit-lmp"
                            >
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><line x1="8" y1="18" x2="16" y2="18"
                                    ></line><line x1="12" y1="6" x2="12" y2="18"
                                    ></line><polyline points="7 11 12 6 17 11"
                                    ></polyline>
                                </svg>
                                Tính Ngày Dự Sinh
                            </button>
                        </form>
                    </div>

                    <!-- Tab: Conception -->
                    <div
                        class="tab-content"
                        id="tab-conception"
                        role="tabpanel"
                        aria-labelledby="tab-btn-conception"
                        hidden
                    >
                        <form id="form-conception" novalidate>
                            <div class="form-group">
                                <label for="conception-date" class="form-label"
                                    >Ngày thụ thai / rụng trứng</label
                                >
                                <input
                                    type="date"
                                    id="conception-date"
                                    class="form-input"
                                    required
                                />
                                <small class="form-help"
                                    >Ngày bạn biết thụ thai (hoặc ngày rụng
                                    trứng ước tính)</small
                                >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-accent btn-lg calc-submit"
                            >
                                Tính Ngày Dự Sinh
                            </button>
                        </form>
                    </div>

                    <!-- Tab: IVF -->
                    <div
                        class="tab-content"
                        id="tab-ivf"
                        role="tabpanel"
                        aria-labelledby="tab-btn-ivf"
                        hidden
                    >
                        <form id="form-ivf" novalidate>
                            <div class="form-group">
                                <label for="transfer-date" class="form-label"
                                    >Ngày chuyển phôi</label
                                >
                                <input
                                    type="date"
                                    id="transfer-date"
                                    class="form-input"
                                    required
                                />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Loại phôi</label>
                                <div class="embryo-options">
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="embryo-day"
                                            value="3"
                                        />
                                        <span>Day-3</span>
                                    </label>
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="embryo-day"
                                            value="5"
                                            checked
                                        />
                                        <span>Day-5</span>
                                    </label>
                                    <label class="radio-card"
                                        ><input
                                            type="radio"
                                            name="embryo-day"
                                            value="6"
                                        />
                                        <span>Day-6</span>
                                    </label>
                                </div>
                            </div>
                            <div class="art-notice">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="var(--accent)"
                                    stroke-width="2"
                                    aria-hidden="true"
                                    ><circle cx="12" cy="12" r="10"
                                    ></circle><line
                                        x1="12"
                                        y1="16"
                                        x2="12"
                                        y2="12"></line><line
                                        x1="12"
                                        y1="8"
                                        x2="12.01"
                                        y2="8"></line>
                                </svg>
                                <span
                                    >Theo ACOG-700: EDD từ ART ưu tiên tuyệt
                                    đối, <strong>không</strong> điều chỉnh bằng siêu
                                    âm.</span
                                >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-accent btn-lg calc-submit"
                                >Tính Ngày Dự Sinh</button
                            >
                        </form>
                    </div>

                    <!-- Tab: Ultrasound -->
                    <div
                        class="tab-content"
                        id="tab-ultrasound"
                        role="tabpanel"
                        aria-labelledby="tab-btn-ultrasound"
                        hidden
                    >
                        <form id="form-ultrasound" novalidate>
                            <div class="form-group">
                                <label for="us-lmp-date" class="form-label"
                                    >Ngày đầu kỳ kinh cuối</label
                                >
                                <input
                                    type="date"
                                    id="us-lmp-date"
                                    class="form-input"
                                    required
                                />
                            </div>
                            <div class="form-group">
                                <label for="us-cycle" class="form-label"
                                    >Chu kỳ: <strong id="us-cycle-val"
                                        >28</strong
                                    > ngày</label
                                >
                                <input
                                    type="range"
                                    id="us-cycle"
                                    min="21"
                                    max="45"
                                    value="28"
                                    class="form-range"
                                />
                            </div>
                            <hr class="form-divider" />
                            <div class="form-group">
                                <label for="us-date" class="form-label"
                                    >Ngày siêu âm</label
                                >
                                <input
                                    type="date"
                                    id="us-date"
                                    class="form-input"
                                    required
                                />
                            </div>
                            <div class="form-group">
                                <label for="crl-input" class="form-label"
                                    >CRL — Chiều dài đầu mông (mm)</label
                                >
                                <input
                                    type="number"
                                    id="crl-input"
                                    class="form-input"
                                    min="10"
                                    max="84"
                                    step="1"
                                    placeholder="10 – 84 mm"
                                    required
                                />
                                <small class="form-help"
                                    >Áp dụng tam cá nguyệt I (7–14 tuần). Công
                                    thức Robinson-Fleming 1975.</small
                                >
                            </div>
                            <button
                                type="submit"
                                class="btn btn-accent btn-lg calc-submit"
                                >So Sánh & Đánh Giá</button
                            >
                        </form>
                    </div>

                    <!-- Validation Error -->
                    <div
                        id="validation-error"
                        class="validation-error"
                        role="alert"
                        aria-live="polite"
                        hidden
                    >
                    </div>
                </div>

                <!-- Results Panel -->
                <div class="calc-results-panel" id="results-panel" hidden>
                    <!-- Primary Result -->
                    <div class="result-card result-primary card">
                        <div class="result-icon-wrap">
                            <span class="result-emoji">👶</span>
                        </div>
                        <div class="result-content">
                            <span class="result-label"
                                >Ngày dự sinh ước tính</span
                            >
                            <div class="result-edd" id="result-edd">
                                --/--/----
                            </div>
                            <div class="result-sub" id="result-countdown"></div>
                        </div>
                    </div>

                    <!-- GA + Progress -->
                    <div class="result-card card">
                        <div class="result-row">
                            <div class="result-circle-wrap">
                                <svg
                                    class="progress-ring"
                                    width="90"
                                    height="90"
                                    viewBox="0 0 90 90"
                                >
                                    <circle
                                        cx="45"
                                        cy="45"
                                        r="38"
                                        fill="none"
                                        stroke="var(--border-light)"
                                        stroke-width="6"></circle>
                                    <circle
                                        id="progress-circle"
                                        cx="45"
                                        cy="45"
                                        r="38"
                                        fill="none"
                                        stroke="var(--primary)"
                                        stroke-width="6"
                                        stroke-linecap="round"
                                        stroke-dasharray="238.76"
                                        stroke-dashoffset="238.76"
                                        transform="rotate(-90 45 45)"></circle>
                                </svg>
                                <span class="progress-pct" id="progress-pct"
                                    >0%</span
                                >
                            </div>
                            <div>
                                <span class="result-label"
                                    >Tuổi thai hiện tại</span
                                >
                                <div class="result-ga" id="result-ga">
                                    -- tuần -- ngày
                                </div>
                                <div class="result-badges">
                                    <span class="badge" id="trimester-badge"
                                        >--</span
                                    >
                                    <span class="badge" id="term-badge" hidden
                                        >--</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Method badge -->
                    <div class="method-badge" id="method-badge" hidden></div>

                    <!-- Clinical Warnings -->
                    <div id="clinical-warnings"></div>

                    <!-- ACOG Comparison (ultrasound only) -->
                    <div
                        class="card acog-comparison"
                        id="acog-comparison"
                        hidden
                    >
                        <h3 class="card-title">So sánh ACOG Redating</h3>
                        <div class="comparison-grid">
                            <div class="comp-col">
                                <span class="comp-label">EDD theo LMP</span>
                                <strong class="comp-date" id="comp-edd-lmp"
                                    >--</strong
                                >
                                <span class="comp-sub" id="comp-ga-lmp">--</span
                                >
                            </div>
                            <div class="comp-vs">VS</div>
                            <div class="comp-col">
                                <span class="comp-label">EDD theo Siêu âm</span>
                                <strong class="comp-date" id="comp-edd-us"
                                    >--</strong
                                >
                                <span class="comp-sub" id="comp-ga-us">--</span>
                            </div>
                        </div>
                        <div class="comp-result" id="comp-result"></div>
                        <div class="comp-citation" id="comp-citation"></div>
                    </div>

                    <!-- Milestones Timeline -->
                    <div class="card milestones-card">
                        <h3 class="card-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="var(--primary)"
                                stroke-width="2"
                                aria-hidden="true"
                                ><polyline
                                    points="22 12 18 12 15 21 9 3 6 12 2 12"
                                ></polyline>
                            </svg>
                            Lịch khám thai quan trọng
                        </h3>
                        <div class="timeline" id="milestones-timeline"></div>
                    </div>

                    <!-- Baby Dev -->
                    <div class="card baby-dev-card" id="baby-dev-card" hidden>
                        <h3 class="card-title">
                            <span id="baby-emoji">🍇</span>
                            Bé yêu tuần <span id="baby-week">--</span>
                        </h3>
                        <div class="baby-stats">
                            <span class="baby-stat"
                                ><strong>Kích thước:</strong>
                                <span id="baby-size">--</span>
                            </span>
                            <span class="baby-stat"
                                ><strong>Cân nặng:</strong>
                                <span id="baby-weight">--</span>
                            </span>
                            <span class="baby-stat"
                                ><strong>So sánh:</strong>
                                <span id="baby-fruit">--</span>
                            </span>
                        </div>
                        <p class="baby-desc" id="baby-desc"></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section" id="cta">
        <div class="container">
            <div class="cta-inner">
                <h2>Cần tư vấn chuyên sâu?</h2>
                <p>
                    Bác sĩ chuyên khoa sản tại An Sinh sẵn sàng đồng hành cùng
                    bạn trong thai kỳ.
                </p>
                <div class="cta-actions">
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-accent btn-lg"
                        id="cta-booking">Đặt Lịch Khám Ngay</a
                    >
                    <a
                        href="tel:0899268299"
                        class="btn btn-outline btn-lg"
                        id="cta-call">Gọi: 0899 268 299</a
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- Disclaimer -->
    <section class="disclaimer-section">
        <div class="container">
            <p class="disclaimer-text">
                <strong>Lưu ý y khoa:</strong> Công cụ này chỉ mang tính hỗ trợ tham
                khảo lâm sàng, KHÔNG thay thế đánh giá của bác sĩ chuyên khoa. Dựa
                trên: ACOG Committee Opinion No. 700 (2017, Reaffirmed 2022) — "Methods
                for Estimating the Due Date." Công thức CRL: Robinson & Fleming (1975).
                Phân kỳ thai: ACOG Committee Opinion No. 579.
            </p>
        </div>
    </section>

    <style>
        /* ── Hero ── */
        .calc-hero {
            background: linear-gradient(
                135deg,
                var(--primary-light) 0%,
                var(--bg) 100%
            );
            padding: var(--space-4xl) 0 var(--space-3xl);
            text-align: center;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: var(--space-xs);
            padding: var(--space-xs) var(--space-lg);
            background: var(--surface);
            border-radius: var(--radius-full);
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: var(--space-lg);
            border: 1px solid var(--border-light);
        }
        .hero-sub {
            font-size: 1.0625rem;
            color: var(--text-secondary);
            line-height: 1.8;
            max-width: 640px;
            margin: 0 auto;
        }
        /* ── Calculator Layout ── */
        .calc-section {
            padding: var(--space-3xl) 0;
        }
        .calc-grid {
            display: grid;
            grid-template-columns: 420px 1fr;
            gap: var(--space-2xl);
            align-items: start;
        }
        .calc-input-panel {
            position: sticky;
            top: 88px;
        }
        .calc-panel-title {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            font-size: 1.125rem;
            margin-bottom: var(--space-lg);
        }
        /* ── Tab Bar ── */
        .tab-bar {
            display: flex;
            gap: 2px;
            background: var(--surface-alt);
            border-radius: var(--radius-md);
            padding: 3px;
            margin-bottom: var(--space-xl);
        }
        .tab-btn {
            flex: 1;
            padding: var(--space-sm) var(--space-md);
            background: none;
            border: none;
            border-radius: var(--radius-sm);
            font-family: var(--font-body);
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            transition: all var(--transition-fast);
            min-height: 44px;
        }
        .tab-btn:hover {
            color: var(--text-primary);
        }
        .tab-btn.active {
            background: var(--bg-white);
            color: var(--primary);
            box-shadow: var(--shadow-sm);
        }
        .tab-content:not(.active) {
            display: none;
        }
        .tab-content.active {
            display: block;
        }
        /* ── Form ── */
        .form-group {
            margin-bottom: var(--space-lg);
        }
        .form-label {
            display: block;
            font-weight: 600;
            font-size: 0.9375rem;
            margin-bottom: var(--space-sm);
            color: var(--text-primary);
        }
        .form-input {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            font-family: var(--font-body);
            font-size: 1rem;
            color: var(--text-primary);
            background: var(--bg-white);
            transition: border-color var(--transition-fast);
            min-height: 44px;
        }
        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(27, 122, 109, 0.1);
        }
        .form-range {
            width: 100%;
            height: 8px;
            appearance: none;
            -webkit-appearance: none;
            background: var(--border);
            border-radius: var(--radius-full);
            outline: none;
            margin: var(--space-sm) 0;
        }
        .form-range::-webkit-slider-thumb {
            appearance: none;
            -webkit-appearance: none;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--primary);
            cursor: pointer;
            border: 3px solid #fff;
            box-shadow: var(--shadow-md);
        }
        .form-range::-moz-range-thumb {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--primary);
            cursor: pointer;
            border: 3px solid #fff;
