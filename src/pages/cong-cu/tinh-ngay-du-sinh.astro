            border-color: rgba(255, 255, 255, 0.5);
        }
        .cta-section .btn-outline:hover {
            background: rgba(255, 255, 255, 0.15);
            color: #fff;
            border-color: #fff;
        }
        /* ── Disclaimer ── */
        .disclaimer-section {
            padding: var(--space-xl) 0;
