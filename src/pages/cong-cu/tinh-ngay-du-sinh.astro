            color: var(--text-muted);
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
            line-height: 1.7;
        }
        /* ── Responsive ── */
        @media (max-width: 768px) {
            .calc-grid {
                grid-template-columns: 1fr;
            }
            .calc-input-panel {
                position: static;
            }
            .tab-btn {
                font-size: 0.75rem;
                padding: var(--space-sm);
            }
            .result-row {
                flex-direction: column;
                text-align: center;
            }
            .comparison-grid {
                grid-template-columns: 1fr;
                gap: var(--space-sm);
            }
            .comp-vs {
                display: none;
            }
            .cta-actions {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>

    <script>
        import {
            calculateDueDate,
            calculateDueDateFromConception,
            calculateGestationalAge,
            getTrimester,
            getPregnancyProgress,
            generateCheckupMilestones,
            getBabyDevelopment,
            getMilestoneStatus,
            formatDateVN,
            validateLmpDate,
            toLocalDate,
            calcEddByLmpModified,
            calcEddByIvf,
            calcGaFromCrl,
            calcEddFromUltrasoundGa,
            shouldRedate,
            reconcileEdd,
            getTermClassification,
            getClinicalWarnings,
        } from "../../utils/due-date-calc.js";

        // ── Tab Switching ──
        const tabBtns = document.querySelectorAll(".tab-btn");
        const tabContents = document.querySelectorAll(".tab-content");
        tabBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const t = btn.dataset.tab;
                tabBtns.forEach((b) => {
                    b.classList.remove("active");
                    b.setAttribute("aria-selected", "false");
                });
                tabContents.forEach((c) => {
                    c.classList.remove("active");
                    c.hidden = true;
                });
                btn.classList.add("active");
                btn.setAttribute("aria-selected", "true");
                const panel = document.getElementById("tab-" + t);
                panel.classList.add("active");
                panel.hidden = false;
                document.getElementById("results-panel").hidden = true;
                hideError();
            });
        });

        // ── Sliders ──
        const cycleSlider = document.getElementById("cycle-length");
        const cycleValue = document.getElementById("cycle-value");
        cycleSlider.addEventListener("input", () => {
            cycleValue.textContent = cycleSlider.value;
        });

        const usCycleSlider = document.getElementById("us-cycle");
        const usCycleVal = document.getElementById("us-cycle-val");
        usCycleSlider.addEventListener("input", () => {
            usCycleVal.textContent = usCycleSlider.value;
        });

        // ── Set max date ──
        const today = new Date();
        const maxDate = today.toISOString().split("T")[0];
        document.querySelectorAll('input[type="date"]').forEach((el) => {
            el.max = maxDate;
        });

        // ── Form: LMP ──
        document.getElementById("form-lmp").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError();
            const lmpDate = document.getElementById("lmp-date").value;
            const cycleLength = parseInt(cycleSlider.value, 10);
            const valid = validateLmpDate(lmpDate);
            if (!valid.valid) return showError(valid.error);
            const edd = calcEddByLmpModified(lmpDate, cycleLength);
            const ga = calculateGestationalAge(lmpDate);
            showResults(edd, ga, lmpDate, "LMP (Naegele cải tiến)");
        });

        // ── Form: Conception ──
        document
            .getElementById("form-conception")
            .addEventListener("submit", (e) => {
                e.preventDefault();
                hideError();
                const cDate = document.getElementById("conception-date").value;
                if (!cDate) return showError("Vui lòng chọn ngày thụ thai.");
                const edd = calculateDueDateFromConception(cDate);
                // GA from conception ≈ conception + 14 days = LMP equivalent
                const lmpEquiv = new Date(toLocalDate(cDate));
                lmpEquiv.setDate(lmpEquiv.getDate() - 14);
                const ga = calculateGestationalAge(lmpEquiv);
                showResults(edd, ga, lmpEquiv, "Ngày thụ thai");
            });

        // ── Form: IVF ──
        document.getElementById("form-ivf").addEventListener("submit", (e) => {
            e.preventDefault();
            hideError();
            const tDate = document.getElementById("transfer-date").value;
            if (!tDate) return showError("Vui lòng chọn ngày chuyển phôi.");
            const embryoDay = parseInt(
                document.querySelector('input[name="embryo-day"]:checked')
                    .value,
                10
            );
            const edd = calcEddByIvf(tDate, embryoDay);
            // GA equivalent: transfer - (embryoDay) + 14 = LMP equivalent
            const lmpEquiv = new Date(toLocalDate(tDate));
            lmpEquiv.setDate(lmpEquiv.getDate() - embryoDay - 14);
            const ga = calculateGestationalAge(lmpEquiv);
            showResults(edd, ga, lmpEquiv, "ART-derived", true);
        });

        // ── Form: Ultrasound ──
        document
            .getElementById("form-ultrasound")
            .addEventListener("submit", (e) => {
                e.preventDefault();
                hideError();
                const lmpDate = document.getElementById("us-lmp-date").value;
                const cycleLength = parseInt(usCycleSlider.value, 10);
                const usDate = document.getElementById("us-date").value;
                const crl = parseFloat(
                    document.getElementById("crl-input").value
                );

                const validLmp = validateLmpDate(lmpDate);
                if (!validLmp.valid) return showError(validLmp.error);
                if (!usDate) return showError("Vui lòng chọn ngày siêu âm.");
                if (isNaN(crl) || crl < 10 || crl > 84)
                    return showError("CRL phải từ 10 đến 84 mm.");

                const gaUs = calcGaFromCrl(crl, "robinson");
                const result = reconcileEdd(
                    lmpDate,
                    cycleLength,
                    usDate,
                    gaUs,
                    false
                );
                const ga = calculateGestationalAge(lmpDate);
                showResults(result.eddFinal, ga, lmpDate, result.method);
                showAcogComparison(result, gaUs, lmpDate, usDate, cycleLength);
            });

        // ── Show Results ──
        function showResults(edd, ga, lmpDate, method, isArt = false) {
            const panel = document.getElementById("results-panel");
            document.getElementById("result-edd").textContent =
                formatDateVN(edd);

            // Countdown
            const daysLeft = Math.ceil(
                (edd.getTime() - today.getTime()) / (1000 * 60 * 60 * 24)
            );
            document.getElementById("result-countdown").textContent =
                daysLeft > 0
                    ? `Còn ${daysLeft} ngày nữa`
                    : daysLeft === 0
                    ? "Hôm nay là ngày dự sinh!"
                    : `Đã qua ${Math.abs(daysLeft)} ngày`;

            // GA
            document.getElementById(
                "result-ga"
            ).textContent = `${ga.weeks} tuần ${ga.days} ngày`;

            // Progress
            const progress = getPregnancyProgress(lmpDate);
            document.getElementById("progress-pct").textContent =
                Math.round(progress) + "%";
            const circle = document.getElementById("progress-circle");
            const circumference = 2 * Math.PI * 38;
            circle.style.strokeDashoffset =
                circumference - (progress / 100) * circumference;

            // Trimester badge
            const tri = getTrimester(ga.weeks);
            const triBadge = document.getElementById("trimester-badge");
            triBadge.textContent = `Tam cá nguyệt ${
                tri === 1 ? "I" : tri === 2 ? "II" : "III"
            }`;
            triBadge.className = `badge badge-t${tri}`;

            // Term classification
            const termBadge = document.getElementById("term-badge");
            if (ga.weeks >= 37) {
                const term = getTermClassification(ga.weeks, ga.days);
                const termLabels = {
                    preterm: "Non tháng",
                    "early-term": "Đủ tháng sớm",
                    "full-term": "Đủ tháng",
                    "late-term": "Muộn kỳ",
                    "post-term": "Quá ngày",
                };
                termBadge.textContent = termLabels[term];
                termBadge.className = `badge badge-${term}`;
                termBadge.hidden = false;
            } else {
                termBadge.hidden = true;
            }

            // Method badge
            const methodBadge = document.getElementById("method-badge");
            if (isArt) {
                methodBadge.textContent =
                    "🧪 ART-derived — Không điều chỉnh bằng siêu âm";
                methodBadge.className = "method-badge method-art";
                methodBadge.hidden = false;
            } else if (method.includes("Siêu âm")) {
                methodBadge.textContent = "📋 " + method;
                methodBadge.className = "method-badge method-us-redate";
                methodBadge.hidden = false;
            } else {
                methodBadge.hidden = true;
            }

            // Clinical warnings
            const warningsDiv = document.getElementById("clinical-warnings");
            const warnings = getClinicalWarnings(ga);
            warningsDiv.innerHTML = warnings
                .map(
                    (w) => `
        <div class="clinical-warning warning-${w.severity}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span>${w.message}</span>
        </div>
    `
                )
                .join("");

            // ACOG comparison hidden by default (shown only for ultrasound)
            document.getElementById("acog-comparison").hidden = true;

            // Milestones
            renderMilestones(lmpDate, ga);

            // Baby dev
            renderBabyDev(ga.weeks);

            panel.hidden = false;
            panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        function showAcogComparison(
            result,
            gaUs,
            lmpDate,
            usDate,
            cycleLength
        ) {
            const comp = document.getElementById("acog-comparison");
            document.getElementById("comp-edd-lmp").textContent = formatDateVN(
                result.eddLmp
            );
            document.getElementById("comp-edd-us").textContent = formatDateVN(
                result.eddUltrasound
            );
            const gaLmpAtUs = calculateGestationalAge(lmpDate, usDate);
            document.getElementById(
                "comp-ga-lmp"
            ).textContent = `${gaLmpAtUs.weeks}t ${gaLmpAtUs.days}ng (theo LMP)`;
            document.getElementById(
                "comp-ga-us"
            ).textContent = `${gaUs.weeks}t ${gaUs.days}ng (theo CRL)`;

            const compResult = document.getElementById("comp-result");
            if (result.wasRedated) {
                compResult.textContent = `⚠️ ĐIỀU CHỈNH sang EDD siêu âm — sai lệch ${result.discrepancyDays} ngày > ngưỡng ${result.decision.threshold} ngày`;
                compResult.className = "comp-result redate";
            } else {
                compResult.textContent = `✅ GIỮ NGUYÊN EDD theo LMP — sai lệch ${result.discrepancyDays} ngày ≤ ngưỡng ${result.decision.threshold} ngày`;
                compResult.className = "comp-result keep";
            }
            document.getElementById("comp-citation").textContent =
                result.decision.acogCitation;

            // Check for T3 redating warning
            if (result.wasRedated && gaLmpAtUs.weeks >= 28) {
                const warningsDiv =
                    document.getElementById("clinical-warnings");
                warningsDiv.innerHTML += `
            <div class="clinical-warning warning-danger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                <span>Cảnh báo IUGR: Điều chỉnh EDD trong tam cá nguyệt III có nguy cơ bỏ sót thai chậm tăng trưởng. Cần đánh giá lâm sàng toàn diện. (ACOG-700)</span>
            </div>`;
            }

            comp.hidden = false;
        }

        function renderMilestones(lmpDate, ga) {
            const milestones = generateCheckupMilestones(lmpDate);
            const timeline = document.getElementById("milestones-timeline");
            timeline.innerHTML = milestones
                .map((m) => {
                    const status = getMilestoneStatus(
                        m.week,
                        ga.weeks,
                        ga.days
                    );
                    return `<div class="milestone ${status}">
            <div class="milestone-dot"></div>
            <div class="milestone-title">Tuần ${m.week}: ${m.title}</div>
            <div class="milestone-date">${formatDateVN(m.date)}</div>
            <div class="milestone-tests">${m.tests
                .slice(0, 2)
                .join(" · ")}</div>
        </div>`;
                })
                .join("");
        }

        function renderBabyDev(weeks) {
            const dev = getBabyDevelopment(weeks);
            const card = document.getElementById("baby-dev-card");
            if (!dev) {
                card.hidden = true;
                return;
            }
            document.getElementById("baby-emoji").textContent = dev.fruitEmoji;
            document.getElementById("baby-week").textContent = weeks;
            document.getElementById("baby-size").textContent = dev.size;
            document.getElementById("baby-weight").textContent = dev.weight;
            document.getElementById("baby-fruit").textContent = dev.fruit;
            document.getElementById("baby-desc").textContent = dev.description;
            card.hidden = false;
        }

        function showError(msg) {
            const el = document.getElementById("validation-error");
            el.textContent = msg;
            el.hidden = false;
        }
        function hideError() {
            document.getElementById("validation-error").hidden = true;
        }
    </script>
</BaseLayout>
