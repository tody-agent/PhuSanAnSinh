            .pe-grid {
                grid-template-columns: 1fr !important;
            }
            .pe-results-panel {
                display: flex !important;
            }
            .pe-details {
                break-inside: avoid;
            }
            .pe-details[open] summary ~ * {
                display: block !important;
            }
        }
    </style>

    <script>
        import {
            createEmptyPatient,
            preprocess,
            screenPatient,
        } from "../../utils/preeclampsia-engine.js";
        import { buildPrompt } from "../../utils/preeclampsia-prompt.js";

        // ── DOM refs ──
        const nameInput = document.getElementById(
            "pe-name"
        ) as HTMLInputElement;
        const ageInput = document.getElementById("pe-age") as HTMLInputElement;
        const gaWeeksInput = document.getElementById(
            "pe-ga-weeks"
        ) as HTMLInputElement;
        const gaDaysInput = document.getElementById(
            "pe-ga-days"
        ) as HTMLInputElement;
        const heightInput = document.getElementById(
            "pe-height"
        ) as HTMLInputElement;
        const weightInput = document.getElementById(
            "pe-weight"
        ) as HTMLInputElement;
        const bmiDisplay = document.getElementById("pe-bmi-display")!;

        const countHigh = document.getElementById("count-high")!;
        const countMod = document.getElementById("count-mod")!;

        const submitBtn = document.getElementById("pe-submit")!;
        const resultsPanel = document.getElementById("pe-results")!;

        const badgeAcog = document.getElementById("badge-acog")!;
        const badgeNice = document.getElementById("badge-nice")!;
        const concordanceEl = document.getElementById("pe-concordance")!;
        const aspirinBox = document.getElementById(
            "pe-aspirin-box"
        ) as HTMLElement;
        const aspirinContent = document.getElementById("pe-aspirin-content")!;
        const factorsContent = document.getElementById("pe-factors-content")!;
        const followupList = document.getElementById("pe-followup-list")!;
        const warningList = document.getElementById("pe-warning-list")!;
        const copyBtn = document.getElementById("pe-copy-btn")!;
        const copyText = document.getElementById("pe-copy-text")!;
        const printBtn = document.getElementById("pe-print-btn")!;

        let lastResult: any = null;
        let lastPatient: any = null;

        // ── Auto BMI ──
        function updateBMI() {
            const h = parseFloat(heightInput.value);
            const w = parseFloat(weightInput.value);
            if (h > 0 && w > 0) {
                const bmi = w / (h / 100) ** 2;
                bmiDisplay.textContent = bmi.toFixed(1);
            } else {
                bmiDisplay.textContent = "—";
            }
        }
        heightInput.addEventListener("input", updateBMI);
        weightInput.addEventListener("input", updateBMI);

        // ── Auto-check age/BMI ──
        function updateAutoChecks() {
            const age = parseInt(ageInput.value);
            const h = parseFloat(heightInput.value);
            const w = parseFloat(weightInput.value);
            const bmi = h > 0 && w > 0 ? w / (h / 100) ** 2 : null;

            const age35 = document.getElementById(
                "mr-age35"
            ) as HTMLInputElement;
            const bmi30 = document.getElementById(
                "mr-bmi30"
            ) as HTMLInputElement;
            const tagAge = document.getElementById("tag-age35")!;
            const tagBmi = document.getElementById("tag-bmi30")!;

            if (!isNaN(age) && age >= 35) {
                age35.checked = true;
                tagAge.style.display = "";
            } else if (!isNaN(age)) {
                age35.checked = false;
                tagAge.style.display = "none";
            }

            if (bmi != null && bmi > 30) {
                bmi30.checked = true;
                tagBmi.style.display = "";
            } else if (bmi != null) {
                bmi30.checked = false;
                tagBmi.style.display = "none";
            }

            updateCounts();
        }
        ageInput.addEventListener("input", updateAutoChecks);
        heightInput.addEventListener("input", updateAutoChecks);
        weightInput.addEventListener("input", updateAutoChecks);

        // ── Sub-fields toggle ──
        document
            .getElementById("hr-preeclampsia")!
            .addEventListener("change", (e) => {
                const el = document.getElementById("sub-pe-adverse")!;
                el.style.display = (e.target as HTMLInputElement).checked
                    ? ""
                    : "none";
            });
        document
            .getElementById("hr-autoimmune")!
            .addEventListener("change", (e) => {
                const el = document.getElementById("sub-autoimmune")!;
                el.style.display = (e.target as HTMLInputElement).checked
                    ? ""
                    : "none";
            });

        // ── Count badges ──
        function updateCounts() {
            const highChecks = document.querySelectorAll(
                '[data-group="high"]:checked'
            );
            const modChecks = document.querySelectorAll(
                '[data-group="mod"]:checked'
            );
            countHigh.textContent = String(highChecks.length);
            countMod.textContent = String(modChecks.length);
        }
        document.querySelectorAll("[data-group]").forEach((cb) => {
            cb.addEventListener("change", updateCounts);
        });

        // ── Build patient from form ──
        function buildPatient() {
            const p = createEmptyPatient();
            p.name = nameInput.value.trim();
            p.maternal_age = ageInput.value ? parseInt(ageInput.value) : null;
            p.gestational_age_weeks = gaWeeksInput.value
                ? parseInt(gaWeeksInput.value)
                : null;
            p.gestational_age_days = gaDaysInput.value
                ? parseInt(gaDaysInput.value)
                : null;
            p.height_cm = heightInput.value
                ? parseFloat(heightInput.value)
                : null;
            p.weight_kg = weightInput.value
                ? parseFloat(weightInput.value)
                : null;

            // High risk
            p.high_risk.history_preeclampsia = (
                document.getElementById("hr-preeclampsia") as HTMLInputElement
            ).checked;
            p.high_risk.pe_with_adverse_outcome = (
                document.getElementById("hr-pe-adverse") as HTMLInputElement
            ).checked;
            p.high_risk.multifetal = (
                document.getElementById("hr-multifetal") as HTMLInputElement
            ).checked;
            p.high_risk.chronic_hypertension = (
                document.getElementById("hr-hypertension") as HTMLInputElement
            ).checked;
            p.high_risk.pregestational_diabetes = (
                document.getElementById("hr-diabetes") as HTMLInputElement
            ).checked;
            p.high_risk.chronic_kidney_disease = (
                document.getElementById("hr-kidney") as HTMLInputElement
            ).checked;
            p.high_risk.autoimmune_disease = (
                document.getElementById("hr-autoimmune") as HTMLInputElement
            ).checked;
            p.high_risk.autoimmune_type =
                (
                    document.getElementById(
                        "hr-autoimmune-type"
                    ) as HTMLSelectElement
                ).value || null;

            // Moderate risk
            p.moderate_risk.nulliparity = (
                document.getElementById("mr-nulliparity") as HTMLInputElement
            ).checked;
            p.moderate_risk.family_history_pe = (
                document.getElementById("mr-family") as HTMLInputElement
            ).checked;
            p.moderate_risk.interpregnancy_gt_10y = (
                document.getElementById("mr-interpregnancy") as HTMLInputElement
            ).checked;
            p.moderate_risk.ivf = (
                document.getElementById("mr-ivf") as HTMLInputElement
            ).checked;
            p.moderate_risk.previous_adverse_outcome = (
                document.getElementById("mr-adverse") as HTMLInputElement
            ).checked;
            p.moderate_risk.low_income = (
                document.getElementById("mr-income") as HTMLInputElement
            ).checked;

            return p;
        }

        // ── Render results ──
        function renderResults(patient: any, result: any) {
            resultsPanel.style.display = "";

            // Risk badges
            setBadge(badgeAcog, result.acog_category);
            setBadge(badgeNice, result.nice_category);

            // Concordance
            if (result.guidelines_agree) {
                concordanceEl.style.display = "";
                concordanceEl.className = "pe-concordance pe-concordance-agree";
                concordanceEl.innerHTML = "✓ Hai guideline đồng thuận";
            } else {
                concordanceEl.style.display = "";
                concordanceEl.className =
                    "pe-concordance pe-concordance-disagree";
                concordanceEl.innerHTML =
                    "⚠ Hai guideline KHÔNG đồng thuận<br>" +
                    result.discordance_reasons
                        .map((r: string) => "• " + r)
                        .join("<br>");
            }

            // Aspirin
            if (
                result.acog_aspirin === true ||
                result.acog_aspirin === "CONSIDER"
            ) {
                aspirinBox.style.display = "";
                const urgencyClass =
                    {
                        OPTIMAL: "pe-urgency-optimal",
                        LATE_BUT_BENEFICIAL: "pe-urgency-late",
                        QUESTIONABLE: "pe-urgency-questionable",
                        DO_NOT_START: "pe-urgency-donotstart",
                        PENDING: "pe-urgency-pending",
                    }[result.aspirin_urgency || "PENDING"] ||
                    "pe-urgency-pending";

                let html = "";
                if (result.acog_aspirin === "CONSIDER") {
                    html +=
                        '<div class="pe-aspirin-row"><span class="pe-aspirin-label">Tình trạng:</span> <strong>Cân nhắc</strong> (chỉ 1 yếu tố moderate: thu nhập thấp)</div>';
                } else {
                    html +=
                        '<div class="pe-aspirin-row"><span class="pe-aspirin-label">Tình trạng:</span> <strong>Có — Khuyến cáo dùng</strong></div>';
                }
                html += `<div class="pe-aspirin-row"><span class="pe-aspirin-label">Liều:</span> ${result.aspirin_dose}</div>`;
                if (result.aspirin_timing) {
                    html += `<div class="pe-aspirin-row"><span class="pe-aspirin-label">Thời điểm:</span> ${result.aspirin_timing}</div>`;
                }
                if (result.aspirin_urgency) {
                    html += `<div class="pe-aspirin-row"><span class="pe-aspirin-label">Mức khẩn:</span> <span class="pe-urgency-tag ${urgencyClass}">${result.aspirin_urgency}</span></div>`;
                }
                html +=
                    '<div style="font-size:0.8125rem;color:var(--text-muted);margin-top:var(--space-sm);">Uống buổi tối trước ngủ · Dừng ở tuần 36</div>';
                aspirinContent.innerHTML = html;
            } else {
                aspirinBox.style.display = "none";
            }

            // Factors
            let fHtml = "";
            fHtml +=
                '<div class="pe-factor-group"><div class="pe-factor-label">Nhóm A (Cao)</div>';
            if (result.acog_high_factors.length > 0) {
                fHtml +=
                    '<div class="pe-factor-tags">' +
                    result.acog_high_factors
                        .map(
                            (f: string) =>
                                `<span class="pe-factor-tag pe-factor-tag-high">${f}</span>`
                        )
                        .join("") +
                    "</div>";
            } else {
                fHtml += '<p class="pe-factor-none">Không có</p>';
            }
            fHtml += "</div>";

            fHtml +=
                '<div class="pe-factor-group"><div class="pe-factor-label">Nhóm B (Trung bình)</div>';
            if (result.acog_moderate_factors.length > 0) {
                fHtml +=
                    '<div class="pe-factor-tags">' +
                    result.acog_moderate_factors
                        .map(
                            (f: string) =>
                                `<span class="pe-factor-tag pe-factor-tag-mod">${f}</span>`
                        )
                        .join("") +
                    "</div>";
            } else {
                fHtml += '<p class="pe-factor-none">Không có</p>';
            }
            fHtml += "</div>";
            factorsContent.innerHTML = fHtml;

            // Follow-up
            followupList.innerHTML = result.follow_up_items
                .map((item: string) => `<li>${item}</li>`)
                .join("");

            // Warning signs
            warningList.innerHTML = result.warning_signs
                .map((item: string) => `<li>${item}</li>`)
                .join("");

            // Scroll to results
            resultsPanel.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        function setBadge(el: HTMLElement, category: string) {
            const labels: Record<string, string> = {
                HIGH: "CAO",
                MODERATE: "TRUNG BÌNH",
                LOW: "THẤP",
            };
            const classes: Record<string, string> = {
                HIGH: "pe-risk-high",
                MODERATE: "pe-risk-moderate",
                LOW: "pe-risk-low",
            };
            el.textContent = labels[category] || category;
            el.className = "pe-risk-badge " + (classes[category] || "");
        }

        // ── Submit ──
        submitBtn.addEventListener("click", () => {
            const patient = buildPatient();
            lastPatient = patient;
            lastResult = screenPatient(patient);
            renderResults(patient, lastResult);
        });

        // ── Copy Prompt ──
        copyBtn.addEventListener("click", async () => {
            if (!lastPatient || !lastResult) return;
            const prompt = buildPrompt(lastPatient, lastResult);
            try {
                await navigator.clipboard.writeText(prompt);
                copyText.textContent = "✓ Đã sao chép!";
                copyBtn.classList.add("copied");
                setTimeout(() => {
                    copyText.textContent = "Sao Chép Prompt Để Hỏi AI";
                    copyBtn.classList.remove("copied");
                }, 2000);
            } catch {
                // Fallback
                const ta = document.createElement("textarea");
                ta.value = prompt;
                ta.style.position = "fixed";
                ta.style.opacity = "0";
                document.body.appendChild(ta);
                ta.select();
                document.execCommand("copy");
                document.body.removeChild(ta);
                copyText.textContent = "✓ Đã sao chép!";
                copyBtn.classList.add("copied");
                setTimeout(() => {
                    copyText.textContent = "Sao Chép Prompt Để Hỏi AI";
                    copyBtn.classList.remove("copied");
                }, 2000);
            }
        });

        // ── Print ──
        printBtn.addEventListener("click", () => window.print());
    </script>
</BaseLayout>
