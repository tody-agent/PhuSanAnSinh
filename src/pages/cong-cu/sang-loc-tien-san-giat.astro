        }

        /* ── Responsive ── */
        @media (max-width: 900px) {
            .pe-grid {
                grid-template-columns: 1fr;
            }
            .pe-input-panel {
                position: static;
            }
            .form-row {
                grid-template-columns: 1fr 1fr;
            }
        }
        @media (max-width: 480px) {
            .form-row {
                grid-template-columns: 1fr;
            }
            .pe-badges-row {
                grid-template-columns: 1fr;
            }
        }

        /* ── Print ── */
        @media print {
            .pe-hero,
            .cta-section,
            .pe-copy-section,
            .pe-print-btn,
            .pe-input-panel,
            .site-header,
            .site-footer,
