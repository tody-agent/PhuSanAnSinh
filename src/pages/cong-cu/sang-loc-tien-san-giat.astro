        }
        .pe-print-btn {
            width: 100%;
        }

        /* ── CTA Section ── */
        .cta-section {
            padding: var(--space-3xl) 0;
        }
        .cta-inner {
            background: linear-gradient(
                135deg,
                var(--primary) 0%,
                var(--primary-dark) 100%
            );
            border-radius: var(--radius-xl);
            padding: var(--space-3xl);
            text-align: center;
            color: #fff;
        }
        .cta-inner h2 {
            color: #fff;
            margin-bottom: var(--space-md);
        }
        .cta-inner p {
            color: rgba(255, 255, 255, 0.9);
