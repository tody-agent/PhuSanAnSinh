---
import "../../styles/global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";
const title =
    "Sàng Lọc Nguy Cơ Tiền Sản Giật — ACOG/USPSTF 2021 + NICE NG133 | An Sinh";
const description =
    "Công cụ sàng lọc nguy cơ tiền sản giật dựa trên ACOG/USPSTF 2021 và NICE NG133. Phân loại tự động, so sánh guideline, tạo prompt AI. Miễn phí, chạy offline.";
---

<BaseLayout title={title} description={description}>
    <!-- Schema.org FAQ -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "Tiền sản giật là gì?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Tiền sản giật là rối loạn tăng huyết áp trong thai kỳ, xuất hiện sau tuần 20, đặc trưng bởi HA ≥140/90 mmHg kèm protein niệu hoặc tổn thương cơ quan đích.",
                    },
                },
                {
                    "@type": "Question",
                    name: "Aspirin dự phòng tiền sản giật có hiệu quả không?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Nghiên cứu ASPRE (NEJM 2017) cho thấy aspirin 150mg/ngày trước 16 tuần giảm 62% tiền sản giật sớm. Được ACOG, NICE, FIGO, USPSTF đồng khuyến cáo.",
                    },
                },
                {
                    "@type": "Question",
                    name: "ACOG và NICE khác nhau thế nào trong sàng lọc tiền sản giật?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Khác biệt chính: ngưỡng tuổi (ACOG ≥35, NICE ≥40), ngưỡng BMI (ACOG >30, NICE ≥35), đa thai (ACOG xếp cao, NICE trung bình), IVF (ACOG tính, NICE không).",
                    },
                },
            ],
        })}
    ></script>

    <!-- Hero -->
    <section class="pe-hero">
        <div class="container">
            <div class="hero-badge">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    ><path d="M22 11.08V12a10 10 0 11-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                ACOG/USPSTF 2021 · NICE NG133 · Miễn phí 100%
            </div>
            <h1>
                Sàng Lọc Nguy Cơ <span class="text-accent-color"
                    >Tiền Sản Giật</span
                >
            </h1>
            <p class="hero-sub">
                Phân loại nguy cơ theo 2 guideline quốc tế. Tạo prompt AI để tư
                vấn chi tiết. Toàn bộ logic chạy trên trình duyệt — không lưu dữ
                liệu, không cần internet.
            </p>
        </div>
    </section>

    <!-- Tool -->
    <section class="pe-section">
        <div class="container">
            <div class="pe-grid">
                <!-- Input Panel -->
                <div class="pe-input-panel card">
                    <h2 class="pe-panel-title">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="var(--primary)"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            ><path
                                d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"
                            ></path><rect
                                x="8"
                                y="2"
                                width="8"
                                height="4"
                                rx="1"
                                ry="1"></rect>
                        </svg>
                        Nhập thông tin bệnh nhân
                    </h2>

                    <!-- Basic Info -->
                    <fieldset class="pe-fieldset">
                        <legend class="pe-legend">Thông tin cơ bản</legend>
                        <div class="form-group">
                            <label for="pe-name" class="form-label"
                                >Họ tên</label
                            >
                            <input
                                type="text"
                                id="pe-name"
                                class="form-input"
                                placeholder="Nguyễn Thị..."
                            />
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="pe-age" class="form-label"
                                    >Tuổi mẹ</label
                                >
                                <input
                                    type="number"
                                    id="pe-age"
                                    class="form-input"
                                    min="14"
                                    max="55"
                                    placeholder="VD: 30"
                                />
                            </div>
                            <div class="form-group">
                                <label for="pe-ga-weeks" class="form-label"
                                    >Tuổi thai (tuần)</label
                                >
                                <input
                                    type="number"
                                    id="pe-ga-weeks"
                                    class="form-input"
                                    min="0"
                                    max="42"
                                    placeholder="VD: 13"
                                />
                            </div>
                            <div class="form-group">
                                <label for="pe-ga-days" class="form-label"
                                    >Ngày</label
                                >
                                <input
                                    type="number"
                                    id="pe-ga-days"
                                    class="form-input"
                                    min="0"
                                    max="6"
                                    placeholder="0-6"
                                />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="pe-height" class="form-label"
                                    >Chiều cao (cm)</label
                                >
                                <input
                                    type="number"
                                    id="pe-height"
                                    class="form-input"
                                    min="100"
                                    max="220"
                                    placeholder="VD: 160"
                                />
                            </div>
                            <div class="form-group">
                                <label for="pe-weight" class="form-label"
                                    >Cân nặng (kg)</label
                                >
                                <input
                                    type="number"
                                    id="pe-weight"
                                    class="form-input"
                                    min="30"
                                    max="200"
                                    placeholder="VD: 55"
                                />
                            </div>
                            <div class="form-group">
                                <label class="form-label">BMI</label>
                                <div class="bmi-display" id="pe-bmi-display">
                                    —
                                </div>
                            </div>
                        </div>
                    </fieldset>

                    <!-- Group A: High Risk -->
                    <fieldset class="pe-fieldset pe-fieldset-high">
                        <legend class="pe-legend">
                            Nhóm A — Nguy cơ CAO
                            <span
                                class="pe-count-badge pe-count-high"
                                id="count-high">0</span
                            >
                        </legend>
                        <p class="pe-rule-text">
                            Chỉ cần ≥1 yếu tố → khuyến cáo aspirin
                        </p>

                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-preeclampsia"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label"
                                >Tiền sử tiền sản giật / sản giật</span
                            >
                        </label>
                        <div
                            class="pe-sub-check"
                            id="sub-pe-adverse"
                            style="display:none;"
                        >
                            <label class="pe-checkbox-card pe-checkbox-sub">
                                <input type="checkbox" id="hr-pe-adverse" />
                                <span class="pe-checkbox-label"
                                    >Kèm kết cục bất lợi</span
                                >
                            </label>
                        </div>

                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-multifetal"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label">Đa thai</span>
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-hypertension"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label"
                                >Tăng huyết áp mạn</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-diabetes"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label"
                                >Đái tháo đường type 1 hoặc 2</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-kidney"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label">Bệnh thận mạn</span>
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="hr-autoimmune"
                                data-group="high"
                            />
                            <span class="pe-checkbox-label">Bệnh tự miễn</span>
                        </label>
                        <div
                            class="pe-sub-check"
                            id="sub-autoimmune"
                            style="display:none;"
                        >
                            <select id="hr-autoimmune-type" class="form-input">
                                <option value="">Chọn loại...</option>
                                <option value="SLE">SLE</option>
                                <option value="APS">APS</option>
                                <option value="both">Cả hai</option>
                            </select>
                        </div>
                    </fieldset>

                    <!-- Group B: Moderate Risk -->
                    <fieldset class="pe-fieldset pe-fieldset-mod">
                        <legend class="pe-legend">
                            Nhóm B — Nguy cơ TRUNG BÌNH
                            <span
                                class="pe-count-badge pe-count-mod"
                                id="count-mod">0</span
                            >
                        </legend>
                        <p class="pe-rule-text">
                            Cần ≥2 yếu tố → khuyến cáo aspirin
                        </p>

                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-nulliparity"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label"
                                >Con so (mang thai lần đầu)</span
                            >
                        </label>
                        <label
                            class="pe-checkbox-card pe-auto-check"
                            id="card-age35"
                        >
                            <input
                                type="checkbox"
                                id="mr-age35"
                                data-group="mod"
                                data-auto="true"
                            />
                            <span class="pe-checkbox-label">Tuổi ≥ 35</span>
                            <span
                                class="pe-auto-tag"
                                id="tag-age35"
                                style="display:none;">Tự tính</span
                            >
                        </label>
                        <label
                            class="pe-checkbox-card pe-auto-check"
                            id="card-bmi30"
                        >
                            <input
                                type="checkbox"
                                id="mr-bmi30"
                                data-group="mod"
                                data-auto="true"
                            />
                            <span class="pe-checkbox-label">BMI &gt; 30</span>
                            <span
                                class="pe-auto-tag"
                                id="tag-bmi30"
                                style="display:none;">Tự tính</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-family"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label"
                                >Gia đình có tiền sản giật (mẹ / chị em gái)</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-interpregnancy"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label"
                                >Khoảng cách thai kỳ trước &gt; 10 năm</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-ivf"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label">Thụ thai IVF</span>
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-adverse"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label"
                                >Tiền sử kết cục bất lợi (con nhẹ cân/SGA/thai
                                lưu)</span
                            >
                        </label>
                        <label class="pe-checkbox-card">
                            <input
                                type="checkbox"
                                id="mr-income"
                                data-group="mod"
                            />
                            <span class="pe-checkbox-label">Thu nhập thấp</span>
                        </label>
                    </fieldset>

                    <!-- Submit -->
                    <button
                        type="button"
                        class="btn btn-accent btn-lg pe-submit"
                        id="pe-submit"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            aria-hidden="true"
                            ><circle cx="11" cy="11" r="8"></circle><line
                                x1="21"
                                y1="21"
                                x2="16.65"
                                y2="16.65"></line>
                        </svg>
                        Sàng Lọc
                    </button>
                </div>

                <!-- Results Panel -->
                <div
                    class="pe-results-panel"
                    id="pe-results"
                    style="display:none;"
                >
                    <!-- Risk Badges -->
                    <div class="card pe-result-main">
                        <h3 class="pe-result-title">Kết quả phân loại</h3>
                        <div class="pe-badges-row">
                            <div class="pe-badge-block">
                                <span class="pe-badge-label"
                                    >ACOG/USPSTF 2021</span
                                >
                                <span class="pe-risk-badge" id="badge-acog"
                                    >—</span
                                >
                            </div>
                            <div class="pe-badge-block">
                                <span class="pe-badge-label">NICE NG133</span>
                                <span class="pe-risk-badge" id="badge-nice"
                                    >—</span
                                >
                            </div>
                        </div>
                        <div
                            class="pe-concordance"
                            id="pe-concordance"
                            style="display:none;"
                        >
                        </div>
                    </div>

                    <!-- Aspirin Box -->
                    <div
                        class="card pe-aspirin-box"
                        id="pe-aspirin-box"
                        style="display:none;"
                    >
                        <h3 class="pe-aspirin-title">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><circle cx="12" cy="12" r="10"></circle><line
                                    x1="12"
                                    y1="8"
                                    x2="12"
                                    y2="12"></line><line
                                    x1="12"
                                    y1="16"
                                    x2="12.01"
                                    y2="16"></line>
                            </svg>
                            Khuyến cáo Aspirin
                        </h3>
                        <div id="pe-aspirin-content"></div>
                    </div>

                    <!-- Factors Found -->
                    <div class="card">
                        <h3 class="pe-section-title">Yếu tố phát hiện</h3>
                        <div id="pe-factors-content"></div>
                    </div>

                    <!-- Collapsibles -->
                    <details class="pe-details card">
                        <summary class="pe-summary">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><rect
                                    x="3"
                                    y="4"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="16"
                                    y1="2"
                                    x2="16"
                                    y2="6"></line><line
                                    x1="8"
                                    y1="2"
                                    x2="8"
                                    y2="6"></line><line
                                    x1="3"
                                    y1="10"
                                    x2="21"
                                    y2="10"></line>
                            </svg>
                            Lịch theo dõi đề xuất
                        </summary>
                        <ul class="pe-list" id="pe-followup-list"></ul>
                    </details>

                    <details class="pe-details card">
                        <summary class="pe-summary">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path
                                    d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
                                ></path><line x1="12" y1="9" x2="12" y2="13"
                                ></line><line x1="12" y1="17" x2="12.01" y2="17"
                                ></line>
                            </svg>
                            Triệu chứng cảnh báo
                        </summary>
                        <ul
                            class="pe-list pe-warning-list"
                            id="pe-warning-list"
                        >
                        </ul>
                    </details>

                    <details class="pe-details card">
                        <summary class="pe-summary">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><path d="M4 19.5A2.5 2.5 0 016.5 17H20"
                                ></path><path
                                    d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"
                                ></path>
                            </svg>
                            Trích dẫn y khoa
                        </summary>
                        <div class="pe-citations" id="pe-citations">
                            <p>
                                1. Rolnik DL et al. <em>NEJM</em> 2017;377:613-622
                                (ASPRE trial)
                            </p>
                            <p>
                                2. ACOG/SMFM Practice Advisory 12/2021
                                (reaffirmed 10/2022)
                            </p>
                            <p>3. USPSTF <em>JAMA</em> 2021;326:1186-1191</p>
                            <p>4. NICE NG133, 06/2019 (amended 2023)</p>
                            <p>
                                5. FIGO — Poon LC et al. <em
                                    >Int J Gynaecol Obstet</em
                                > 2019;145(S1):1-33
                            </p>
                            <p>6. WHO Pre-eclampsia Fact Sheet 12/2025</p>
                            <p>7. FMF PE Risk Calculator (63.827 thai phụ)</p>
                        </div>
                    </details>

                    <!-- Copy Prompt CTA -->
                    <div class="pe-copy-section">
                        <button
                            type="button"
                            class="btn pe-copy-btn"
                            id="pe-copy-btn"
                        >
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                                ><rect
                                    x="9"
                                    y="9"
                                    width="13"
                                    height="13"
                                    rx="2"
                                    ry="2"></rect><path
                                    d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                                ></path>
                            </svg>
                            <span id="pe-copy-text"
                                >Sao Chép Prompt Để Hỏi AI</span
                            >
                        </button>
                        <p class="pe-copy-hint">
                            Paste vào ChatGPT / Claude / Gemini để nhận giải
                            thích chi tiết + tư vấn
                        </p>
                    </div>

                    <!-- Print -->
                    <button
                        type="button"
                        class="btn btn-outline pe-print-btn"
                        id="pe-print-btn"
                    >
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            aria-hidden="true"
                            ><polyline points="6 9 6 2 18 2 18 9"
                            ></polyline><path
                                d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"
                            ></path><rect x="6" y="14" width="12" height="8"
                            ></rect>
                        </svg>
                        In kết quả
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section cta-section" id="cta">
        <div class="container">
            <div class="cta-inner">
                <h2>Cần tư vấn chuyên sâu?</h2>
                <p>
                    Bác sĩ chuyên khoa sản tại An Sinh sẵn sàng đồng hành cùng
                    bạn trong thai kỳ.
                </p>
                <div class="cta-actions">
                    <a
                        href="https://phusanansinh.com/dat-lich-hen-kham.html"
                        class="btn btn-accent btn-lg"
                        id="cta-booking">Đặt Lịch Khám Ngay</a
                    >
                    <a
                        href="tel:0899268299"
                        class="btn btn-outline btn-lg"
                        id="cta-call">Gọi: 0899 268 299</a
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- Disclaimer -->
    <section class="disclaimer-section">
        <div class="container">
            <p class="disclaimer-text">
                <strong>Lưu ý y khoa:</strong> Công cụ này chỉ mang tính hỗ trợ lâm
                sàng, KHÔNG thay thế đánh giá của bác sĩ chuyên khoa. Dựa trên: ACOG/USPSTF
                Practice Advisory 12/2021 (Reaffirmed 10/2022) · NICE NG133 06/2019
                (Amended 2023) · FIGO 2019. Không lưu dữ liệu. Không gọi API.
            </p>
        </div>
    </section>

    <style>
        /* ── Hero ── */
        .pe-hero {
            background: linear-gradient(
                135deg,
                var(--primary-light) 0%,
                var(--bg) 100%
            );
            padding: var(--space-4xl) 0 var(--space-3xl);
            text-align: center;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: var(--space-xs);
            padding: var(--space-xs) var(--space-lg);
            background: var(--surface);
            border-radius: var(--radius-full);
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: var(--space-lg);
            border: 1px solid var(--border-light);
        }
        .hero-sub {
            font-size: 1.0625rem;
            color: var(--text-secondary);
            line-height: 1.8;
            max-width: 640px;
            margin: 0 auto;
        }

        /* ── Layout ── */
        .pe-section {
            padding: var(--space-3xl) 0;
        }
        .pe-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: var(--space-2xl);
            max-width: 680px;
            margin: 0 auto;
        }
        .pe-input-panel {
            position: static;
        }
        .pe-panel-title {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            font-size: 1.125rem;
            margin-bottom: var(--space-lg);
        }

        /* ── Fieldsets ── */
        .pe-fieldset {
