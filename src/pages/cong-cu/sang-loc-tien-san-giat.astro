            margin: 0 auto var(--space-xl);
        }
        .cta-actions {
            display: flex;
            gap: var(--space-md);
            justify-content: center;
            flex-wrap: wrap;
        }

        /* ── Disclaimer ── */
        .disclaimer-section {
            padding: var(--space-xl) 0;
            border-top: 1px solid var(--border-light);
        }
        .disclaimer-text {
            font-size: 0.8125rem;
            color: var(--text-muted);
            text-align: center;
