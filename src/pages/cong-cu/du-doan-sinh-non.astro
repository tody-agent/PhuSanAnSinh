    <script>
        import {
            calcFmfRisk,
            stratifyRisk,
            estimateQuippRisk,
            buildPrompt,
            validatePretermInputs,
        } from "../../utils/preterm-birth-calc.js";

        // ── DOM refs ──
        const form = document.getElementById("preterm-form");
        const resultsPanel = document.getElementById("results-panel");
        const errorEl = document.getElementById("validation-error");
        const obsHistorySelect = document.getElementById("obs-history");
        const earliestPtbGroup = document.getElementById("earliest-ptb-group");

        // Show/hide earliest PTB week based on obstetric history
        obsHistorySelect.addEventListener("change", () => {
            const val = obsHistorySelect.value;
            const showPtb = val !== "nullipara" && val !== "all_term";
            earliestPtbGroup.hidden = !showPtb;
        });

        // ── Form Submit ──
        form.addEventListener("submit", (e) => {
            e.preventDefault();
            hideError();

            // Collect form data
            const formData = collectFormData();

            // Validate
            const validation = validatePretermInputs(formData);
            if (!validation.valid) return showError(validation.error);

            // Calculate risks
            const riskResults = calculateRisks(formData);

            // Display results
            displayResults(formData, riskResults);

            // Generate & display prompt
            const prompt = buildPrompt(formData, riskResults);
            document.getElementById("prompt-output").textContent = prompt;

            // Show results panel
            resultsPanel.hidden = false;
            resultsPanel.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        function collectFormData() {
            const gaWeeks = parseInt(
                document.getElementById("ga-weeks").value,
                10
            );
            const gaDays = parseInt(
                document.getElementById("ga-days").value || "0",
                10
            );
            const maternalAge =
                parseFloat(document.getElementById("maternal-age").value) ||
                null;
            const bmi =
                parseFloat(document.getElementById("bmi").value) || null;
            const ethnicity = document.getElementById("ethnicity").value;
            const smoker =
                document.querySelector('input[name="smoker"]:checked')
                    ?.value === "yes";
            const fetusCount = parseInt(
                document.querySelector('input[name="fetusCount"]:checked')
                    ?.value || "1",
                10
            );
            const assessmentType = document.querySelector(
                'input[name="assessmentType"]:checked'
            )?.value;

            const obstetricHistory = obsHistorySelect.value;
            const earliestPtbWeek =
                parseInt(document.getElementById("earliest-ptb").value, 10) ||
                null;
            const previousPtb =
                obstetricHistory !== "nullipara" &&
                obstetricHistory !== "all_term";
            const previousPprom =
                document.getElementById("previous-pprom").checked;
            const lateMiscarriage =
                document.getElementById("late-miscarriage").checked;
            const cervicalSurgery =
                document.getElementById("cervical-surgery").checked;
            const cerclage = document.getElementById("cerclage").checked;
            const progesterone =
                document.getElementById("progesterone").checked;

            const clVal = document.getElementById("cervical-length").value;
            const ffnVal = document.getElementById("ffn").value;
            const cervicalLength = clVal !== "" ? parseFloat(clVal) : null;
            const ffn = ffnVal !== "" ? parseFloat(ffnVal) : null;

            let availableTests = "none";
            if (cervicalLength !== null && ffn !== null)
                availableTests = "cl_ffn";
            else if (cervicalLength !== null) availableTests = "cl_only";
            else if (ffn !== null) availableTests = "ffn_only";

            return {
                assessmentType,
                gaWeeks,
                gaDays,
                maternalAge,
                ethnicity,
                bmi,
                smoker,
                fetusCount,
                obstetricHistory,
                previousPtb,
                earliestPtbWeek,
                previousPprom,
                lateMiscarriage,
                cervicalSurgery,
                cerclage,
                progesterone,
                cervicalLength,
                ffn,
                availableTests,
            };
        }

        function calculateRisks(fd) {
            // QUiPP-style
            const hasRiskFactor =
                fd.previousPtb ||
                fd.previousPprom ||
                fd.lateMiscarriage ||
                fd.cervicalSurgery ||
                fd.fetusCount > 1;
            const hasPreviousPtb32 =
                fd.previousPtb &&
                fd.earliestPtbWeek != null &&
                fd.earliestPtbWeek < 33;

            const quipp = estimateQuippRisk({
                gaWeeks: fd.gaWeeks,
                gaDays: fd.gaDays,
                cl: fd.cervicalLength,
                ffn: fd.ffn,
                hasRiskFactor,
                symptomatic: fd.assessmentType === "symptomatic",
            });

            // Risk stratification
            const stratification = stratifyRisk({
                cl: fd.cervicalLength,
                ffn: fd.ffn,
                hasRiskFactor,
                hasPreviousPtb32,
            });

            // FMF model (needs CL + maternal data)
            let fmf = null;
            if (fd.cervicalLength !== null && fd.maternalAge && fd.bmi) {
                fmf = calcFmfRisk({
                    maternalAge: fd.maternalAge,
                    ethnicity: fd.ethnicity,
                    bmi: fd.bmi,
                    smoker: fd.smoker,
                    obstetricHistory: fd.obstetricHistory,
                    cervicalSurgery: fd.cervicalSurgery,
                    cervicalLength: fd.cervicalLength,
                });
            }

            return { quipp, stratification, fmf };
        }

        function displayResults(fd, riskResults) {
            const { quipp, stratification, fmf } = riskResults;

            // Risk header
            const header = document.getElementById("risk-header");
            header.className = `result-card result-primary card risk-${stratification.color}`;
            document.getElementById("risk-emoji").textContent =
                stratification.level === "VERY_LOW"
                    ? "✅"
                    : stratification.level === "LOW"
                    ? "🟡"
                    : stratification.level === "MODERATE"
                    ? "🟠"
                    : stratification.level === "HIGH"
                    ? "🔴"
                    : "🚨";
            document.getElementById("risk-level").textContent =
                stratification.label;
            document.getElementById("risk-reason").textContent =
                stratification.reason;

            // QUiPP bars
            const barsHtml = [
                { label: "Sinh trong 7 ngày", value: quipp.risk7d },
                { label: "Sinh trong 14 ngày", value: quipp.risk14d },
                { label: "Sinh trong 28 ngày", value: quipp.risk28d },
            ]
                .map((b) => {
                    const barClass =
                        b.value < 5
                            ? "bar-low"
                            : b.value < 10
                            ? "bar-med"
                            : "bar-high";
                    return `<div class="risk-bar-item">
                    <div class="risk-bar-header"><span>${
                        b.label
                    }</span><span class="risk-bar-value">${
                        b.value
                    }%</span></div>
                    <div class="risk-bar-track"><div class="risk-bar-fill ${barClass}" style="width:${Math.min(
                        b.value,
                        100
                    )}%"></div></div>
                </div>`;
                })
                .join("");
            document.getElementById("quipp-bars").innerHTML = barsHtml;

            // Action level
            document.getElementById(
                "quipp-action"
            ).textContent = `Mức hành động: ${quipp.actionLevel} (ngưỡng ≥5% sinh trong 7 ngày — EQUIPTT trial)`;

            // Highlight threshold row
            const rows = document.querySelectorAll("#threshold-table tbody tr");
            rows.forEach((r) => r.classList.remove("active-row"));
            let rowIdx =
                quipp.risk7d < 1
                    ? 0
                    : quipp.risk7d < 5
                    ? 1
                    : quipp.risk7d < 10
                    ? 2
                    : quipp.risk7d < 25
                    ? 3
                    : 4;
            rows[rowIdx]?.classList.add("active-row");

            // FMF card
            const fmfCard = document.getElementById("fmf-card");
            if (fmf) {
                document.getElementById("fmf-results").innerHTML = `
                    <div class="fmf-stat"><div class="fmf-stat-label">&lt; 32 tuần</div><div class="fmf-stat-value">${(
                        fmf.riskBelow32 * 100
                    ).toFixed(1)}%</div></div>
                    <div class="fmf-stat"><div class="fmf-stat-label">&lt; 34 tuần</div><div class="fmf-stat-value">${(
                        fmf.riskBelow34 * 100
                    ).toFixed(1)}%</div></div>
                    <div class="fmf-stat"><div class="fmf-stat-label">&lt; 37 tuần</div><div class="fmf-stat-value">${(
                        fmf.riskBelow37 * 100
                    ).toFixed(1)}%</div></div>
                `;
                fmfCard.hidden = false;
            } else {
                fmfCard.hidden = true;
            }
        }

        // ── Copy Prompt ──
        document
            .getElementById("copy-prompt-btn")
            .addEventListener("click", async () => {
                const text =
                    document.getElementById("prompt-output").textContent;
                try {
                    await navigator.clipboard.writeText(text);
                    const btnText = document.getElementById("copy-btn-text");
                    btnText.textContent = "✅ Đã Copy!";
                    setTimeout(() => {
                        btnText.textContent = "Copy Prompt";
                    }, 2000);
                } catch {
                    // Fallback
                    const ta = document.createElement("textarea");
                    ta.value = text;
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand("copy");
                    document.body.removeChild(ta);
                    const btnText = document.getElementById("copy-btn-text");
                    btnText.textContent = "✅ Đã Copy!";
                    setTimeout(() => {
                        btnText.textContent = "Copy Prompt";
                    }, 2000);
                }
            });

        function showError(msg) {
            errorEl.textContent = msg;
            errorEl.hidden = false;
        }
        function hideError() {
            errorEl.hidden = true;
        }
    </script>
</BaseLayout>
