        }
        .result-period .result-icon {
            background: var(--primary-light);
            color: var(--primary);
        }
        .result-label {
            display: block;
            font-size: 0.8125rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-weight: 500;
        }
        .result-date {
            display: block;
            font-size: 1.25rem;
            color: var(--text-primary);
            margin-top: 2px;
        }

        /* ── Phases Card ── */
        .phases-title,
        .calendar-title,
        .forecast-title {
            font-size: 1.125rem;
            margin-bottom: var(--space-lg);
        }
        .phases-bar {
            display: flex;
            height: 32px;
            border-radius: var(--radius-md);
            overflow: hidden;
            margin-bottom: var(--space-md);
        }
        .phase-segment {
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.6875rem;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            padding: 0 var(--space-xs);
            transition: flex var(--transition-base);
        }
        .phase-menstruation {
            background: #dc2626;
        }
        .phase-follicular {
            background: var(--primary);
        }
        .phase-ovulation {
            background: var(--accent);
        }
        .phase-luteal {
            background: #6b7280;
        }

        .phases-legend {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-md) var(--space-xl);
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: var(--space-sm);
            font-size: 0.8125rem;
            color: var(--text-secondary);
        }
        .legend-dot {
            width: 12px;
            height: 12px;
            border-radius: var(--radius-full);
            flex-shrink: 0;
        }

        /* ── Calendar ── */
        .cal-month {
            margin-bottom: var(--space-xl);
        }
        .cal-month:last-child {
            margin-bottom: 0;
        }
        .cal-month-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: var(--space-sm);
        }
        .cal-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 2px;
        }
        .cal-header {
            text-align: center;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            padding: var(--space-xs);
            text-transform: uppercase;
        }
        .cal-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8125rem;
            border-radius: var(--radius-sm);
            position: relative;
            min-height: 36px;
        }
        .cal-day.empty {
            background: transparent;
        }
        .cal-day.day-menstruation {
            background: #fecaca;
            color: #991b1b;
            font-weight: 600;
        }
        .cal-day.day-follicular {
            background: var(--primary-light);
            color: var(--primary-dark);
        }
        .cal-day.day-ovulation {
            background: #fed7aa;
            color: #9a3412;
            font-weight: 700;
        }
        .cal-day.day-ovulation-peak {
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            border-radius: 50%;
            box-shadow: 0 0 0 3px rgba(240, 125, 0, 0.25);
        }
        .cal-day.day-luteal {
            background: #f3f4f6;
            color: #4b5563;
        }
        .cal-day.day-normal {
            background: transparent;
            color: var(--text-secondary);
        }
        .cal-day.today {
            outline: 2px solid var(--primary);
            outline-offset: -2px;
        }

        /* ── Forecast Table ── */
        .forecast-table-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        .forecast-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }
        .forecast-table th {
            text-align: left;
            padding: var(--space-sm) var(--space-md);
            border-bottom: 2px solid var(--border);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.8125rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            white-space: nowrap;
        }
        .forecast-table td {
            padding: var(--space-sm) var(--space-md);
            border-bottom: 1px solid var(--border-light);
            white-space: nowrap;
        }
        .forecast-table tbody tr:hover {
            background: var(--surface-alt);
        }
        .td-ovulation {
            color: var(--accent);
            font-weight: 600;
        }
        .td-fertile {
            color: #e11d48;
            font-weight: 500;
        }

        /* ── FAQ ── */
        .faq-list {
            max-width: 800px;
            margin: 0 auto;
        }
        .faq-item {
            border-bottom: 1px solid var(--border-light);
        }
        .faq-question {
            padding: var(--space-lg) 0;
            cursor: pointer;
            font-weight: 600;
            font-size: 1.0625rem;
            color: var(--text-primary);
            list-style: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            min-height: 44px;
        }
        .faq-question::-webkit-details-marker {
            display: none;
        }
        .faq-question::after {
            content: "+";
            font-size: 1.5rem;
            color: var(--primary);
            font-weight: 400;
            flex-shrink: 0;
            margin-left: var(--space-md);
            transition: transform var(--transition-fast);
        }
        details[open] .faq-question::after {
            content: "−";
        }
        .faq-answer {
            padding: 0 0 var(--space-lg);
        }
        .faq-answer p {
            font-size: 0.9375rem;
            line-height: 1.8;
        }

        /* ── CTA Section ── */
        .cta-section {
            background: linear-gradient(
                135deg,
                var(--primary) 0%,
                var(--primary-dark) 100%
            );
            color: #fff;
            text-align: center;
        }
        .cta-content {
            max-width: 600px;
            margin: 0 auto;
        }
        .cta-content h2 {
            color: #fff;
            margin-bottom: var(--space-md);
        }
        .cta-content p {
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: var(--space-xl);
        }
        .cta-actions {
            display: flex;
            gap: var(--space-md);
            justify-content: center;
            flex-wrap: wrap;
        }
        .cta-section .btn-outline {
            color: #fff;
            border-color: rgba(255, 255, 255, 0.5);
        }
        .cta-section .btn-outline:hover {
            background: rgba(255, 255, 255, 0.15);
            color: #fff;
            border-color: #fff;
        }

        /* ── Disclaimer ── */
        .disclaimer-section {
            padding: var(--space-xl) 0;
            background: var(--surface-alt);
        }
        .disclaimer-text {
            font-size: 0.8125rem;
            color: var(--text-muted);
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
            line-height: 1.7;
        }

        /* ── Animations ── */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .calc-results-panel:not([hidden]) {
            animation: fadeInUp 0.4s ease-out;
        }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .calc-layout {
                grid-template-columns: 1fr;
            }
            .calc-card {
                position: static;
            }
            .results-cards {
                grid-template-columns: 1fr;
            }
            .cta-actions {
                flex-direction: column;
                align-items: stretch;
            }
            .tool-hero {
                padding: var(--space-3xl) 0 var(--space-xl);
            }
        }
    </style>

    <script type="module">
        import {
            calculateOvulationDay,
            calculateFertileWindow,
            calculateNextPeriod,
            calculateFullCycle,
            generateCyclePhases,
            validateCycleInput,
            predictMultipleCycles,
        } from "../utils/ovulation-calc.js";
        import { formatDateVN, toLocalDate } from "../utils/due-date-calc.js";

        // DOM refs
        const form = document.getElementById("ovulation-form");
        const lmpInput = document.getElementById("lmp-date");
        const cycleSlider = document.getElementById("cycle-length");
        const cycleValue = document.getElementById("cycle-value");
        const resultsPanel = document.getElementById("results-panel");
        const formError = document.getElementById("form-error");

        // Set max date to today
        const today = new Date();
        lmpInput.max = today.toISOString().split("T")[0];
        // Set default to ~14 days ago
        const defaultLmp = new Date(today);
        defaultLmp.setDate(defaultLmp.getDate() - 14);
        lmpInput.value = defaultLmp.toISOString().split("T")[0];

        // Cycle slider live update
        cycleSlider.addEventListener("input", () => {
            cycleValue.textContent = cycleSlider.value;
        });

        // Form submit
        form.addEventListener("submit", (e) => {
            e.preventDefault();
            formError.hidden = true;

            const lmpDate = lmpInput.value;
            const cycleLength = parseInt(cycleSlider.value, 10);
            const validation = validateCycleInput(lmpDate, cycleLength);

            if (!validation.valid) {
                formError.textContent = validation.error;
                formError.hidden = false;
                resultsPanel.hidden = true;
                return;
            }

            showResults(lmpDate, cycleLength);
        });

        function showResults(lmpDate, cycleLength) {
            const cycle = calculateFullCycle(lmpDate, cycleLength);
            const phases = generateCyclePhases(lmpDate, cycleLength);
            const forecasts = predictMultipleCycles(lmpDate, cycleLength, 6);

            // Key dates
            document.getElementById("result-ovulation").textContent =
                formatDateVN(cycle.ovulationDay);
            document.getElementById("result-fertile").textContent =
                formatDateVN(cycle.fertileWindow.start) +
                " → " +
                formatDateVN(cycle.fertileWindow.end);
            document.getElementById("result-next-period").textContent =
                formatDateVN(cycle.nextPeriod);

            // Phases bar
            renderPhasesBar(phases, cycleLength);

            // Calendar
            renderCalendar(cycle, phases);

            // Forecast table
            renderForecast(forecasts);

            resultsPanel.hidden = false;
            resultsPanel.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        function renderPhasesBar(phases, cycleLength) {
            const bar = document.getElementById("phases-bar");
            const legend = document.getElementById("phases-legend");

            const colors = {
                menstruation: {
                    bg: "phase-menstruation",
                    label: "Hành kinh",
                    color: "#DC2626",
                },
                follicular: {
                    bg: "phase-follicular",
                    label: "Nang trứng",
                    color: "#1B7A6D",
                },
                ovulation: {
                    bg: "phase-ovulation",
                    label: "Rụng trứng",
                    color: "#F07D00",
                },
                luteal: {
                    bg: "phase-luteal",
                    label: "Hoàng thể",
                    color: "#6B7280",
                },
            };

            bar.innerHTML = phases
                .map((p) => {
                    const days =
                        Math.round((p.end - p.start) / (1000 * 60 * 60 * 24)) +
                        1;
                    const pct = (days / cycleLength) * 100;
                    return `<div class="phase-segment ${
                        colors[p.name].bg
                    }" style="flex:${pct}" title="${
                        p.label
                    }: ${days} ngày">${days}d</div>`;
                })
                .join("");

            legend.innerHTML = phases
                .map((p) => {
                    const days =
                        Math.round((p.end - p.start) / (1000 * 60 * 60 * 24)) +
                        1;
                    return `<div class="legend-item">
          <span class="legend-dot" style="background:${
              colors[p.name].color
          }"></span>
          ${colors[p.name].label} (${days} ngày)
        </div>`;
                })
                .join("");
        }

        function renderCalendar(cycle, phases) {
            const container = document.getElementById("calendar-container");
            const today = toLocalDate(new Date());

            // Determine months to show (current cycle month + next month)
            const startMonth = new Date(
                cycle.lmpDate.getFullYear(),
                cycle.lmpDate.getMonth(),
                1
            );
            const endDate = cycle.nextPeriod;
            const months = [];
            let m = new Date(startMonth);
            while (m <= endDate || months.length < 2) {
                months.push(new Date(m));
                m.setMonth(m.getMonth() + 1);
                if (months.length > 3) break;
            }

            const dayNames = ["CN", "T2", "T3", "T4", "T5", "T6", "T7"];
            const monthNames = [
                "Tháng 1",
                "Tháng 2",
                "Tháng 3",
                "Tháng 4",
                "Tháng 5",
                "Tháng 6",
                "Tháng 7",
                "Tháng 8",
                "Tháng 9",
                "Tháng 10",
                "Tháng 11",
                "Tháng 12",
            ];

            container.innerHTML = months
                .map((month) => {
                    const year = month.getFullYear();
                    const mon = month.getMonth();
                    const firstDay = new Date(year, mon, 1).getDay();
                    const daysInMonth = new Date(year, mon + 1, 0).getDate();

                    let cells = dayNames
                        .map((d) => `<div class="cal-header">${d}</div>`)
                        .join("");

                    // Empty cells before first day
                    for (let i = 0; i < firstDay; i++) {
                        cells += '<div class="cal-day empty"></div>';
                    }

                    for (let d = 1; d <= daysInMonth; d++) {
                        const date = new Date(year, mon, d);
                        const cls = getDayClass(date, cycle, phases, today);
                        cells += `<div class="cal-day ${cls}" title="${getDayTitle(
                            cls
                        )}">${d}</div>`;
                    }

                    return `<div class="cal-month">
          <div class="cal-month-title">${monthNames[mon]} ${year}</div>
          <div class="cal-grid">${cells}</div>
        </div>`;
                })
                .join("");
        }

        function getDayClass(date, cycle, phases, today) {
            const t = date.getTime();
            let cls = "day-normal";

            // Check if date is ovulation peak
            if (sameDay(date, cycle.ovulationDay)) {
                cls = "day-ovulation-peak";
            }
            // Check phases
            else {
                for (const p of phases) {
                    if (t >= p.start.getTime() && t <= p.end.getTime()) {
                        cls = "day-" + p.name;
                        break;
                    }
                }
            }

            if (sameDay(date, today)) cls += " today";
            return cls;
        }

        function getDayTitle(cls) {
            if (cls.includes("ovulation-peak")) return "Ngày rụng trứng";
            if (cls.includes("ovulation"))
                return "Giai đoạn rụng trứng (dễ thụ thai)";
            if (cls.includes("menstruation")) return "Kỳ hành kinh";
            if (cls.includes("follicular")) return "Giai đoạn nang trứng";
            if (cls.includes("luteal")) return "Giai đoạn hoàng thể";
            return "";
        }

        function sameDay(a, b) {
            return (
                a.getFullYear() === b.getFullYear() &&
                a.getMonth() === b.getMonth() &&
                a.getDate() === b.getDate()
            );
        }

        function renderForecast(forecasts) {
            const tbody = document.getElementById("forecast-tbody");
            const monthNames = [
                "Th.1",
                "Th.2",
                "Th.3",
                "Th.4",
                "Th.5",
                "Th.6",
                "Th.7",
                "Th.8",
                "Th.9",
                "Th.10",
                "Th.11",
                "Th.12",
            ];

            tbody.innerHTML = forecasts
                .map((c, i) => {
                    const monthLabel =
                        monthNames[c.lmpDate.getMonth()] +
                        "/" +
                        c.lmpDate.getFullYear();
                    return `<tr>
          <td>${monthLabel}</td>
          <td>${formatDateVN(c.lmpDate)}</td>
          <td class="td-ovulation">${formatDateVN(c.ovulationDay)}</td>
          <td class="td-fertile">${formatDateVN(
              c.fertileWindow.start
          )} → ${formatDateVN(c.fertileWindow.end)}</td>
        </tr>`;
                })
                .join("");
        }
    </script>
</BaseLayout>
