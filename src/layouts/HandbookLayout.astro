---
import BaseLayout from "./BaseLayout.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  author: string;
  readingTime?: number;
  volume?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags,
  author,
  readingTime,
  volume,
} = Astro.props;

const categoryMap: Record<string, string> = {
  "nen-tang": "Nền Tảng Y Khoa",
  "vo-sinh-hiem-muon": "Vô Sinh & Hiếm Muộn",
  "ho-tro-sinh-san": "Hỗ Trợ Sinh Sản",
  "di-truyen": "Di Truyền Học",
  "phu-khoa": "Phụ Khoa",
  "san-khoa": "Sản Khoa",
  "hau-san": "Hậu Sản",
};

const formattedDate = new Intl.DateTimeFormat("vi-VN", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(pubDate);
const formattedUpdate = updatedDate
  ? new Intl.DateTimeFormat("vi-VN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(updatedDate)
  : null;
---

<BaseLayout title={`${title} | Sản Phụ Handbook`} description={description}>
  <article
    class="article-page handbook-page"
    itemscope
    itemtype="https://schema.org/MedicalScholarlyArticle"
  >
    <header class="article-header handbook-header">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Trang chủ</a></li>
            <li><a href="/san-phu-handbook">Sản Phụ Handbook</a></li>
            <li aria-current="page">{title}</li>
          </ol>
        </nav>
        <div class="handbook-badge-row">
          <span class="article-category">{categoryMap[category] || category}</span>
          {volume && <span class="handbook-volume-badge">{volume}</span>}
        </div>
        <h1 itemprop="name">{title}</h1>
        <div class="article-meta">
          <span itemprop="author">{author}</span>
          <time datetime={pubDate.toISOString()} itemprop="datePublished"
            >{formattedDate}</time
          >
          {readingTime && <span>{readingTime} phút đọc</span>}
        </div>
      </div>
    </header>

    <div class="container">
      <div class="article-layout">
        <div class="article-content prose" itemprop="articleBody">
          <slot />
        </div>
        <aside class="article-sidebar">
          <div class="sidebar-cta card">
            <h3>Cần tư vấn?</h3>
            <p>Bác sĩ chuyên khoa sẵn sàng giải đáp thắc mắc của bạn.</p>
            <a
              href="https://phusanansinh.com/dat-lich-hen-kham.html"
              class="btn btn-accent btn-sm"
              id="handbook-sidebar-cta">Hẹn Khám</a
            >
            <a
              href="tel:0899268299"
              class="btn btn-outline btn-sm mt-1"
              id="handbook-sidebar-call">Gọi: 0899 268 299</a
            >
          </div>
          {
            tags.length > 0 && (
              <div class="sidebar-tags">
                <h4>Tags</h4>
                <div class="tag-list">
                  {tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            )
          }
          <div class="sidebar-handbook-nav">
            <h4>Danh mục Handbook</h4>
            <ul role="list">
              {Object.entries(categoryMap).map(([slug, label]) => (
                <li>
                  <a
                    href={`/san-phu-handbook?cat=${slug}`}
                    class={slug === category ? "active" : ""}
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <!-- Article Schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalScholarlyArticle",
      name: title,
      headline: title,
      description: description,
      datePublished: pubDate.toISOString(),
      ...(updatedDate && { dateModified: updatedDate.toISOString() }),
      author: {
        "@type": "Person",
        name: author,
      },
      publisher: {
        "@type": "MedicalClinic",
        name: "Phòng Khám An Sinh",
        url: "https://phusanansinh.com",
      },
      about: {
        "@type": "MedicalSpecialty",
        name: "Obstetrics and Gynecology",
      },
      inLanguage: "vi",
    })}
  ></script>
</BaseLayout>

<style>
  .handbook-page {
    padding-bottom: var(--space-4xl);
    overflow-x: hidden;
  }

  .handbook-header {
    background: linear-gradient(135deg, var(--surface-alt) 0%, #e8f4f8 100%);
    padding: var(--space-3xl) 0;
    border-bottom: 3px solid var(--primary-light);
  }

  .handbook-badge-row {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .handbook-volume-badge {
    display: inline-block;
    background: var(--surface);
    color: var(--text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border);
    letter-spacing: 0.03em;
  }

  .breadcrumb ol {
    display: flex;
    gap: var(--space-sm);
    list-style: none;
    font-size: 0.875rem;
    margin-bottom: var(--space-lg);
  }

  .breadcrumb li + li::before {
    content: "›";
    margin-right: var(--space-sm);
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-secondary);
  }

  .breadcrumb [aria-current] {
    color: var(--text-primary);
    font-weight: 500;
  }

  .article-category {
    display: inline-block;
    background: var(--primary-light);
    color: var(--primary);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .handbook-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: var(--space-md);
    max-width: 800px;
  }

  .article-meta {
    display: flex;
    gap: var(--space-lg);
    font-size: 0.875rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-3xl);
    padding-top: var(--space-3xl);
    align-items: start;
  }

  /* ── Prose ── */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.85;
    overflow-wrap: break-word;
    word-break: break-word;
    max-width: 100%;
    overflow-x: hidden;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--primary-light);
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding: var(--space-md) var(--space-lg);
    background: var(--primary-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: var(--space-xl) 0;
  }

  .prose :global(blockquote p) {
    color: var(--primary-dark);
    font-style: italic;
    margin: 0;
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-xl) 0;
  }

  .prose :global(strong) {
    color: var(--text-primary);
  }

  .prose :global(a) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    font-size: 0.9375rem;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border);
    text-align: left;
    white-space: nowrap;
  }

  .prose :global(th) {
    background: var(--surface-alt);
    font-weight: 600;
    color: var(--text-primary);
  }

  /* ── Sidebar ── */
  .sidebar-cta {
    position: sticky;
    top: 80px;
    text-align: center;
  }

  .sidebar-cta h3 {
    color: var(--primary);
    margin-bottom: var(--space-sm);
  }

  .sidebar-cta p {
    font-size: 0.875rem;
    margin-bottom: var(--space-lg);
  }

  .sidebar-cta .btn {
    width: 100%;
  }

  .sidebar-tags {
    margin-top: var(--space-xl);
  }

  .sidebar-tags h4 {
    font-size: 0.875rem;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    background: var(--surface-alt);
    color: var(--text-secondary);
    font-size: 0.8125rem;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-light);
  }

  .sidebar-handbook-nav {
    margin-top: var(--space-xl);
  }

  .sidebar-handbook-nav h4 {
    font-size: 0.875rem;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .sidebar-handbook-nav ul {
    list-style: none;
    padding: 0;
  }

  .sidebar-handbook-nav li {
    margin-bottom: var(--space-xs);
  }

  .sidebar-handbook-nav a {
    display: block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .sidebar-handbook-nav a:hover,
  .sidebar-handbook-nav a.active {
    background: var(--primary-light);
    color: var(--primary);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .handbook-header {
      padding: var(--space-xl) 0;
    }

    .handbook-badge-row {
      margin-bottom: var(--space-sm);
    }

    .article-category {
      font-size: 0.6875rem;
      padding: 0.2rem 0.5rem;
    }

    .handbook-volume-badge {
      font-size: 0.6875rem;
      padding: 0.2rem 0.5rem;
    }

    .handbook-header h1 {
      font-size: clamp(1.125rem, 5vw, 1.5rem);
      margin-bottom: var(--space-sm);
      line-height: 1.3;
    }

    .breadcrumb ol {
      font-size: 0.75rem;
      margin-bottom: var(--space-sm);
      flex-wrap: wrap;
    }

    .article-meta {
      font-size: 0.8125rem;
      gap: var(--space-md);
    }

    .article-layout {
      grid-template-columns: 1fr;
      padding-top: var(--space-xl);
      gap: var(--space-xl);
    }

    .sidebar-cta {
      position: static;
    }

    /* Mobile prose typography — optimized for content density */
    .prose {
      font-size: 0.9375rem;
      line-height: 1.7;
    }

    .prose :global(h2) {
      font-size: 1.125rem;
      margin-top: var(--space-2xl);
      margin-bottom: var(--space-md);
      padding-bottom: 0.375rem;
    }

    .prose :global(h3) {
      font-size: 1rem;
      margin-top: var(--space-xl);
      margin-bottom: var(--space-sm);
    }

    .prose :global(p) {
      margin-bottom: var(--space-md);
    }

    .prose :global(ul),
    .prose :global(ol) {
      margin-bottom: var(--space-md);
      padding-left: var(--space-lg);
    }

    .prose :global(li) {
      margin-bottom: 0.125rem;
    }

    .prose :global(blockquote) {
      padding: var(--space-sm) var(--space-md);
      margin: var(--space-lg) 0;
    }

    .prose :global(img) {
      margin: var(--space-lg) 0;
    }

    .prose :global(table) {
      font-size: 0.8125rem;
    }

    .prose :global(th),
    .prose :global(td) {
      padding: 0.375rem 0.5rem;
    }
  }
</style>
