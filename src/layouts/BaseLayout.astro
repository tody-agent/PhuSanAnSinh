        gap: var(--space-sm);
        padding: 0.625rem 0.75rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--text-primary);
        transition: all var(--transition-fast);
      }

      .dropdown-item:hover {
        background: var(--primary-light);
        color: var(--primary-dark);
      }

      .dropdown-item strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
      }

      .dropdown-desc {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 1px;
      }

      .dropdown-item:hover .dropdown-desc {
        color: var(--primary);
      }

      .dropdown-icon {
        font-size: 1.25rem;
        width: 2rem;
        text-align: center;
        flex-shrink: 0;
      }

      /* ── Mega Dropdown (Công cụ) ── */
      .nav-dropdown-mega {
        min-width: 480px;
        padding: 0;
      }

      .dropdown-mega-inner {
        display: flex;
      }

      .dropdown-tools {
        flex: 1;
        padding: var(--space-md);
      }

      .dropdown-tool-card {
        display: flex;
        align-items: flex-start;
        gap: var(--space-sm);
        padding: 0.75rem;
        border-radius: var(--radius-md);
        text-decoration: none;
        color: var(--text-primary);
        transition: all var(--transition-fast);
      }

      .dropdown-tool-card:hover {
        background: var(--primary-light);
      }

      .tool-icon {
        font-size: 1.5rem;
        width: 2.25rem;
        height: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: var(--surface-alt);
        border-radius: var(--radius-sm);
      }

      .dropdown-tool-card:hover .tool-icon {
        background: #fff;
      }

      .tool-info strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .tool-info span {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 2px;
        line-height: 1.3;
      }

      .dropdown-tool-card:hover .tool-info strong {
        color: var(--primary-dark);
      }

      .dropdown-tool-card:hover .tool-info span {
        color: var(--primary);
      }

      /* ── Dropdown Promo Sidebar ── */
      .dropdown-promo {
        width: 180px;
        background: var(--surface-alt);
        border-left: 1px solid var(--border-light);
        padding: var(--space-md);
        border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      .promo-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .promo-link {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--primary);
        text-decoration: none;
        padding: 0.375rem 0;
        transition: color var(--transition-fast);
      }

      .promo-link:hover {
        color: var(--accent);
      }

      /* ── Header Actions ── */
      .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      .header-phone {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9375rem;
      }

      .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        min-height: 44px;
        min-width: 44px;
        align-items: center;
        justify-content: center;
      }

      .mobile-toggle span {
        width: 22px;
        height: 2px;
        background: var(--text-primary);
        border-radius: 2px;
        transition: var(--transition-fast);
      }

      /* ── Footer ── */
      .site-footer {
        background: var(--text-primary);
        color: #c9cdd4;
        padding: var(--space-4xl) 0 var(--space-xl);
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr repeat(3, 1fr);
        gap: var(--space-3xl);
      }

      .site-footer h4 {
        color: #fff;
        font-size: 1rem;
        margin-bottom: var(--space-lg);
      }

      .footer-desc {
        color: #9ca3af;
        font-size: 0.875rem;
        margin-top: var(--space-md);
      }

      .footer-col ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      .footer-col a {
        color: #9ca3af;
        font-size: 0.875rem;
        transition: color var(--transition-fast);
      }

      .footer-col a:hover {
        color: #fff;
      }

      .footer-contact li {
        display: flex;
        align-items: flex-start;
        gap: var(--space-sm);
        font-size: 0.875rem;
        color: #9ca3af;
      }

      .footer-contact svg {
        flex-shrink: 0;
        margin-top: 2px;
      }

      .footer-contact a {
        color: #9ca3af;
      }

      .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: var(--space-3xl);
        padding-top: var(--space-xl);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        font-size: 0.8125rem;
        color: #6b7280;
      }

      .footer-social {
        display: flex;
        gap: var(--space-md);
      }

      .footer-social a {
        color: #6b7280;
        transition: color var(--transition-fast);
      }

      .footer-social a:hover {
        color: var(--primary);
      }

      /* ── Sticky CTA Bar ── */
      .sticky-cta {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 99;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-top: 1px solid var(--border-light);
        padding: var(--space-sm) var(--space-md);
        justify-content: space-around;
      }

      .sticky-cta-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        color: var(--text-secondary);
        font-size: 0.6875rem;
        font-weight: 500;
        text-decoration: none;
        min-height: 44px;
        min-width: 44px;
        justify-content: center;
        padding: var(--space-xs);
        transition: color var(--transition-fast);
      }

      .sticky-cta-item:hover {
        color: var(--primary);
      }

      .sticky-cta-primary {
        color: #fff;
        background: var(--accent);
        border-radius: var(--radius-md);
        padding: var(--space-xs) var(--space-lg);
      }

      .sticky-cta-primary:hover {
        background: var(--accent-dark);
        color: #fff;
      }

      /* ── Backdrop Overlay ── */
      .nav-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 199;
        opacity: 0;
        transition: opacity 0.3s ease;
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
      }

      .nav-backdrop.is-visible {
        display: block;
        opacity: 1;
      }

      /* ── Drawer Header (mobile only, hidden desktop) ── */
      .drawer-header {
        display: none;
      }

      .drawer-cta {
        display: none;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        /* FIX FIXED CONTAINING BLOCK BUG ON IOS:
           backdrop-filter creates a containing block which traps the fixed drawer.
           Disable it on mobile so the drawer attaches to the true viewport. */
        .site-header {
          backdrop-filter: none !important;
          -webkit-backdrop-filter: none !important;
          background: #ffffff;
        }

        /* ── Mobile Drawer ── */
        .main-nav {
          position: fixed;
          top: 0;
          bottom: 0; /* Add bottom: 0 to guarantee full height */
          right: -100%;
          width: 85%;
          max-width: 360px;
          height: 100dvh;
          background: #fff;
          z-index: 200;
          overflow-x: hidden;
          overflow-y: auto;
          overscroll-behavior: none; /* Prevent scroll chaining */
          -webkit-overflow-scrolling: touch;
          box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
          transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          display: flex;
          flex-direction: column;
        }

        .main-nav.is-open {
          right: 0;
        }

        /* ── Drawer Header ── */
        .drawer-header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: var(--space-md) var(--space-lg);
          border-bottom: 1px solid var(--border-light);
          flex-shrink: 0;
        }

        .drawer-header .logo {
          display: flex;
          align-items: center;
          gap: var(--space-sm);
          text-decoration: none;
        }

        .drawer-header .logo-brand {
          font-size: 1rem;
          font-weight: 800;
          color: var(--primary);
        }

        .drawer-close {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 40px;
          height: 40px;
          border: none;
          background: var(--surface-alt);
          border-radius: var(--radius-full);
          color: var(--text-secondary);
          cursor: pointer;
          transition: all var(--transition-fast);
        }

        .drawer-close:hover {
          background: var(--primary-light);
          color: var(--primary);
        }

        /* ── Nav List ── */
        .nav-list {
          flex-direction: column;
          align-items: stretch; /* FIX: Prevent centering inherited from desktop */
          gap: 0;
          padding: var(--space-md) 0;
          flex: 1;
          overflow-y: auto;
        }

        .nav-item-icon {
          display: block; /* Show icons in mobile drawer */
          color: var(--primary);
          margin-right: var(--space-sm);
        }

        .nav-list > li > a {
          display: flex;
          align-items: center;
          padding: 1rem var(--space-xl);
          border-radius: 0;
          font-size: 1rem;
          font-weight: 600;
          color: var(--text-primary);
          min-height: 56px;
          border-left: 4px solid transparent;
          transition: all var(--transition-fast);
        }

        .nav-list > li > a:hover,
        .nav-list > li > a:active {
          background: var(--primary-light);
          color: var(--primary-dark);
          border-left-color: var(--primary);
        }

        /* ── Dropdown Trigger ── */
        .nav-has-dropdown {
          position: static;
        }

        .nav-dropdown-trigger {
          display: flex;
          width: 100%;
          padding: 1rem var(--space-xl);
          border-radius: 0;
          justify-content: space-between;
          min-height: 56px;
          font-size: 1rem;
          font-weight: 600;
          border-left: 4px solid transparent;
          transition: all var(--transition-fast);
        }

        .nav-dropdown-trigger:hover,
        .nav-dropdown-trigger:active {
          background: var(--primary-light);
          color: var(--primary-dark);
          border-left-color: var(--primary);
        }

        .nav-dropdown-trigger[aria-expanded="true"] {
          color: var(--primary-dark);
          background: var(--primary-light);
          border-left-color: var(--primary);
        }

        /* ── Dropdown Panel (Accordion) ── */
        .nav-dropdown {
          position: static !important;
          left: auto !important;
          top: auto !important;
          transform: none !important;
          opacity: 1 !important;
          visibility: visible !important;
          pointer-events: auto;
          box-shadow: none !important;
          border: none !important;
          border-radius: 0 !important;
          min-width: 0 !important;
          max-width: 100% !important;
          width: 100% !important;
          padding: 0 !important;
          max-height: 0;
          overflow: hidden;
          background: var(--surface-alt);
          transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        }

        .nav-dropdown.is-open {
          max-height: 600px;
          overflow: visible;
        }

        /* Override hover selectors */
        .nav-has-dropdown:hover > .nav-dropdown,
        .nav-dropdown-trigger[aria-expanded="true"] + .nav-dropdown {
          transform: none !important;
          left: auto !important;
          position: static !important;
        }

        .nav-has-dropdown:hover > .nav-dropdown:not(.is-open) {
          max-height: 0;
          overflow: hidden;
        }

        /* ── Dropdown Items ── */
        .nav-dropdown-mega {
          min-width: 0 !important;
        }

        .dropdown-mega-inner {
          flex-direction: column;
        }

        .dropdown-promo {
          width: 100%;
          border-left: none;
          border-top: 1px solid var(--border-light);
          border-radius: 0;
          flex-direction: row;
          flex-wrap: wrap;
          padding: var(--space-sm) var(--space-lg);
        }

        .promo-label {
          width: 100%;
        }

        .dropdown-grid {
          width: 100%;
          overflow: hidden;
        }

        .dropdown-tools {
          padding: var(--space-xs) 0;
          width: 100%;
          flex: none;
        }

        .dropdown-item {
          padding: 0.75rem var(--space-lg);
          padding-left: calc(var(--space-lg) + 3px);
          width: 100%;
          box-sizing: border-box;
          min-height: 48px;
          transition: background var(--transition-fast);
        }

        .dropdown-item:active {
          background: var(--primary-light);
        }

        .dropdown-tool-card {
          padding: 0.75rem var(--space-lg);
          padding-left: calc(var(--space-lg) + 3px);
          width: 100%;
          box-sizing: border-box;
          min-height: 48px;
          transition: background var(--transition-fast);
        }

        .dropdown-tool-card:active {
          background: var(--primary-light);
        }

        .tool-icon {
          width: 2rem;
          height: 2rem;
          min-width: 2rem;
        }

        .tool-info strong {
          font-size: 0.8125rem;
        }

        .tool-info span {
          font-size: 0.7rem;
        }

        .dropdown-icon {
          width: 1.75rem;
          min-width: 1.75rem;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .nav-has-dropdown::after {
          display: none;
        }

        /* ── Drawer CTA ── */
        .drawer-cta {
          display: flex;
          flex-direction: column;
          gap: var(--space-sm);
          padding: var(--space-lg);
          border-top: 1px solid var(--border-light);
          flex-shrink: 0;
          background: var(--surface-alt);
        }

        .drawer-cta-btn {
          width: 100%;
          justify-content: center;
          min-height: 48px;
          font-size: 1rem;
          font-weight: 700;
          border-radius: var(--radius-md);
          box-shadow: 0 4px 12px rgba(240, 125, 0, 0.3);
        }

        .drawer-phone {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: var(--space-sm);
          padding: 0.75rem;
          color: var(--primary);
          font-weight: 600;
          font-size: 0.9375rem;
          border: 1px solid var(--border);
          border-radius: var(--radius-md);
          text-decoration: none;
          min-height: 44px;
          transition: all var(--transition-fast);
        }

        .drawer-phone:hover {
          background: var(--primary-light);
          border-color: var(--primary);
        }

        /* ── Header Optimizations ── */
        .header-inner {
          gap: 8px;
        }

        .header-actions {
          margin-left: auto;
        }

        .header-phone {
          display: none;
        }

        .mobile-toggle {
          display: flex;
        }

        /* ── Hamburger → X Animation ── */
        .mobile-toggle span {
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          transform-origin: center;
        }

        .mobile-toggle[aria-expanded="true"] span:nth-child(1) {
          transform: rotate(45deg) translate(5px, 5px);
        }

        .mobile-toggle[aria-expanded="true"] span:nth-child(2) {
          opacity: 0;
          transform: scaleX(0);
        }

        .mobile-toggle[aria-expanded="true"] span:nth-child(3) {
          transform: rotate(-45deg) translate(5px, -5px);
        }

        /* ── Sticky CTA Bar ── */
        .sticky-cta {
          display: flex;
        }

        .sticky-cta-item {
          font-size: 0.75rem;
          gap: 3px;
        }

        .sticky-cta-primary {
          padding: var(--space-xs) var(--space-lg);
          font-weight: 700;
          box-shadow: 0 -2px 8px rgba(240, 125, 0, 0.25);
        }

        body {
          padding-bottom: 64px;
        }

        /* ── Footer ── */
        .footer-grid {
          grid-template-columns: 1fr;
          gap: var(--space-xl);
        }

        .footer-bottom {
          flex-direction: column;
          gap: var(--space-md);
          text-align: center;
        }
      }

      /* ── Small Phone (320px–374px) ── */
      @media (max-width: 374px) {
        .header-inner {
          height: 60px;
          gap: var(--space-sm);
        }

        .logo-icon {
          width: 32px !important;
          height: 32px !important;
        }

        .logo-brand {
          font-size: 0.9375rem;
        }

        .logo-sub {
          font-size: 0.5625rem;
        }

        #header-cta {
          padding: 0.375rem 0.75rem;
          font-size: 0.75rem;
        }

        .main-nav {
          width: 90%;
        }

        .sticky-cta-item {
          font-size: 0.6875rem;
          padding: 2px;
        }

        .sticky-cta-primary {
          padding: var(--space-xs) var(--space-md);
        }
      }

      @media (min-width: 769px) and (max-width: 1024px) {
        .footer-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .nav-dropdown-mega {
          min-width: 400px;
        }
      }

      /* ── Reduced Motion ── */
      @media (prefers-reduced-motion: reduce) {
        .main-nav,
        .nav-backdrop,
        .nav-dropdown,
        .mobile-toggle span {
          transition: none !important;
        }
      }

      /* ═══════════════════════════════════════
         Universal Search Styles
         ═══════════════════════════════════════ */

      /* Search trigger button in header */
      .search-trigger {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: var(--surface);
        color: var(--text-secondary);
        cursor: pointer;
        transition: all var(--transition-fast);
      }

      .search-trigger:hover {
        border-color: var(--primary);
        color: var(--primary);
        box-shadow: var(--shadow-sm);
      }

      /* Search overlay */
      .search-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 12vh;
      }

      .search-overlay[hidden] {
        display: none;
      }

      .search-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        animation: searchFadeIn 150ms ease;
      }

      .search-container {
        position: relative;
        width: 100%;
        max-width: 560px;
        background: var(--surface);
        border-radius: var(--radius-xl);
        box-shadow:
          var(--shadow-xl),
          0 0 0 1px var(--border-light);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: 70vh;
        animation: searchSlideIn 200ms ease;
      }

      @keyframes searchFadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes searchSlideIn {
        from {
          opacity: 0;
          transform: translateY(-12px) scale(0.98);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      /* Search header / input */
      .search-header {
        padding: var(--space-md) var(--space-lg);
        border-bottom: 1px solid var(--border-light);
      }

      .search-input-wrap {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
      }

      .search-input-icon {
        flex-shrink: 0;
        color: var(--text-muted);
      }

      .search-input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        font-family: var(--font-body);
        font-size: 1.0625rem;
        color: var(--text-primary);
        padding: var(--space-sm) 0;
        line-height: 1.5;
      }

      .search-input::placeholder {
        color: var(--text-muted);
      }

      .search-input::-webkit-search-cancel-button {
        display: none;
      }

      .search-kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px 6px;
        font-family: var(--font-body);
        font-size: 0.6875rem;
        font-weight: 600;
        color: var(--text-muted);
        background: var(--surface-alt);
        border: 1px solid var(--border);
        border-radius: 4px;
        line-height: 1.4;
        white-space: nowrap;
      }

      /* Search body */
      .search-body {
        flex: 1;
        overflow-y: auto;
        overscroll-behavior: contain;
        padding: var(--space-sm) 0;
        min-height: 120px;
      }

      .search-empty[hidden],
      .search-no-results[hidden] {
        display: none !important;
      }

      .search-empty,
      .search-no-results {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--space-sm);
        padding: var(--space-3xl) var(--space-xl);
        text-align: center;
        color: var(--text-muted);
      }

      .search-empty p,
      .search-no-results p {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--text-secondary);
        margin: 0;
      }

      .search-hint {
        font-size: 0.8125rem;
        color: var(--text-muted);
      }

      .search-suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-sm);
        justify-content: center;
        margin-top: var(--space-md);
      }

      .search-suggestions a {
        font-size: 0.75rem;
        padding: 0.35rem 0.75rem;
        border-radius: var(--radius-full);
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-secondary);
        text-decoration: none;
        transition: all var(--transition-fast);
      }

      .search-suggestions a:hover {
        background: var(--primary-light);
        border-color: var(--primary);
        color: var(--primary-dark);
      }

      /* Search results */
      .search-results {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .search-results :global(.search-result-item) {
        margin: 0;
      }

      .search-results :global(.search-result-link) {
        display: flex;
        align-items: flex-start;
        gap: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        text-decoration: none;
        color: var(--text-primary);
        transition: background var(--transition-fast);
        cursor: pointer;
        border-left: 3px solid transparent;
      }

      .search-results :global(.search-result-link:hover),
      .search-results :global(.search-result-link[aria-selected="true"]) {
        background: var(--primary-light);
        border-left-color: var(--primary);
      }

      .search-results :global(.search-result-icon) {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-sm);
        background: var(--surface-alt);
        margin-top: 2px;
      }

      .search-results
        :global(.search-result-link[aria-selected="true"] .search-result-icon) {
        background: var(--primary);
        color: #fff;
      }

      .search-results :global(.search-result-text) {
        flex: 1;
        min-width: 0;
      }

      .search-results :global(.search-result-title) {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .search-results :global(.search-result-title mark),
      .search-results :global(.search-result-desc mark) {
        background: rgba(240, 125, 0, 0.2);
        color: #d97000;
        padding: 0 2px;
        border-radius: 2px;
        font-weight: bold;
      }

      .search-results :global(.search-result-desc) {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.4;
        margin-top: 2px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .search-results :global(.search-result-meta) {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        margin-top: 4px;
      }

      .search-results :global(.search-result-badge) {
        display: inline-flex;
        align-items: center;
        padding: 1px 8px;
        font-size: 0.6875rem;
        font-weight: 600;
        border-radius: var(--radius-full);
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .search-results :global(.search-result-badge[data-type="blog"]) {
        background: var(--primary-light);
        color: var(--primary-dark);
      }

      .search-results :global(.search-result-badge[data-type="tool"]) {
        background: var(--accent-light);
        color: var(--accent-dark);
      }

      .search-results :global(.search-result-badge[data-type="page"]) {
        background: var(--surface-alt);
        color: var(--text-secondary);
      }

      .search-results :global(.search-result-cat) {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      /* Search footer */
      .search-footer {
        padding: var(--space-sm) var(--space-lg);
        border-top: 1px solid var(--border-light);
        background: var(--surface-alt);
      }

      .search-footer-hints {
        display: flex;
        align-items: center;
        gap: var(--space-lg);
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .search-footer-hints kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        padding: 1px 4px;
        font-family: var(--font-body);
        font-size: 0.625rem;
        font-weight: 600;
        color: var(--text-muted);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 3px;
        margin-right: 2px;
      }

      @media (max-width: 768px) {
        .search-container {
          margin: 0 var(--space-md);
          max-height: 80vh;
        }
        .search-overlay {
          padding-top: 8vh;
        }
        .search-footer {
          display: none;
        }
      }
    </style>

    <script>
      // ── Mobile Drawer Navigation ──
      const toggle = document.getElementById("mobile-toggle");
      const nav = document.getElementById("main-nav");
      const backdrop = document.getElementById("nav-backdrop");
      const drawerClose = document.getElementById("drawer-close");
      const headerInner = document.querySelector(".header-inner");
      const headerActions = document.querySelector(".header-actions");

      function openDrawer() {
        if (!toggle || !nav || !backdrop) return;

        // FOOLPROOF FIX: Move drawer out of sticky header to avoid iOS/Chrome fixed-in-sticky bugs.
        // It becomes a direct child of body, relative strictly to the true viewport.
        document.body.appendChild(backdrop);
        document.body.appendChild(nav);

        // Force a reflow before animating (fixes transition occasionally dropping)
        nav.getBoundingClientRect();

        toggle.setAttribute("aria-expanded", "true");
        nav.classList.add("is-open");
        backdrop.classList.add("is-visible");

        // Simple scroll lock
        document.body.style.overflow = "hidden";
      }

      function closeDrawer() {
        if (!toggle || !nav || !backdrop) return;
        toggle.setAttribute("aria-expanded", "false");
        nav.classList.remove("is-open");
        backdrop.classList.remove("is-visible");

        // Restore scroll
        document.body.style.overflow = "";

        // Wait for close animation (300ms) to finish before restoring element to header
        setTimeout(() => {
          if (
            !nav.classList.contains("is-open") &&
            headerInner &&
            headerActions
          ) {
            headerInner.insertBefore(backdrop, headerActions);
            headerInner.insertBefore(nav, headerActions);
          }
        }, 300);

        // Close all nested dropdowns
        nav
          .querySelectorAll(".nav-dropdown.is-open")
          .forEach((d) => d.classList.remove("is-open"));
        nav
          .querySelectorAll('.nav-dropdown-trigger[aria-expanded="true"]')
          .forEach((t) => t.setAttribute("aria-expanded", "false"));
      }

      // Close drawer if resizing matches desktop breakpoint
      window.addEventListener("resize", () => {
        if (
          window.innerWidth > 768 &&
          nav &&
          nav.classList.contains("is-open")
        ) {
          closeDrawer();
        }
      });

      // Prevent backdrop scrolling on iOS
      if (backdrop) {
        backdrop.addEventListener(
          "touchmove",
          function (e) {
            e.preventDefault();
          },
          { passive: false },
        );
      }

      // Toggle button
      if (toggle) {
        toggle.addEventListener("click", () => {
          const isOpen = toggle.getAttribute("aria-expanded") === "true";
          isOpen ? closeDrawer() : openDrawer();
        });
      }

      // Close button inside drawer
      if (drawerClose) {
        drawerClose.addEventListener("click", closeDrawer);
      }

      // Backdrop click
      if (backdrop) {
        backdrop.addEventListener("click", closeDrawer);
      }

      // Close drawer links (navigate away)
      nav?.querySelectorAll("a[href]").forEach((link) => {
        link.addEventListener("click", () => {
          if (window.innerWidth <= 768) {
            // Small delay so navigation starts
            setTimeout(closeDrawer, 100);
          }
        });
      });

      // Dropdown accordion (mobile) + hover (desktop)
      document.querySelectorAll(".nav-dropdown-trigger").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const parent = (trigger as HTMLElement).closest(".nav-has-dropdown");
          const dropdown = parent?.querySelector(".nav-dropdown");
          if (!dropdown) return;

          const isExpanded = trigger.getAttribute("aria-expanded") === "true";

          // On mobile, close siblings first
          if (window.innerWidth <= 768) {
            document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
              if (t !== trigger) {
                t.setAttribute("aria-expanded", "false");
                t.closest(".nav-has-dropdown")
                  ?.querySelector(".nav-dropdown")
                  ?.classList.remove("is-open");
              }
            });
          }

          trigger.setAttribute("aria-expanded", String(!isExpanded));
          dropdown.classList.toggle("is-open", !isExpanded);
        });
      });

      // Close dropdowns on outside click (desktop)
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (
          !target.closest(".nav-has-dropdown") &&
          !target.closest(".mobile-toggle") &&
          !target.closest(".main-nav")
        ) {
          document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
            t.setAttribute("aria-expanded", "false");
          });
          document.querySelectorAll(".nav-dropdown.is-open").forEach((d) => {
            d.classList.remove("is-open");
          });
        }
      });

      // Escape key closes everything
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          closeDrawer();
          document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
            t.setAttribute("aria-expanded", "false");
          });
          document.querySelectorAll(".nav-dropdown.is-open").forEach((d) => {
            d.classList.remove("is-open");
          });
        }
      });

      // Header scroll shadow
      const header = document.getElementById("site-header");
      if (header) {
        window.addEventListener(
          "scroll",
          () => {
            header.style.boxShadow =
              window.scrollY > 10 ? "var(--shadow-sm)" : "none";
          },
          { passive: true },
        );
      }

      // ═══════════════════════════════════════
      // Universal Search
      // ═══════════════════════════════════════

      const searchTrigger = document.getElementById("search-trigger");
      const searchOverlay = document.getElementById("search-overlay");
      const searchBackdropEl = document.getElementById("search-backdrop");
      const searchInput = document.getElementById(
        "search-input",
      ) as HTMLInputElement;
      const searchResults = document.getElementById("search-results");
      const searchEmpty = document.getElementById("search-empty");
      const searchNoResults = document.getElementById("search-no-results");

      let searchIndex: any[] | null = null;
      let activeIndex = -1;
      let debounceTimer: ReturnType<typeof setTimeout>;

      // Vietnamese normalize function
      function normalize(text: string): string {
        if (!text) return "";
        return text
          .toLowerCase()
          .replace(/đ/g, "d")
          .replace(/Đ/g, "d")
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/\s+/g, " ")
          .trim();
      }

      // Search scoring
      function searchScore(
        entry: any,
        tokens: string[],
        fullQuery: string,
      ): number {
        if (!tokens.length) return 0;
        const title = normalize(entry.t);
        const desc = normalize(entry.d);
        const tags = (entry.k || []).map((t: string) => normalize(t));
        const cat = normalize(entry.c);

        const allMatch = tokens.every(
          (tk: string) =>
            title.includes(tk) ||
            desc.includes(tk) ||
            tags.some((tag: string) => tag.includes(tk)) ||
            cat.includes(tk),
        );
        if (!allMatch) return 0;

        let score = 1;
        if (title.includes(fullQuery)) score += 15;
        if (title.startsWith(fullQuery)) score += 8;
        tokens.forEach((tk: string) => {
          if (title.includes(tk)) score += 6;
          if (tags.some((tag: string) => tag.includes(tk))) score += 3;
          if (cat.includes(tk)) score += 2;
          if (desc.includes(tk)) score += 1;
        });
        if (entry.y === "tool") score += 2;
        if (entry.y === "page") score += 1;
        return score;
      }

      function doSearch(query: string): any[] {
        if (!searchIndex) return [];
        const nq = normalize(query);
        if (!nq) return [];
        const tokens = nq.split(" ").filter(Boolean);
        if (!tokens.length) return [];

        const scored: any[] = [];
        for (const entry of searchIndex) {
          const s = searchScore(entry, tokens, nq);
          if (s > 0) scored.push({ ...entry, _score: s });
        }
        scored.sort((a: any, b: any) => b._score - a._score);
        return scored.slice(0, 8);
      }

      // Fetch index lazily
      async function loadIndex() {
        if (searchIndex) return;
        try {
          const res = await fetch("/search-index.json");
          searchIndex = await res.json();
        } catch (e) {
          console.error("Failed to load search index", e);
        }
      }

      // Type icons
      function typeIcon(type: string): string {
        if (type === "tool")
          return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>';
        if (type === "page")
          return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>';
        return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>';
      }

      function typeName(type: string): string {
        if (type === "tool") return "Công cụ";
        if (type === "page") return "Trang";
        return "Bài viết";
      }

      // Highlight matched text
      function highlightText(text: string, query: string): string {
        if (!text || !query) return text || "";
        const nq = normalize(query);
        const tokens = nq.split(" ").filter(Boolean);
        if (!tokens.length) return text;

        const normText = normalize(text);
        const ranges: Array<[number, number]> = [];

        for (const token of tokens) {
          let pos = 0;
          while (true) {
            const idx = normText.indexOf(token, pos);
            if (idx === -1) break;
            ranges.push([idx, idx + token.length]);
            pos = idx + 1;
          }
        }

        if (!ranges.length) return text;

        ranges.sort((a, b) => a[0] - b[0]);
        const merged: Array<[number, number]> = [ranges[0]];
        for (let i = 1; i < ranges.length; i++) {
          const last = merged[merged.length - 1];
          if (ranges[i][0] <= last[1]) {
            last[1] = Math.max(last[1], ranges[i][1]);
          } else {
            merged.push(ranges[i]);
          }
        }

        let result = "";
        let prev = 0;
        for (const [start, end] of merged) {
          result += escapeHtml(text.slice(prev, start));
          result += "<mark>" + escapeHtml(text.slice(start, end)) + "</mark>";
          prev = end;
        }
        result += escapeHtml(text.slice(prev));
        return result;
      }

      function escapeHtml(str: string): string {
        return str
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
      }

      // Render results
      function renderResults(results: any[], query: string) {
        if (!searchResults || !searchEmpty || !searchNoResults) return;

        if (!query.trim()) {
          searchResults.innerHTML = "";
          searchEmpty.hidden = false;
          searchNoResults.hidden = true;
          return;
        }

        if (results.length === 0) {
          searchResults.innerHTML = "";
          searchEmpty.hidden = true;
          searchNoResults.hidden = false;
          searchNoResults.innerHTML = `
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              <line x1="8" y1="8" x2="14" y2="14" stroke="var(--error)"></line>
            </svg>
            <p>Không tìm thấy kết quả cho "<strong>${escapeHtml(query)}</strong>"</p>
            <span class="search-hint" style="margin-top: 0.5rem;">Gợi ý tìm kiếm phổ biến:</span>
            <div class="search-suggestions">
               <a href="/cong-cu/du-doan-sinh-non">Dự đoán sinh non</a>
               <a href="/cong-cu/tinh-ngay-du-sinh">Tính ngày dự sinh</a>
               <a href="/sieu-am-5d">Siêu âm 5D</a>
               <a href="/kham-thai">Khám thai</a>
            </div>
          `;
          return;
        }

        searchEmpty.hidden = true;
        searchNoResults.hidden = true;
        activeIndex = -1;

        searchResults.innerHTML = results
          .map(
            (r: any, i: number) => `
          <li class="search-result-item" role="option" id="search-item-${i}">
            <a class="search-result-link" href="${r.u}" data-index="${i}">
              <span class="search-result-icon">${typeIcon(r.y)}</span>
              <div class="search-result-text">
                <div class="search-result-title">${highlightText(r.t, query)}</div>
                <div class="search-result-desc">${escapeHtml(r.d)}</div>
                <div class="search-result-meta">
                  <span class="search-result-badge" data-type="${r.y}">${typeName(r.y)}</span>
                  <span class="search-result-cat">${escapeHtml(r.c)}</span>
                </div>
              </div>
            </a>
          </li>
        `,
          )
          .join("");
      }

      // Keyboard navigation
      function setActiveResult(index: number) {
        if (!searchResults) return;
        const items = searchResults.querySelectorAll(".search-result-link");
        items.forEach((item, i) => {
          item.setAttribute("aria-selected", i === index ? "true" : "false");
        });
        if (index >= 0 && index < items.length) {
          (items[index] as HTMLElement).scrollIntoView({ block: "nearest" });
        }
      }

      // Open / Close search
      function openSearch() {
        if (!searchOverlay || !searchInput) return;
        searchOverlay.hidden = false;
        document.body.style.overflow = "hidden";
        loadIndex();
        requestAnimationFrame(() => {
          searchInput.focus();
        });
      }

      function closeSearch() {
        if (!searchOverlay || !searchInput) return;
        searchOverlay.hidden = true;
        document.body.style.overflow = "";
        searchInput.value = "";
        if (searchResults) searchResults.innerHTML = "";
        if (searchEmpty) searchEmpty.hidden = false;
        if (searchNoResults) searchNoResults.hidden = true;
        activeIndex = -1;
      }

      // Event listeners
      searchTrigger?.addEventListener("click", openSearch);
      searchBackdropEl?.addEventListener("click", closeSearch);

      // Ctrl+K / Cmd+K shortcut
      document.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          if (searchOverlay?.hidden) {
            openSearch();
          } else {
            closeSearch();
          }
        }
      });

      // Search input handler
      searchInput?.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          const query = searchInput.value;
          const results = doSearch(query);
          renderResults(results, query);
        }, 100);
      });

      // Keyboard navigation in search
      searchInput?.addEventListener("keydown", (e) => {
        if (!searchResults) return;
        const items = searchResults.querySelectorAll(".search-result-link");
        const count = items.length;
        if (!count) return;

        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIndex = (activeIndex + 1) % count;
          setActiveResult(activeIndex);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIndex = activeIndex <= 0 ? count - 1 : activeIndex - 1;
          setActiveResult(activeIndex);
        } else if (
          e.key === "Enter" &&
          activeIndex >= 0 &&
          activeIndex < count
        ) {
          e.preventDefault();
          (items[activeIndex] as HTMLAnchorElement).click();
        }
      });

      // Escape closes search
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !searchOverlay?.hidden) {
          closeSearch();
        }
      });
    </script>
  </body>
</html>
