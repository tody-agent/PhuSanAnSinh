      function openBookingSheet(ctx?: any) {
        if (!bookingSheet || !bookingBackdrop) return;

        // Reset to Step 1
        const stepForm = document.getElementById('booking-step-form');
        const stepCal = document.getElementById('booking-step-calendar');
        if (stepForm) stepForm.hidden = false;
        if (stepCal) stepCal.hidden = true;

        // Reset submit button
        const footerEl = bookingSheet.querySelector('.booking-sheet-footer') as HTMLElement;
        if (footerEl) footerEl.hidden = false;

        bookingSheet.classList.add("is-open");
        bookingBackdrop.classList.add("is-visible");
        document.body.style.overflow = "hidden";

        // Set current page URL
        const urlInput = bookingSheet.querySelector('input[name="url"]') as HTMLInputElement;
        if (urlInput) urlInput.value = window.location.href;

        // Close mobile drawer if open
        if (window.innerWidth <= 768) { closeDrawer(); }

        // ═══ Pre-fill from URL param context (quick-booking) ═══
        if (ctx && ctx.phone) {
          const phoneEl = document.getElementById("booking-phone") as HTMLInputElement;
          if (phoneEl) phoneEl.value = ctx.phone;
        }
        if (ctx && ctx.name) {
          const nameEl = document.getElementById("booking-name") as HTMLInputElement;
          if (nameEl) nameEl.value = ctx.name;
        }
        if (ctx && ctx.service) {
          const serviceEl = document.getElementById("booking-service") as HTMLSelectElement;
          if (serviceEl) {
            for (const opt of serviceEl.options) {
              if (opt.value === ctx.service) { serviceEl.value = ctx.service; break; }
            }
          }
        }
        if (ctx && ctx.note) {
          const noteEl = document.getElementById("booking-note") as HTMLTextAreaElement;
          if (noteEl) noteEl.value = ctx.note;
        }
        if (ctx && ctx.ref) {
          const refInput = bookingSheet.querySelector('input[name="ref"]') as HTMLInputElement;
          if (refInput) refInput.value = ctx.ref;
        }
        if (ctx && ctx.formType) {
          const formTypeInput = bookingSheet.querySelector('input[name="formType"]') as HTMLInputElement;
          if (formTypeInput) formTypeInput.value = ctx.formType;
        }

        // ═══ Configure context ═══
        const bCtx = (window as any)._bookingContext;
        if (ctx && ctx.milestones && ctx.milestones.length > 0) {
          bCtx.milestones = ctx.milestones;
          bCtx.lmpDate = ctx.lmpDate || null;
          bCtx.source = 'checklist';
        } else {
          bCtx.milestones = [];
          bCtx.source = 'general';
          // Try to detect EDD from localStorage for Step 2 after submit
          try {
            const eddRaw = localStorage.getItem('ansinh_edd_info');
            if (eddRaw) {
              const eddInfo = JSON.parse(eddRaw);
              if (eddInfo && eddInfo.lmpDate) bCtx.lmpDate = eddInfo.lmpDate;
            }
          } catch (e) { /* ignore */ }
        }

        // ═══ Configure conditional fields ═══
        const dateField = document.getElementById('booking-date-field');
        const dayPrefField = document.getElementById('booking-daypref-field');
        const timeField = document.getElementById('booking-time-field');
        const timePrefField = document.getElementById('booking-timepref-field');
        const reminderField = document.getElementById('booking-reminder-field');

        const isMulti = bCtx.milestones.length > 1;
        const isChecklist = bCtx.source === 'checklist';

        if (isMulti) {
          // Multi milestone: show day-of-week chips, hide date dropdown
          if (dateField) dateField.hidden = true;
          if (dayPrefField) dayPrefField.hidden = false;
          if (timeField) timeField.hidden = true;
          if (timePrefField) timePrefField.hidden = false;
          if (reminderField) reminderField.hidden = false;
        } else {
          // Single or no milestone: show date dropdown
          if (dateField) dateField.hidden = false;
          if (dayPrefField) dayPrefField.hidden = true;
          if (timePrefField) timePrefField.hidden = isChecklist ? false : true;
          if (reminderField) reminderField.hidden = isChecklist ? false : true;
          // Time field managed by date selection
        }

        // Pre-select date from ctx
        if (ctx && ctx.date) {
          const dateSelect = document.getElementById('booking-date-select') as HTMLSelectElement;
          if (dateSelect) {
            for (const opt of dateSelect.options) {
              if (opt.value === ctx.date) { dateSelect.value = ctx.date; break; }
            }
            // Re-generate time slots for the selected date
            const tf = document.getElementById('booking-time-field');
            if (tf) { tf.hidden = false; generateTimeSlots(ctx.date); }
          }
        }
        // Pre-select time slot from ctx
        if (ctx && ctx.timeSlot) {
          setTimeout(() => {
            const timeSelect = document.getElementById('booking-time-select') as HTMLSelectElement;
            if (timeSelect) {
              for (const opt of timeSelect.options) {
                if (opt.value === ctx.timeSlot) { timeSelect.value = ctx.timeSlot; break; }
              }
            }
          }, 50);
        }

        // Set hidden form fields
        if (isChecklist && bCtx.milestones.length > 0) {
          const msInput = bookingSheet.querySelector('input[name="selectedMilestones"]') as HTMLInputElement;
          const mwInput = bookingSheet.querySelector('input[name="milestoneWeeks"]') as HTMLInputElement;
          if (msInput) msInput.value = bCtx.milestones.map((m: any) => m.title).join(', ');
          if (mwInput) mwInput.value = bCtx.milestones.map((m: any) => m.week).join(',');
        }

        // ═══ Smart Booking: Auto-fill & Suggestion Banner ═══
        try {
          const smartBanner = document.getElementById("booking-smart-banner");
          const bannerTitle = document.getElementById("smart-banner-title");
          const bannerDesc = document.getElementById("smart-banner-desc");
          const bannerIcon = document.getElementById("smart-banner-icon");
          const bannerDismiss = document.getElementById("smart-banner-dismiss");

          const historyRaw = localStorage.getItem('ansinh_booking_history');
          if (historyRaw) {
            try {
              const history = JSON.parse(historyRaw);
              if (Array.isArray(history) && history.length > 0) {
                const last = history[0];
                const phoneEl = document.getElementById("booking-phone") as HTMLInputElement;
                const nameEl = document.getElementById("booking-name") as HTMLInputElement;
                if (phoneEl && !phoneEl.value && last.phone) phoneEl.value = last.phone;
                if (nameEl && !nameEl.value && last.name) nameEl.value = last.name;
              }
            } catch (e) { /* ignore */ }
          }

          // Show smart suggestion banner (only in general mode, not checklist)
          if (!isChecklist && bCtx.lmpDate) {
            try {
              const lmp = new Date(bCtx.lmpDate);
              const now = new Date();
              const totalDays = Math.floor((now.getTime() - lmp.getTime()) / (1000 * 60 * 60 * 24));
              if (totalDays > 0) {
                const gaWeeks = Math.floor(totalDays / 7);
                const gaDays = totalDays % 7;
                let nextMilestone = null;
                for (const m of MILESTONES_DATA) {
                  if (m.week > gaWeeks || (m.week === gaWeeks && gaDays <= 2)) {
                    nextMilestone = m; break;
                  }
                }
                if (nextMilestone) {
                  // Auto-detect next milestone for Step 2 calendar save
                  bCtx.milestones = [nextMilestone];

                  const serviceEl = document.getElementById("booking-service") as HTMLSelectElement;
                  if (serviceEl && nextMilestone.service && !ctx?.service) {
                    for (const opt of serviceEl.options) {
                      if (opt.value === nextMilestone.service) { serviceEl.value = nextMilestone.service; break; }
                    }
                  }
                  const noteEl = document.getElementById("booking-note") as HTMLTextAreaElement;
                  if (noteEl && !noteEl.value) noteEl.value = `Khám thai tuần ${nextMilestone.week} — ${nextMilestone.title}`;

                  if (smartBanner && bannerTitle && bannerDesc && bannerIcon) {
                    const weeksUntil = nextMilestone.week - gaWeeks;
                    bannerTitle.textContent = weeksUntil <= 0
                      ? `Tuần ${gaWeeks}: Đã đến lúc ${nextMilestone.title}`
                      : weeksUntil <= 2
                        ? `Tuần ${gaWeeks}: Sắp đến mốc ${nextMilestone.title}`
                        : `Tuần ${gaWeeks}: Mốc tiếp theo — ${nextMilestone.title} (tuần ${nextMilestone.week})`;
                    bannerDesc.textContent = nextMilestone.reason;
                    bannerIcon.textContent = nextMilestone.icon;
                    smartBanner.hidden = false;
                  }
                }
              }
            } catch (e) { /* ignore */ }
          }

          if (bannerDismiss && smartBanner) {
            bannerDismiss.onclick = () => {
              smartBanner.hidden = true;
              const serviceEl = document.getElementById("booking-service") as HTMLSelectElement;
              const noteEl = document.getElementById("booking-note") as HTMLTextAreaElement;
              if (serviceEl) serviceEl.value = '';
              if (noteEl) noteEl.value = '';
            };
          }
        } catch (e) {
          console.warn('Smart Booking error:', e);
        }
      }

      function closeBookingSheet() {
        if (!bookingSheet || !bookingBackdrop) return;
        bookingSheet.classList.remove("is-open");
        bookingBackdrop.classList.remove("is-visible");
        document.body.style.overflow = "";
        // Reset wizard to Step 1
        setTimeout(() => {
          const stepForm = document.getElementById('booking-step-form');
          const stepCal = document.getElementById('booking-step-calendar');
          const footerEl = bookingSheet?.querySelector('.booking-sheet-footer') as HTMLElement;
          if (stepForm) stepForm.hidden = false;
          if (stepCal) stepCal.hidden = true;
          if (footerEl) footerEl.hidden = false;
        }, 350);
      }

      // Global event delegation for all booking triggers
      document.addEventListener("click", (e) => {
        const target = e.target as Element;
        const bookingTrigger = target.closest('.open-booking, a[href*="dat-lich-hen-kham"]');
        if (bookingTrigger) {
          e.preventDefault();
          e.stopPropagation();
          openBookingSheet();
        }
      });

      // Custom event for checklist pages to pass context
      document.addEventListener('open-booking', ((e: CustomEvent) => {
        openBookingSheet(e.detail);
      }) as EventListener);

      if (bookingBackdrop) {
        bookingBackdrop.addEventListener("click", closeBookingSheet);
      }

      if (bookingClose) {
        bookingClose.addEventListener("click", closeBookingSheet);
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && bookingSheet?.classList.contains("is-open")) {
          closeBookingSheet();
        }
      });

      // Sticky services trigger → open services sheet
      const stickyServicesTrigger = document.getElementById(
        "sticky-services-trigger",
      );
      const servicesSheet = document.getElementById("services-sheet");
      const servicesBackdrop = document.getElementById("services-sheet-backdrop");
      const servicesClose = document.getElementById("services-sheet-close");

      function openServicesSheet() {
        if (!servicesSheet) return;
        servicesSheet.hidden = false;
        document.body.style.overflow = "hidden";
      }

      function closeServicesSheet() {
        if (!servicesSheet) return;
        servicesSheet.hidden = true;
        document.body.style.overflow = "";
      }

      if (stickyServicesTrigger) {
        stickyServicesTrigger.addEventListener("click", (e) => {
          e.preventDefault();
          e.stopPropagation();
          openServicesSheet();
        });
      }

      if (servicesBackdrop) {
        servicesBackdrop.addEventListener("click", closeServicesSheet);
      }

      if (servicesClose) {
        servicesClose.addEventListener("click", closeServicesSheet);
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && servicesSheet && !servicesSheet.hidden) {
          closeServicesSheet();
        }
      });

      servicesSheet?.querySelectorAll("a[href]").forEach((link) => {
        link.addEventListener("click", () => {
          setTimeout(closeServicesSheet, 100);
        });
      });

      // ═══════════════════════════════════════
      // Booking Form Submission
      // ═══════════════════════════════════════

      const bookingForm = document.getElementById(
        "booking-form",
      ) as HTMLFormElement;
      const APPS_SCRIPT_URL =
        "https://script.google.com/macros/s/AKfycbz5gOgCVmLJPvkRkMKGz5cwspW9pjm0fMOiqHZFp-m1R2I0dKNJoWQKG8v5VD6VGBs6/exec";

      // Generate date dropdown
      function generateDateDropdown() {
        const select = document.getElementById("booking-date-select") as HTMLSelectElement;
        if (!select) return;
        const today = new Date();
        const todayDay = today.getDay();
        const dayFullNames = ["Chủ nhật", "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7"];

        let html = '';
        const daysUntilSunday = todayDay === 0 ? 0 : 7 - todayDay;

        // This week
        for (let i = 0; i <= daysUntilSunday; i++) {
          const d = new Date(today);
          d.setDate(d.getDate() + i);
          const val = d.toISOString().split("T")[0];
          const dayName = dayFullNames[d.getDay()];
          const dateStr = `${d.getDate()}/${d.getMonth() + 1}`;
          let label = "";
          if (i === 0) label = `Hôm nay — ${dayName} ${dateStr}`;
          else if (i === 1) label = `Ngày mai — ${dayName} ${dateStr}`;
          else if (i === 2) label = `Ngày kia — ${dayName} ${dateStr}`;
          else label = `${dayName} ${dateStr}`;
          const sel = i === 1 ? " selected" : "";
          html += `<option value="${val}"${sel}>${label}</option>`;
        }

        // Separator
        html += `<option disabled>── Tuần tới ──</option>`;

        // Next week
        const daysToNextMonday = todayDay === 0 ? 1 : 8 - todayDay;
        for (let i = 0; i < 7; i++) {
          const d = new Date(today);
          d.setDate(d.getDate() + daysToNextMonday + i);
          const val = d.toISOString().split("T")[0];
          const dayName = dayFullNames[d.getDay()];
          const dateStr = `${d.getDate()}/${d.getMonth() + 1}`;
          html += `<option value="${val}">${dayName} ${dateStr}</option>`;
        }

        select.innerHTML = html;

        // Trigger time slots for default selected date
        if (select.value) {
          const timeField = document.getElementById("booking-time-field");
          if (timeField) {
            timeField.hidden = false;
            generateTimeSlots(select.value);
          }
        }

        // Listen for date changes
        select.onchange = () => {
          if (select.value) {
            const timeField = document.getElementById("booking-time-field");
            if (timeField) {
              timeField.hidden = false;
              generateTimeSlots(select.value);
            }
          }
        };
      }

      function generateTimeSlots(dateStr: string) {
        const select = document.getElementById("booking-time-select") as HTMLSelectElement;
        if (!select) return;
        const isToday = dateStr === new Date().toISOString().split("T")[0];
        const now = new Date();
        const slots = ["17:00-18:00", "18:00-19:00", "19:00-20:00", "20:00-21:00"];
        let html = `<option value="">— Chọn khung giờ —</option>`;
        let firstAvailable = "";
        for (const slot of slots) {
          const hour = parseInt(slot.split(":")[0]);
          const disabled = isToday && now.getHours() >= hour;
          if (!disabled && !firstAvailable) firstAvailable = slot;
          html += `<option value="${slot}" ${disabled ? "disabled" : ""}>${slot}${disabled ? " (đã qua)" : ""}</option>`;
        }
        select.innerHTML = html;
        if (firstAvailable) select.value = firstAvailable;
      }

      generateDateDropdown();

      // ═══ Chip handlers ═══
      function setupChipGroup(containerId: string, onSelect: (val: string) => void) {
        const container = document.getElementById(containerId);
        if (!container) return;
        container.addEventListener('click', (e) => {
          const chip = (e.target as Element).closest('.booking-chip') as HTMLElement;
          if (!chip) return;
          container.querySelectorAll('.booking-chip').forEach(c => c.classList.remove('is-active'));
          chip.classList.add('is-active');
          onSelect(chip.dataset.val || '');
        });
      }
      // Day preference dropdown handler
      const daySelect = document.getElementById('booking-day-select') as HTMLSelectElement;
      if (daySelect) {
        daySelect.onchange = () => {
          (window as any)._bookingContext.dayPref = daySelect.value === 'cn' ? 'sunday' : daySelect.value;
        };
      }
      setupChipGroup('booking-time-chips', (v) => { (window as any)._bookingContext.timePref = v; });
      setupChipGroup('booking-reminder-chips', (v) => { (window as any)._bookingContext.reminderHours = v === '8' ? 8 : 'morning_prior'; });

      // Form submit
      if (bookingForm) {
        bookingForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const submitBtn = document.getElementById(
            "booking-submit",
          ) as HTMLButtonElement;
          const phone = (
            document.getElementById("booking-phone") as HTMLInputElement
          )?.value?.trim();
          if (!phone || !/^0[0-9]{8,10}$/.test(phone)) {
            showToast("error", "Vui lòng nhập số điện thoại hợp lệ");
            return;
          }

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = "Đang gửi...";
          }

          const formData = new FormData(bookingForm);
          const data: Record<string, string> = {};
          formData.forEach((v, k) => {
            data[k] = v.toString();
          });
          data.formType = data.formType || "booking";
          data.url = data.url || window.location.href;
          data.timestamp = new Date().toISOString();

          try {
            // ═══ CRM API — primary (sale.todyai.io) ═══
            const crmPayload: Record<string, any> = {
              phone: data.phone,
              name: data.name,
              service: data.service,
              date: data.date,
              time_slot: data.time,
              note: data.note,
              form_type: data.formType || 'booking',
              source_url: data.url || window.location.href,
            };
            // Auto-capture UTM params
            const urlParams = new URLSearchParams(window.location.search);
            ['utm_source', 'utm_medium', 'utm_campaign'].forEach(k => {
              const v = urlParams.get(k);
              if (v) crmPayload[k] = v;
            });
            // Click IDs
            const fbclid = urlParams.get('fbclid');
            const gclid = urlParams.get('gclid');
            if (fbclid || gclid) {
              crmPayload.click_ids = {};
              if (fbclid) crmPayload.click_ids.fbclid = fbclid;
              if (gclid) crmPayload.click_ids.gclid = gclid;
            }

            // Dual-write: CRM + Google Sheets in parallel
            await Promise.allSettled([
              fetch('https://sale.todyai.io/api/bookings', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-Tenant-Slug': 'an-sinh'
                },
                body: JSON.stringify(crmPayload),
              }),
              fetch(APPS_SCRIPT_URL, {
                method: "POST",
                mode: "no-cors",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
              })
            ]);

            // ═══ Smart Booking: Save booking history ═══
            try {
              const historyRaw = localStorage.getItem('ansinh_booking_history');
              const history = historyRaw ? JSON.parse(historyRaw) : [];
              history.unshift({
                phone: data.phone || '',
                name: data.name || '',
                service: data.service || '',
                date: data.date || '',
                note: data.note || '',
                timestamp: new Date().toISOString(),
              });
              localStorage.setItem('ansinh_booking_history', JSON.stringify(history.slice(0, 5)));
            } catch (e) { /* localStorage may fail — non-critical */ }

            // ═══ Wizard: Step 2 or Toast ═══
            const bCtx = (window as any)._bookingContext;
            if (bCtx.milestones && bCtx.milestones.length > 0) {
              // Morph to Step 2: Calendar Save
              const stepForm = document.getElementById('booking-step-form');
              const stepCal = document.getElementById('booking-step-calendar');
              const footerEl = bookingSheet?.querySelector('.booking-sheet-footer') as HTMLElement;
              if (stepForm) stepForm.hidden = true;
              if (stepCal) stepCal.hidden = false;
              if (footerEl) footerEl.hidden = true;

              // Populate calendar info
              const ms = bCtx.milestones;
              const calInfo = document.getElementById('booking-cal-info');
              if (calInfo) {
                if (ms.length === 1) {
                  calInfo.innerHTML = `<strong>${ms[0].icon} ${ms[0].title}</strong> — Tuần ${ms[0].week}<br>${ms[0].reason}`;
                } else {
                  calInfo.innerHTML = `<strong>📋 ${ms.length} mốc khám thai</strong><br>` + ms.map((m: any) => `${m.icon} Tuần ${m.week}: ${m.title}`).join('<br>');
                }
              }

              // Configure buttons: 1 milestone = Google Cal + ICS, multi = ICS only
              const btnGoogle = document.getElementById('booking-cal-google') as HTMLButtonElement;
              const btnIcs = document.getElementById('booking-cal-ics') as HTMLButtonElement;
              if (btnGoogle) btnGoogle.hidden = ms.length > 1;
              if (btnIcs) {
                btnIcs.textContent = ms.length > 1 ? `📲 Tải ${ms.length} lịch (.ics)` : '📲 Tải lịch (.ics)';
              }

              showToast('success', 'Đặt lịch thành công! Lưu lịch để nhắc nhở nhé.');
            } else {
              // No milestones: just toast and close
              showToast('success', 'Đặt lịch thành công! Bác sĩ sẽ liên hệ bạn sớm.');
              closeBookingSheet();
            }

            // Reset form for next use
            const smartBanner = document.getElementById('booking-smart-banner');
            if (smartBanner) smartBanner.hidden = true;
            bookingForm.reset();
            generateDateDropdown();
          } catch {
            showToast('error', 'Lỗi kết nối. Vui lòng gọi hotline 0899 268 299.');
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg> Xác Nhận Đặt Lịch';
            }
          }
        });
      }

      // ═══ Step 2: Calendar Save Button Handlers ═══

      // Helper: adjust date to target day of week
      // dayPref: '2'-'7' (Thứ 2=Mon..Thứ 7=Sat) or 'sunday'
      function adjustToTargetDay(d: Date, dayPref: string) {
        let targetDay: number;
        if (dayPref === 'sunday') targetDay = 0;
        else {
          const thu = parseInt(dayPref);
          if (isNaN(thu) || thu < 2 || thu > 7) return;
          targetDay = thu - 1; // Thứ 2→1(Mon), Thứ 7→6(Sat)
        }
        const diff = (targetDay - d.getDay() + 7) % 7;
        d.setDate(d.getDate() + diff);
      }

      document.getElementById('booking-cal-google')?.addEventListener('click', () => {
        const bCtx = (window as any)._bookingContext;
        if (!bCtx.milestones || bCtx.milestones.length === 0) return;
        const m = bCtx.milestones[0];
        let lmp = bCtx.lmpDate ? new Date(bCtx.lmpDate) : null;
        if (!lmp) {
          try {
            const eddRaw = localStorage.getItem('ansinh_edd_info');
            if (eddRaw) {
              const eddInfo = JSON.parse(eddRaw);
              if (eddInfo?.lmpDate) lmp = new Date(eddInfo.lmpDate);
            }
          } catch (e) { /* ignore */ }
        }
        if (!lmp) { showToast('error', 'Không tìm thấy ngày kinh cuối.'); return; }
        const apptDate = new Date(lmp);
        apptDate.setDate(apptDate.getDate() + m.week * 7);
        adjustToTargetDay(apptDate, bCtx.dayPref || '7');
        // Set time
        const timePref = bCtx.timePref || 'morning';
        const hours = timePref === 'morning' ? 8 : timePref === 'afternoon' ? 14 : 18;
        apptDate.setHours(hours, 0, 0, 0);
        const endDate = new Date(apptDate);
        endDate.setHours(hours + 1);
        // Format for Google Calendar
        const fmt = (d: Date) => d.toISOString().replace(/[-:]/g, '').replace(/\.\d{3}/, '');
        const gcUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent('🩺 ' + m.title + ' — An Sinh')}&dates=${fmt(apptDate)}/${fmt(endDate)}&details=${encodeURIComponent(m.reason + '\n\nPhòng Khám An Sinh\nĐT: 0899 268 299')}&location=${encodeURIComponent('Phòng Khám An Sinh, Từ Sơn, Bắc Ninh')}`;
        window.open(gcUrl, '_blank');
      });

      document.getElementById('booking-cal-ics')?.addEventListener('click', () => {
        const bCtx = (window as any)._bookingContext;
        if (!bCtx.milestones || bCtx.milestones.length === 0) return;

        // Try to get lmpDate from context, then localStorage fallback
        let lmp = bCtx.lmpDate ? new Date(bCtx.lmpDate) : null;
        if (!lmp) {
          try {
            const eddRaw = localStorage.getItem('ansinh_edd_info');
            if (eddRaw) {
              const eddInfo = JSON.parse(eddRaw);
              if (eddInfo?.lmpDate) lmp = new Date(eddInfo.lmpDate);
            }
          } catch (e) { /* ignore */ }
        }
        if (!lmp) { showToast('error', 'Không tìm thấy ngày kinh cuối. Vui lòng tính ngày dự sinh trước.'); return; }

        const dayPref = bCtx.dayPref || '7';
        const timePref = bCtx.timePref || 'morning';
        const hours = timePref === 'morning' ? 8 : timePref === 'afternoon' ? 14 : 18;

        // Format date as local time for ICS (YYYYMMDDTHHmmss)
        const fmtLocal = (d: Date) => {
          const y = d.getFullYear();
          const mo = String(d.getMonth() + 1).padStart(2, '0');
          const da = String(d.getDate()).padStart(2, '0');
          const h = String(d.getHours()).padStart(2, '0');
          const mi = String(d.getMinutes()).padStart(2, '0');
          return y.toString() + mo + da + 'T' + h + mi + '00';
        };

        const calLines: string[] = [
          'BEGIN:VCALENDAR',
          'VERSION:2.0',
          'PRODID:-//AnSinh//PrenatalReminder//VI',
          'CALSCALE:GREGORIAN',
          'METHOD:PUBLISH',
          'X-WR-CALNAME:Lich Kham Thai - Phong Kham An Sinh',
          'X-WR-TIMEZONE:Asia/Ho_Chi_Minh',
          'BEGIN:VTIMEZONE',
          'TZID:Asia/Ho_Chi_Minh',
          'BEGIN:STANDARD',
          'DTSTART:19700101T000000',
          'TZOFFSETFROM:+0700',
          'TZOFFSETTO:+0700',
          'TZNAME:ICT',
          'END:STANDARD',
          'END:VTIMEZONE',
        ];

        for (const m of bCtx.milestones) {
          const apptDate = new Date(lmp);
          apptDate.setDate(apptDate.getDate() + m.week * 7);
          adjustToTargetDay(apptDate, dayPref);
          apptDate.setHours(hours, 0, 0, 0);
          const endDate = new Date(apptDate);
          endDate.setHours(hours + 1);
          const uid = 'ansinh-w' + m.week + '-' + Date.now() + '@phusanansinh.com';
          const desc = ((m.reason || '').replace(/[\r\n]+/g, ' ')) + ' | Phong Kham An Sinh | DT: 0899 268 299';
          calLines.push(
            'BEGIN:VEVENT',
            'UID:' + uid,
            'DTSTART;TZID=Asia/Ho_Chi_Minh:' + fmtLocal(apptDate),
            'DTEND;TZID=Asia/Ho_Chi_Minh:' + fmtLocal(endDate),
            'SUMMARY:' + m.title + ' - An Sinh',
            'DESCRIPTION:' + desc,
            'LOCATION:Phong Kham An Sinh\\, Tu Son\\, Bac Ninh',
            'BEGIN:VALARM',
            'TRIGGER:-P1D',
            'ACTION:DISPLAY',
            'DESCRIPTION:Nhac lich kham: ' + m.title,
            'END:VALARM',
            'END:VEVENT',
          );
        }
        calLines.push('END:VCALENDAR');
        const icsContent = calLines.join('\r\n') + '\r\n';

        // Trigger download
        const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = bCtx.milestones.length === 1 ? 'lich-kham-tuan-' + bCtx.milestones[0].week + '.ics' : 'lich-kham-thai-ky.ics';
        a.style.display = 'none';
        document.body.appendChild(a);
        a.click();
        // Delay cleanup for mobile browsers
        setTimeout(() => {
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        }, 250);
        showToast('success', 'Đã tải file lịch!');
      });

      function showToast(type: string, msg: string) {
        const toast = document.getElementById("form-toast");
        const icon = document.getElementById("form-toast-icon");
        const msgEl = document.getElementById("form-toast-msg");
        const closeBtn = document.getElementById("form-toast-close");
        if (!toast || !icon || !msgEl) return;
        toast.className = `form-toast form-toast--${type}`;
        icon.textContent =
          type === "success" ? "✅" : type === "error" ? "❌" : "⏳";
        msgEl.textContent = msg;
        toast.hidden = false;
        closeBtn?.addEventListener(
          "click",
          () => {
            toast.hidden = true;
          },
          { once: true },
        );
        setTimeout(() => {
          toast.hidden = true;
        }, 5000);
      }
    </script>

    <BookingBottomSheet />
  </body>
</html>
