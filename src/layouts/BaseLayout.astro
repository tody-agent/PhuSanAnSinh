        <span>Hotline</span>
      </a>
    </div>

    <style>
      /* ── Header ── */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border-light);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
        gap: var(--space-lg);
      }

      .logo {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        text-decoration: none;
        flex-shrink: 0;
      }

      .logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
      }

      .logo-brand {
        font-size: 1.125rem;
        font-weight: 800;
        color: var(--primary);
      }

      .logo-sub {
        font-size: 0.6875rem;
        font-weight: 500;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .nav-list {
        display: flex;
        list-style: none;
        gap: var(--space-xs);
        align-items: center;
      }

      .nav-list > li > a {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--text-primary);
        transition: color var(--transition-fast);
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-sm);
      }

      .nav-list > li > a:hover {
        color: var(--primary);
        background: var(--primary-light);
      }

      /* ── Dropdown Trigger ── */
      .nav-dropdown-trigger {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--text-primary);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        transition: all var(--transition-fast);
      }

      .nav-dropdown-trigger:hover,
      .nav-has-dropdown:hover .nav-dropdown-trigger,
      .nav-dropdown-trigger[aria-expanded="true"] {
        color: var(--primary);
        background: var(--primary-light);
      }

      .dropdown-chevron {
        transition: transform var(--transition-fast);
        flex-shrink: 0;
      }

      .nav-dropdown-trigger[aria-expanded="true"] .dropdown-chevron {
        transform: rotate(180deg);
      }

      /* ── Dropdown Panel ── */
      .nav-has-dropdown {
        position: relative;
      }

      .nav-dropdown {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background: #fff;
        border-radius: var(--radius-lg);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12),
          0 4px 16px rgba(0, 0, 0, 0.06);
        border: 1px solid var(--border-light);
        padding: var(--space-md);
        min-width: 280px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 200ms ease, transform 200ms ease, visibility 200ms;
        z-index: 200;
      }

      .nav-has-dropdown:hover > .nav-dropdown,
      .nav-dropdown-trigger[aria-expanded="true"] + .nav-dropdown {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
      }

      /* invisible bridge to prevent gap hover flicker */
      .nav-has-dropdown::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        height: 12px;
      }

      /* ── Dropdown Items ── */
      .dropdown-grid {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .dropdown-item {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: 0.625rem 0.75rem;
        border-radius: var(--radius-sm);
        text-decoration: none;
        color: var(--text-primary);
        transition: all var(--transition-fast);
      }

      .dropdown-item:hover {
        background: var(--primary-light);
        color: var(--primary-dark);
      }

      .dropdown-item strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
      }

      .dropdown-desc {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 1px;
      }

      .dropdown-item:hover .dropdown-desc {
        color: var(--primary);
      }

      .dropdown-icon {
        font-size: 1.25rem;
        width: 2rem;
        text-align: center;
        flex-shrink: 0;
      }

      /* ── Mega Dropdown (Công cụ) ── */
      .nav-dropdown-mega {
        min-width: 480px;
        padding: 0;
      }

      .dropdown-mega-inner {
        display: flex;
      }

      .dropdown-tools {
        flex: 1;
        padding: var(--space-md);
      }

      .dropdown-tool-card {
        display: flex;
        align-items: flex-start;
        gap: var(--space-sm);
        padding: 0.75rem;
        border-radius: var(--radius-md);
        text-decoration: none;
        color: var(--text-primary);
        transition: all var(--transition-fast);
      }

      .dropdown-tool-card:hover {
        background: var(--primary-light);
      }

      .tool-icon {
        font-size: 1.5rem;
        width: 2.25rem;
        height: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: var(--surface-alt);
        border-radius: var(--radius-sm);
      }

      .dropdown-tool-card:hover .tool-icon {
        background: #fff;
      }

      .tool-info strong {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .tool-info span {
        display: block;
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 2px;
        line-height: 1.3;
      }

      .dropdown-tool-card:hover .tool-info strong {
        color: var(--primary-dark);
      }

      .dropdown-tool-card:hover .tool-info span {
        color: var(--primary);
      }

      /* ── Dropdown Promo Sidebar ── */
      .dropdown-promo {
        width: 180px;
        background: var(--surface-alt);
        border-left: 1px solid var(--border-light);
        padding: var(--space-md);
        border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      .promo-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .promo-link {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--primary);
        text-decoration: none;
        padding: 0.375rem 0;
        transition: color var(--transition-fast);
      }

      .promo-link:hover {
        color: var(--accent);
      }

      /* ── Header Actions ── */
      .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      .header-phone {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        font-weight: 600;
        color: var(--primary);
        font-size: 0.9375rem;
      }

      .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        min-height: 44px;
        min-width: 44px;
        align-items: center;
        justify-content: center;
      }

      .mobile-toggle span {
        width: 22px;
        height: 2px;
        background: var(--text-primary);
        border-radius: 2px;
        transition: var(--transition-fast);
      }

      /* ── Footer ── */
      .site-footer {
        background: var(--text-primary);
        color: #c9cdd4;
        padding: var(--space-4xl) 0 var(--space-xl);
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr repeat(3, 1fr);
        gap: var(--space-3xl);
      }

      .site-footer h4 {
        color: #fff;
        font-size: 1rem;
        margin-bottom: var(--space-lg);
      }

      .footer-desc {
        color: #9ca3af;
        font-size: 0.875rem;
        margin-top: var(--space-md);
      }

      .footer-col ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      .footer-col a {
        color: #9ca3af;
        font-size: 0.875rem;
        transition: color var(--transition-fast);
      }

      .footer-col a:hover {
        color: #fff;
      }

      .footer-contact li {
        display: flex;
        align-items: flex-start;
        gap: var(--space-sm);
        font-size: 0.875rem;
        color: #9ca3af;
      }

      .footer-contact svg {
        flex-shrink: 0;
        margin-top: 2px;
      }

      .footer-contact a {
        color: #9ca3af;
      }

      .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: var(--space-3xl);
        padding-top: var(--space-xl);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        font-size: 0.8125rem;
        color: #6b7280;
      }

      .footer-social {
        display: flex;
        gap: var(--space-md);
      }

      .footer-social a {
        color: #6b7280;
        transition: color var(--transition-fast);
      }

      .footer-social a:hover {
        color: var(--primary);
      }

      /* ── Sticky CTA Bar ── */
      .sticky-cta {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 99;
        background: var(--text-primary);
        padding: var(--space-sm) var(--space-md);
        justify-content: space-around;
      }

      .sticky-cta-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        color: #c9cdd4;
        font-size: 0.6875rem;
        font-weight: 500;
        text-decoration: none;
        min-height: 44px;
        min-width: 44px;
        justify-content: center;
        padding: var(--space-xs);
        transition: color var(--transition-fast);
      }

      .sticky-cta-item:hover {
        color: #fff;
      }

      .sticky-cta-primary {
        color: #fff;
        background: var(--accent);
        border-radius: var(--radius-md);
        padding: var(--space-xs) var(--space-lg);
      }

      .sticky-cta-primary:hover {
        background: var(--accent-dark);
        color: #fff;
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .main-nav {
          display: none;
          position: absolute;
          top: 72px;
          left: 0;
          right: 0;
          background: #fff;
          border-bottom: 1px solid var(--border);
          z-index: 99;
          box-shadow: var(--shadow-lg);
          overflow-x: hidden;
          overflow-y: auto;
          max-height: calc(100vh - 72px);
          max-height: calc(100dvh - 72px);
        }

        .main-nav.is-open {
          display: block;
        }

        .nav-list {
          flex-direction: column;
          gap: 0;
          padding: var(--space-sm) 0;
        }

        .nav-list > li > a {
          display: block;
          padding: 0.75rem var(--space-lg);
          border-radius: 0;
        }

        .nav-has-dropdown {
          position: static;
        }

        .nav-dropdown-trigger {
          display: flex;
          width: 100%;
          padding: 0.75rem var(--space-lg);
          border-radius: 0;
          justify-content: space-between;
        }

        .nav-dropdown {
          position: static;
          transform: none;
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
          box-shadow: none;
          border: none;
          border-radius: 0;
          min-width: auto !important;
          max-width: 100%;
          width: 100%;
          padding: 0;
          display: none;
          background: var(--surface-alt);
        }

        .nav-dropdown.is-open {
          display: block;
        }

        .nav-dropdown-mega {
          min-width: auto !important;
        }

        .dropdown-mega-inner {
          flex-direction: column;
        }

        .dropdown-promo {
          width: 100%;
          border-left: none;
          border-top: 1px solid var(--border-light);
          border-radius: 0;
          flex-direction: row;
          flex-wrap: wrap;
          padding: var(--space-sm) var(--space-lg);
        }

        .promo-label {
          width: 100%;
        }

        .dropdown-grid {
          width: 100%;
          overflow: hidden;
        }

        .dropdown-tools {
          padding: var(--space-sm) 0;
          width: 100%;
        }

        .dropdown-item {
          padding: 0.625rem var(--space-lg);
          width: 100%;
          box-sizing: border-box;
        }

        .dropdown-tool-card {
          padding: 0.625rem var(--space-lg);
          width: 100%;
          box-sizing: border-box;
        }

        .tool-icon {
          font-size: 1.25rem;
          width: 2rem;
          height: 2rem;
          min-width: 2rem;
        }

        .tool-info strong {
          font-size: 0.8125rem;
        }

        .tool-info span {
          font-size: 0.7rem;
        }

        .dropdown-icon {
          font-size: 1.125rem;
          width: 1.75rem;
          min-width: 1.75rem;
        }

        .nav-has-dropdown::after {
          display: none;
        }

        /* Disable hover-based dropdowns on mobile */
        .nav-has-dropdown:hover > .nav-dropdown {
          display: none;
        }
        .nav-has-dropdown:hover > .nav-dropdown.is-open {
          display: block;
        }

        .header-phone {
          display: none;
        }

        .mobile-toggle {
          display: flex;
        }

        .sticky-cta {
          display: flex;
        }

        body {
          padding-bottom: 64px;
        }

        .footer-grid {
          grid-template-columns: 1fr;
          gap: var(--space-xl);
        }

        .footer-bottom {
          flex-direction: column;
          gap: var(--space-md);
          text-align: center;
        }
      }

      @media (min-width: 769px) and (max-width: 1024px) {
        .footer-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .nav-dropdown-mega {
          min-width: 400px;
        }
      }
    </style>

    <script>
      // Mobile menu toggle
      const toggle = document.getElementById("mobile-toggle");
      const nav = document.getElementById("main-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          const isOpen = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!isOpen));
          nav.classList.toggle("is-open", !isOpen);
          // Close all nested dropdowns when closing mobile menu
          if (isOpen) {
            nav
              .querySelectorAll(".nav-dropdown.is-open")
              .forEach((d) => d.classList.remove("is-open"));
            nav
              .querySelectorAll('.nav-dropdown-trigger[aria-expanded="true"]')
              .forEach((t) => t.setAttribute("aria-expanded", "false"));
          }
        });
      }

      // Dropdown triggers (mobile accordion + desktop keyboard)
      document.querySelectorAll(".nav-dropdown-trigger").forEach((trigger) => {
        trigger.addEventListener("click", (e) => {
          const parent = (trigger as HTMLElement).closest(".nav-has-dropdown");
          const dropdown = parent?.querySelector(".nav-dropdown");
          if (!dropdown) return;

          const isExpanded = trigger.getAttribute("aria-expanded") === "true";

          // On mobile, close siblings first
          if (window.innerWidth <= 768) {
            document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
              if (t !== trigger) {
                t.setAttribute("aria-expanded", "false");
                t.closest(".nav-has-dropdown")
                  ?.querySelector(".nav-dropdown")
                  ?.classList.remove("is-open");
              }
            });
          }

          trigger.setAttribute("aria-expanded", String(!isExpanded));
          dropdown.classList.toggle("is-open", !isExpanded);
        });
      });

      // Close dropdowns on outside click
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (
          !target.closest(".nav-has-dropdown") &&
          !target.closest(".mobile-toggle")
        ) {
          document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
            t.setAttribute("aria-expanded", "false");
          });
          document.querySelectorAll(".nav-dropdown.is-open").forEach((d) => {
            d.classList.remove("is-open");
          });
        }
      });

      // Keyboard: Escape closes dropdown
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          document.querySelectorAll(".nav-dropdown-trigger").forEach((t) => {
            t.setAttribute("aria-expanded", "false");
          });
          document.querySelectorAll(".nav-dropdown.is-open").forEach((d) => {
            d.classList.remove("is-open");
          });
        }
      });

      // Header scroll effect
      const header = document.getElementById("site-header");
      if (header) {
        window.addEventListener(
          "scroll",
          () => {
            header.style.boxShadow =
              window.scrollY > 10 ? "var(--shadow-sm)" : "none";
          },
          { passive: true }
        );
      }
    </script>
  </body>
</html>
