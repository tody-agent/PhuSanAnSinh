---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Phòng khám sản phụ khoa uy tín tại Từ Sơn, Bắc Ninh. Siêu âm 5D, khám thai, điều trị phụ khoa, nam khoa, vô sinh. Bác sĩ chuyên khoa 20+ năm kinh nghiệm. Đặt lịch ngay!",
  ogImage = "/og-image.jpg",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>

    <!-- Schema.org MedicalClinic -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MedicalClinic",
        name: "Phòng Khám An Sinh",
        alternateName: "Sản Phụ Khoa An Sinh",
        url: "https://phusanansinh.com",
        telephone: "+84899268299",
        email: "phusanansinh.com@gmail.com",
        address: {
          "@type": "PostalAddress",
          streetAddress: "416 Minh Khai, Đồng Nguyên",
          addressLocality: "Từ Sơn",
          addressRegion: "Bắc Ninh",
          addressCountry: "VN",
        },
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
            ],
            opens: "17:00",
            closes: "22:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Sunday",
            opens: "08:00",
            closes: "22:00",
          },
        ],
        medicalSpecialty: [
          "Obstetrics",
          "Gynecology",
          "Andrology",
          "ReproductiveEndocrinology",
        ],
        sameAs: ["https://www.facebook.com/phongkhamansinh"],
      })}
    />

    <!-- Schema.org SiteNavigationElement -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SiteNavigationElement",
        name: [
          "Dịch vụ",
          "Công cụ thai kỳ",
          "Bài viết",
          "Kiến thức y khoa",
          "Liên hệ",
        ],
        url: [
          "https://phusanansinh.com/sieu-am-5d",
          "https://phusanansinh.com/tinh-ngay-rung-trung",
          "https://phusanansinh.com/blog",
          "https://phusanansinh.com/san-phu-handbook",
          "https://phusanansinh.com/#lien-he",
        ],
      })}
    />
